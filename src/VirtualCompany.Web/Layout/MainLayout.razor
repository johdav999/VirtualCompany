@inherits LayoutComponentBase
<div class="page">
    <div class="sidebar">
        @* Keep the mobile nav toggle interactive without making the page body interactive. *@
        <NavMenu @rendermode="InteractiveServer" />
    </div>

    <main>
        <div class="top-row px-4"></div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
