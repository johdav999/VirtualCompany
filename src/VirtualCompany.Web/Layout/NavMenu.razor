@inject OnboardingApiClient ApiClient
@inject FinanceAccessResolver FinanceAccessResolver
@inject NavigationManager Navigation
@implements IDisposable

@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.WebUtilities

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Virtual Company</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="onboarding">
                <span class="bi bi-building-add" aria-hidden="true"></span> Onboarding
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="dashboard">
                <span class="bi bi-grid-1x2" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>
        @if (!string.IsNullOrWhiteSpace(financeHref))
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@financeHref">
                    <span class="bi bi-cash-stack" aria-hidden="true"></span> Finance
                </NavLink>
            </div>
        }
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="agents">
                <span class="bi bi-people" aria-hidden="true"></span> Agents
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="workflows">
                <span class="bi bi-diagram-3" aria-hidden="true"></span> Workflows
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="inbox">
                <span class="bi bi-bell" aria-hidden="true"></span> Inbox
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="activity-feed">
                <span class="bi bi-activity" aria-hidden="true"></span> Activity
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="approvals">
                <span class="bi bi-check2-square" aria-hidden="true"></span> Approvals
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="audit">
                <span class="bi bi-list-check" aria-hidden="true"></span> Audit
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="briefing-preferences">
                <span class="bi bi-bell" aria-hidden="true"></span> Briefing delivery
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private string? financeHref;
    private CurrentUserContextViewModel? currentUser;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += HandleLocationChanged;

        try
        {
            currentUser = await ApiClient.GetCurrentUserContextAsync();
            RefreshFinanceHref();
        }
        catch (OnboardingApiException)
        {
            financeHref = null;
        }
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        RefreshFinanceHref();
        _ = InvokeAsync(StateHasChanged);
    }

    private void RefreshFinanceHref()
    {
        var requestedCompanyId = TryGetCompanyIdFromUri(Navigation.Uri);
        financeHref = FinanceAccessResolver.BuildNavigationHref(currentUser, requestedCompanyId);
    }

    private static Guid? TryGetCompanyIdFromUri(string uri)
    {
        var absoluteUri = new Uri(uri, UriKind.Absolute);
        if (!QueryHelpers.ParseQuery(absoluteUri.Query).TryGetValue(FinanceRoutes.CompanyIdQueryKey, out var values))
        {
            return null;
        }

        return Guid.TryParse(values.FirstOrDefault(), out var companyId) ? companyId : null;
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
