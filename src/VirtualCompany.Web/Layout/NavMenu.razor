        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="agents">
                <span class="bi bi-people" aria-hidden="true"></span> Agents
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="workflows">
