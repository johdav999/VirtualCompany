@using VirtualCompany.Web.Services

<a class="wizard-card finance-metric-card text-decoration-none text-reset" href="@Kpi.Href">
    <div class="finance-kpi-card__top">
        <span class="@IconClass" aria-hidden="true">@Kpi.Icon</span>
        <span class="finance-kpi-card__label">@Kpi.Label</span>
    </div>
    <div class="finance-kpi-card__value">@Kpi.Value</div>
    @if (!string.IsNullOrWhiteSpace(Kpi.ComparisonText))
    {
        <div class="@ComparisonClass">@TrendPrefix @Kpi.ComparisonText</div>
    }
</a>

@code {
    [Parameter, EditorRequired]
    public FinanceKpiViewModel Kpi { get; set; } = default!;

    private string IconClass => $"finance-overview-icon finance-overview-icon--{ToneClass}";
    private string ComparisonClass => $"finance-kpi-card__trend finance-overview-tone--{ToneClass}";
    private string TrendPrefix => Kpi.Tone switch
    {
        FinanceKpiTone.Positive => "+",
        FinanceKpiTone.Warning or FinanceKpiTone.Danger => "-",
        _ => string.Empty
    };

    private string ToneClass => Kpi.Tone switch
    {
        FinanceKpiTone.Positive => "positive",
        FinanceKpiTone.Warning => "warning",
        FinanceKpiTone.Danger => "danger",
        _ => "neutral"
    };
}
