<section class="wizard-card finance-state-card" aria-live="polite" aria-busy="true">
    <div class="d-flex align-items-center gap-3">
        <div class="spinner-border text-primary" role="status" aria-hidden="true"></div>
        <div>
            <h2 class="h5 mb-2">@Title</h2>
            <p class="text-body-secondary mb-0">@Message</p>
        </div>
    </div>
</section>

@code {
    [Parameter]
    public string Title { get; set; } = "Loading finance summary";

    [Parameter]
    public string Message { get; set; } = "Fetching the latest tenant-scoped finance data.";
}