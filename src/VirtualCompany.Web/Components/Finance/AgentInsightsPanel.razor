@using System.Globalization
@using VirtualCompany.Web.Services

<section class="wizard-card wizard-card--compact finance-agent-insights-panel" data-testid="@TestId">
    <div class="cockpit-card__header">
        <div>
            <span class="dashboard-kicker">Agent insights</span>
            <h3 class="h6 mt-2 mb-1">@Title</h3>
            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <p class="text-body-secondary mb-0">@Subtitle</p>
            }
        </div>
    </div>

    @if (Items.Count == 0)
    {
        <p class="text-body-secondary mt-3 mb-0">@EmptyMessage</p>
    }
    else
    {
        <div class="finance-agent-insights-list mt-3">
            @foreach (var insight in Items)
            {
                <article class="finance-insight-card">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="d-flex flex-wrap gap-2 align-items-center">
                                <span class="@SeverityClass(insight.Severity)">@FormatLabel(insight.Severity)</span>
                                <span class="badge text-bg-light">@FormatLabel(insight.Status)</span>
                            </div>
                            <strong class="d-block mt-2">@insight.CheckName</strong>
                            <div class="text-body-secondary mt-1">@insight.Message</div>
                            <div class="small mt-2">@insight.Recommendation</div>
                            <small class="text-body-secondary d-block mt-2">
                                @ResolveEntitySummary(insight) | Updated @FormatDateTime(insight.UpdatedAt)
                            </small>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>

@code {
    [Parameter] public string Title { get; set; } = "Agent insights";
    [Parameter] public string? Subtitle { get; set; } = "Persisted finance agent insights for the selected entity.";
    [Parameter] public string EmptyMessage { get; set; } = "No agent insights are linked to this record.";
    [Parameter] public string TestId { get; set; } = "agent-insights-panel";
    [Parameter] public IReadOnlyList<NormalizedFinanceInsightResponse> Items { get; set; } = [];

    private static string SeverityClass(string severity) =>
        $"finance-risk-pill finance-risk-pill--{NormalizeToken(severity)}";

    private static string ResolveEntitySummary(NormalizedFinanceInsightResponse insight)
    {
        var entity = insight.EntityReference;
        if (!string.IsNullOrWhiteSpace(entity.DisplayName))
        {
            return entity.DisplayName!;
        }

        return $"{FormatLabel(entity.EntityType)} {entity.EntityId}";
    }

    private static string FormatDateTime(DateTime value) =>
        value == default
            ? "n/a"
            : value.ToLocalTime().ToString("yyyy-MM-dd HH:mm", CultureInfo.InvariantCulture);

    private static string FormatLabel(string? value) =>
        string.IsNullOrWhiteSpace(value)
            ? "n/a"
            : string.Join(" ", value.Trim().Replace("-", "_", StringComparison.Ordinal).Split('_', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));

    private static string NormalizeToken(string? value) =>
        string.IsNullOrWhiteSpace(value)
            ? "neutral"
            : value.Trim().ToLowerInvariant().Replace('_', '-');
}