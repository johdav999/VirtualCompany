<section class="wizard-card finance-state-card" role="alert">
    <h2 class="h5 mb-2">@Title</h2>
    <p class="mb-3">@Message</p>
    @if (OnRetry.HasDelegate)
    {
        <button class="btn btn-outline-danger" type="button" @onclick="(() => OnRetry.InvokeAsync())">@RetryText</button>
    }
</section>

@code {
    [Parameter]
    public string Title { get; set; } = "Finance data is unavailable";

    [Parameter]
    public string Message { get; set; } = "The finance request failed.";

    [Parameter]
    public string RetryText { get; set; } = "Retry";

    [Parameter]
    public EventCallback OnRetry { get; set; }
}