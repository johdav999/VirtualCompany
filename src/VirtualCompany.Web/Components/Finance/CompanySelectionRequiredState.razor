<section class="py-4">
    <h1>Select a company to open Finance</h1>
    <p class="text-body-secondary mb-3">@Message</p>
    <a class="btn btn-primary" href="/dashboard">Open dashboard</a>
</section>

@code {
    [Parameter]
    public string Message { get; set; } =
        "Finance pages stay scoped to the active company. Select a company before opening the finance workspace.";
}
