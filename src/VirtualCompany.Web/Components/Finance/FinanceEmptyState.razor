<section class="wizard-card finance-state-card">
    <h2 class="h5 mb-2">@Title</h2>
    <p class="text-body-secondary mb-0">@Message</p>
</section>

@code {
    [Parameter]
    public string Title { get; set; } = "Nothing to show";

    [Parameter]
    public string Message { get; set; } = "No finance data is available for the active tenant.";
}