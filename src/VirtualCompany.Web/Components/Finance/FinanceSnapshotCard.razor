@using System.Globalization
@using VirtualCompany.Web.Services
@inject NavigationManager Navigation

<article class="wizard-card finance-snapshot-card" data-testid="finance-snapshot-card">
    <div class="cockpit-card__header">
        <div>
            <span class="dashboard-kicker">Finance snapshot</span>
            <h4 class="h6 mt-2 mb-1">Decision-ready cash view</h4>
            <p class="text-body-secondary mb-0">Live cash, receivables, and payables for the active company.</p>
        </div>
    </div>

    @if (Snapshot is null || !Snapshot.HasFinanceData)
    {
        <div class="finance-snapshot-card__empty mt-3" data-testid="finance-snapshot-empty">
            <p class="text-body-secondary mb-3">Finance data is missing or incomplete for this workspace.</p>
            <a class="btn btn-primary"
               data-testid="connect-accounting-cta"
               href="@DashboardRoutes.BuildFinancePath(CompanyId, FinanceRoutes.Home, "open-workspace", "this-month")"
               @onclick="NavigateToFinanceHomeAsync"
               @onclick:preventDefault="true">Connect accounting</a>
        </div>
    }
    else
    {
        <div class="finance-snapshot-card__grid mt-3">
            <section class="finance-snapshot-card__metric">
                <div class="dashboard-kicker">Current cash balance</div>
                <strong class="finance-snapshot-card__value" data-testid="executive-cockpit-cash-position">@FormatCurrency(Snapshot.CurrentCashBalance, Snapshot.Currency)</strong>
            </section>
            <section class="finance-snapshot-card__metric">
                <div class="dashboard-kicker">Expected incoming cash</div>
                <strong class="finance-snapshot-card__value" data-testid="executive-cockpit-expected-incoming-cash">@FormatCurrency(Snapshot.ExpectedIncomingCash, Snapshot.Currency)</strong>
            </section>
            <section class="finance-snapshot-card__metric">
                <div class="dashboard-kicker">Expected outgoing cash</div>
                <strong class="finance-snapshot-card__value" data-testid="executive-cockpit-expected-outgoing-cash">@FormatCurrency(Snapshot.ExpectedOutgoingCash, Snapshot.Currency)</strong>
            </section>
            <section class="finance-snapshot-card__metric">
                <div class="dashboard-kicker">Overdue receivables</div>
                <strong class="finance-snapshot-card__value" data-testid="executive-cockpit-overdue-receivables">@FormatCurrency(Snapshot.OverdueReceivables, Snapshot.Currency)</strong>
            </section>
            <section class="finance-snapshot-card__metric">
                <div class="dashboard-kicker">Upcoming payables</div>
                <strong class="finance-snapshot-card__value" data-testid="executive-cockpit-upcoming-payables">@FormatCurrency(Snapshot.UpcomingPayables, Snapshot.Currency)</strong>
            </section>
        </div>
        <p class="text-body-secondary mt-3 mb-0">
            As of @Snapshot.AsOfUtc.ToLocalTime():g.
            Upcoming window: next @Snapshot.UpcomingWindowDays day(s).
        </p>
        <div class="dashboard-actions mt-3">
            <a class="btn btn-sm btn-outline-primary"
               href="@DashboardRoutes.BuildFinancePath(CompanyId, FinanceRoutes.CashPosition, "view-cash-position", "this-month")"
               @onclick="NavigateToCashPositionAsync"
               @onclick:preventDefault="true">Open cash position</a>
            <a class="btn btn-sm btn-outline-secondary"
               href="@DashboardRoutes.BuildFinancePath(CompanyId, FinanceRoutes.Home, "open-workspace", "this-month")"
               @onclick="NavigateToFinanceHomeAsync"
               @onclick:preventDefault="true">Open finance workspace</a>
        </div>
    }
</article>

@code {
    [Parameter]
    public Guid? CompanyId { get; set; }

    [Parameter]
    public DashboardFinanceSnapshotViewModel? Snapshot { get; set; }
    [Parameter] public EventCallback<DashboardActionTelemetryContext> OnActionClick { get; set; }

    private static string FormatCurrency(decimal amount, string currency) =>
        $"{currency} {amount.ToString("N2", CultureInfo.InvariantCulture)}";

    private async Task NavigateToFinanceHomeAsync()
    {
        var route = DashboardRoutes.BuildFinancePath(CompanyId, FinanceRoutes.Home, "open-workspace", "this-month");
        if (OnActionClick.HasDelegate)
        {
            await OnActionClick.InvokeAsync(new DashboardActionTelemetryContext("finance-snapshot", "open-finance-home", route, Label: "Finance workspace"));
        }

        Navigation.NavigateTo(route);
    }

    private async Task NavigateToCashPositionAsync()
    {
        var route = DashboardRoutes.BuildFinancePath(CompanyId, FinanceRoutes.CashPosition, "view-cash-position", "this-month");
        if (OnActionClick.HasDelegate)
        {
            await OnActionClick.InvokeAsync(new DashboardActionTelemetryContext("finance-snapshot", "open-cash-position", route, Label: "Cash position"));
        }

        Navigation.NavigateTo(route);
    }
}