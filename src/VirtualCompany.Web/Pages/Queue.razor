@page "/queue"
@rendermode InteractiveServer
@inject OnboardingApiClient OnboardingApiClient
@inject ActionInsightApiClient ActionInsightApiClient
@inject NavigationManager Navigation

<PageTitle>Action Queue</PageTitle>

@if (isLoading)
{
    <section class="py-4">
        <h1>Action queue</h1>
        <p class="text-body-secondary mb-0">Loading tenant-scoped prioritized actions...</p>
    </section>
}
else if (CompanyId is null)
{
    <section class="py-4 dashboard-hero">
        <div class="wizard-card">
            <h1>Select a company</h1>
            <p class="text-body-secondary">Choose the company where you want to review the full action queue.</p>

            @if (activeMemberships.Count == 0)
            {
                <p class="mb-0">No active company memberships are available yet.</p>
            }
            else
            {
                <div class="template-grid">
                    @foreach (var membership in activeMemberships)
                    {
                        <a class="template-card text-decoration-none text-reset" href="@BuildQueueUri(membership.CompanyId, 1, DefaultPageSize)">
                            <strong>@membership.CompanyName</strong>
                            <div class="text-body-secondary mt-2">Role: @membership.MembershipRole</div>
                        </a>
                    }
                </div>
            }
        </div>
    </section>
}
else
{
    <section class="py-4 dashboard-hero">
        <div class="dashboard-shell">
            <div class="wizard-card dashboard-summary">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <span class="dashboard-kicker">Action queue</span>
                        <h1>@(companyAccess?.CompanyName ?? "Action queue")</h1>
                        <p class="text-body-secondary mb-0">All prioritized actions for the selected company, ordered deterministically for stable paging.</p>
                    </div>
                    @if (CompanyId is Guid companyId)
                    {
                        <a class="btn btn-outline-secondary" href="@($"/dashboard?companyId={companyId:D}")">Back to dashboard</a>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="alert alert-danger mt-4 mb-0">@errorMessage</div>
                }
                else if (queuePage?.Items.Count == 0)
                {
                    <p class="text-body-secondary mt-4 mb-0">No actionable insights need attention right now.</p>
                }
                else if (queuePage is not null)
                {
                    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
                        <span class="text-body-secondary">
                            Showing page @queuePage.PageNumber of @(queuePage.TotalPages == 0 ? 1 : queuePage.TotalPages)
                            | @queuePage.TotalCount total item@(queuePage.TotalCount == 1 ? string.Empty : "s")
                        </span>
                    </div>

                    <div class="list-group">
                        @foreach (var item in queuePage.Items)
                        {
                            <article class="list-group-item">
                                <div class="d-flex justify-content-between align-items-start gap-3">
                                    <div class="flex-grow-1">
                                        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                            <span class="badge text-bg-dark">@FormatPriority(item.Priority)</span>
                                            <span class="text-body-secondary small">@FormatInsightType(item.Type)</span>
                                        </div>
                                        <h2 class="h6 mb-1">@item.Title</h2>
                                        <p class="text-body-secondary mb-2">@item.Reason</p>
                                        <div class="small text-body-secondary d-flex flex-wrap gap-3">
                                            <span>Owner: @item.Owner</span>
                                            <span>@FormatDueState(item)</span>
                                            <span>Impact: @item.ImpactScore</span>
                                        </div>
                                    </div>
                                    <a class="btn btn-sm btn-outline-primary" href="@item.DeepLink">Open work</a>
                                </div>
                            </article>
                        }
                    </div>

                    @if (queuePage.TotalPages > 1)
                    {
                        <div class="dashboard-actions mt-4">
                            @if (queuePage.HasPreviousPage)
                            {
                                <a class="btn btn-outline-secondary" href="@BuildQueueUri(CompanyId!.Value, queuePage.PageNumber - 1, queuePage.PageSize)">Previous</a>
                            }
                            else
                            {
                                <button class="btn btn-outline-secondary" disabled>Previous</button>
                            }

                            @if (queuePage.HasNextPage)
                            {
                                <a class="btn btn-outline-primary" href="@BuildQueueUri(CompanyId!.Value, queuePage.PageNumber + 1, queuePage.PageSize)">Next</a>
                            }
                            else
                            {
                                <button class="btn btn-outline-primary" disabled>Next</button>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </section>
}

@code {
    private const int DefaultPageSize = 20;
    private const int MaxPageSize = 100;

    [SupplyParameterFromQuery(Name = "companyId")]
    public Guid? CompanyId { get; set; }

    [SupplyParameterFromQuery(Name = "page")]
    public int? Page { get; set; }

    [SupplyParameterFromQuery(Name = "pageNumber")]
    public int PageNumber { get; set; } = 1;

    [SupplyParameterFromQuery(Name = "pageSize")]
    public int PageSize { get; set; } = DefaultPageSize;

    private bool isLoading = true;
    private string? errorMessage;
    private CurrentUserContextViewModel? currentUser;
    private CompanyAccessViewModel? companyAccess;
    private PagedActionQueueResultViewModel? queuePage;

    private IReadOnlyList<CompanyMembershipViewModel> activeMemberships =>
        currentUser?.Memberships
            .Where(x => string.Equals(x.Status, "active", StringComparison.OrdinalIgnoreCase))
            .ToList()
        ?? [];

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        companyAccess = null;
        queuePage = null;

        try
        {
            currentUser = await OnboardingApiClient.GetCurrentUserContextAsync();
            if (CompanyId is null && currentUser?.ActiveCompany is not null)
            {
                Navigation.NavigateTo(BuildQueueUri(currentUser.ActiveCompany.CompanyId, 1, NormalizePageSize(PageSize)), replace: true);
                return;
            }

            if (CompanyId is Guid companyId)
            {
                var pageNumber = NormalizePageNumber(Page ?? PageNumber);
                companyAccess = await OnboardingApiClient.GetCompanyAccessAsync(companyId);
                if (companyAccess is not null)
                {
                    queuePage = await ActionInsightApiClient.GetAllActionsAsync(
                        companyId,
                        pageNumber,
                        NormalizePageSize(PageSize));
                }
            }
        }
        catch (OnboardingApiException ex)
        {
            errorMessage = ex.Message;
            queuePage = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private static int NormalizePageNumber(int pageNumber) => pageNumber <= 0 ? 1 : pageNumber;

    private static int NormalizePageSize(int pageSize) => Math.Clamp(pageSize <= 0 ? DefaultPageSize : pageSize, 1, MaxPageSize);

    private static string BuildQueueUri(Guid companyId, int pageNumber, int pageSize) =>
        QueueRoutes.BuildPath(companyId, NormalizePageNumber(pageNumber), NormalizePageSize(pageSize));

    private static string FormatPriority(string priority) =>
        priority.Replace("_", " ", StringComparison.Ordinal).ToUpperInvariant();

    private static string FormatInsightType(string type) =>
        type.Replace("_", " ", StringComparison.Ordinal);

    private static string FormatDueState(ActionQueueItemViewModel item)
    {
        var sla = item.SlaState.Replace("_", " ", StringComparison.Ordinal);
        if (item.DueUtc is not DateTime dueUtc)
        {
            return $"SLA: {sla}";
        }

        return $"{sla}: {dueUtc.ToLocalTime():g}";
    }
}