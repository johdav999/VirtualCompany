@page "/finance"
@rendermode InteractiveServer
@inherits FinancePageBase

<PageTitle>Finance</PageTitle>

<FinancePageLayout
    IsLoading="@IsLoading"
    AccessState="@AccessState"
    ErrorMessage="@ErrorMessage"
    Title="Finance"
    Description="Open tenant-scoped finance workflows from a single module shell."
    LoadingMessage="Loading finance workspace...">
    @if (IsEntryStateLoading)
    {
        <FinanceLoadingState
            Title="Preparing finance workspace"
            Message="Checking whether this company needs finance setup before the workspace can load." />
    }
    else if (!string.IsNullOrWhiteSpace(EntryStateErrorMessage))
    {
        <FinanceErrorState
            Title="Finance workspace is unavailable"
            Message="@EntryStateErrorMessage"
            RetryText="Reload finance workspace"
            OnRetry="@RefreshEntryStateAsync" />
    }
    else if (IsFinanceInitializing)
    {
        <section class="wizard-card finance-state-card" aria-live="polite" aria-busy="true">
            <div class="d-flex flex-column gap-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="spinner-border text-primary" role="status" aria-hidden="true"></div>
                    <div>
                        <div class="small text-uppercase text-body-secondary fw-semibold">@(IsFinanceRequested ? "Initialization requested" : "Initialization in progress")</div>
                        <h2 class="h5 mb-2">@FinanceProgressTitle</h2>
                        <p class="text-body-secondary mb-0">@FinanceStateMessage</p>
                    </div>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-outline-primary" type="button" @onclick="RefreshEntryStateAsync">Refresh status</button>
                    <span class="text-body-secondary align-self-center">This page refreshes automatically while setup is running.</span>
                </div>
            </div>
        </section>
    }
    else if (IsFinanceFailed)
    {
        <section class="wizard-card finance-state-card" aria-live="assertive">
            <div class="d-flex flex-column gap-3">
                <div>
                    <div class="small text-uppercase text-danger fw-semibold">Initialization failed</div>
                    <h2 class="h5 mb-2">Finance setup needs attention</h2>
                    <p class="text-body-secondary mb-0">@FinanceStateMessage</p>
                </div>
                <p class="text-body-secondary mb-0">
                    Retrying is safe. If a finance seed job is already active, the server keeps the current job instead of enqueueing a duplicate.
                </p>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-primary" type="button" @onclick="RetryFinanceSetupAsync">Retry finance setup</button>
                    <button class="btn btn-outline-secondary" type="button" @onclick="RefreshEntryStateAsync">Refresh status</button>
                </div>
            </div>
        </section>
    }
    else if (!IsFinanceReady)
    {
        <section class="wizard-card finance-state-card" aria-live="polite">
            <div class="d-flex flex-column gap-3">
                <div>
                    <div class="small text-uppercase text-body-secondary fw-semibold">Finance data required</div>
                    <h2 class="h5 mb-2">Generate finance data</h2>
                    <p class="text-body-secondary mb-0">@FinanceStateMessage</p>
                </div>
                @if (!string.IsNullOrWhiteSpace(ManualSeedErrorMessage))
                {
                    <div class="alert alert-danger mb-0" role="alert">
                        @ManualSeedErrorMessage
                    </div>
                }
                <div class="d-flex flex-wrap gap-2">
                    <button id="finance-seed-action" class="btn btn-primary" type="button" @onclick="HandleManualSeedActionAsync" disabled="@IsSubmittingManualSeed">
                        @(IsSubmittingManualSeed ? "Submitting..." : ManualSeedActionLabel)
                    </button>
                    <button class="btn btn-outline-secondary" type="button" @onclick="RefreshEntryStateAsync" disabled="@IsSubmittingManualSeed">Refresh status</button>
                </div>
                <p class="text-body-secondary mb-0">@ManualSeedActionDescription</p>
            </div>
        </section>
    }
    else
    {
        @if (ShowFinanceReadyBanner)
        {
            <div class="alert alert-success" role="status">
                <div class="fw-semibold">Finance data is ready.</div>
                <div class="text-body-secondary">
                    Open a finance section to continue.
                </div>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(ManualSeedErrorMessage))
        {
            <div class="alert alert-danger" role="alert">
                @ManualSeedErrorMessage
            </div>
        }
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <div class="text-body-secondary">@ManualSeedActionDescription</div>
            <button id="finance-seed-action" class="btn btn-outline-primary" type="button" @onclick="HandleManualSeedActionAsync" disabled="@IsSubmittingManualSeed">
                @(IsSubmittingManualSeed ? "Submitting..." : ManualSeedActionLabel)
            </button>
        </div>
        @if (IsSimulationControlPanelVisible)
        {
            <section class="wizard-card finance-state-card mb-4" aria-live="polite">
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                        <div>
                            <div class="small text-uppercase text-body-secondary fw-semibold">Company simulation</div>
                            <h2 class="h5 mb-2">Finance progression controls</h2>
                            <p class="text-body-secondary mb-0">Control the active company simulation and keep finance queries aligned with the current simulated timeline.</p>
                            <p class="text-body-secondary mb-0">Generated records flow into the existing finance lists and detail views for the active company.</p>
                        </div>
                        @if (SupportsSimulationRefresh)
                        {
                            <div class="d-flex flex-wrap gap-2 align-items-center">
                                <span class="@SimulationStatusBadgeClass">@SimulationStatusLabel</span>
                                <button class="btn btn-outline-secondary" type="button" @onclick="RefreshSimulationStateAsync" disabled="@IsSimulationBusy">Refresh</button>
                            </div>
                        }
                    </div>
                    @if (IsSimulationStateLoading && SimulationState is null)
                    {
                        <div class="text-body-secondary">Loading simulation state...</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(SimulationStateErrorMessage))
                    {
                        <div class="alert alert-danger mb-0" role="alert">@SimulationStateErrorMessage</div>
                    }
                    else if (!string.IsNullOrWhiteSpace(SimulationDisabledReason))
                    {
                        <div class="alert alert-warning mb-0" role="alert">@SimulationDisabledReason</div>
                    }

                    else if (!string.IsNullOrWhiteSpace(SimulationActionMessage))
                    {
                        <div class="alert alert-success mb-0" role="status">@SimulationActionMessage</div>
                    }
                    <div class="row g-3">
                        <div class="col-12 col-lg-4">
                            <div class="border rounded-3 p-3 h-100">
                                <div class="small text-uppercase text-body-secondary fw-semibold mb-1">Current simulated time</div>
                                <div class="fw-semibold">@CurrentSimulatedDateTimeLabel</div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-4">
                            <div class="border rounded-3 p-3 h-100">
                                <div class="small text-uppercase text-body-secondary fw-semibold mb-1">Last progression</div>
                                <div class="fw-semibold">@LastProgressionTimestampLabel</div>
                                <div class="small text-body-secondary mt-1">@LastProgressionMetadataLabel</div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-4">
                            <div class="border rounded-3 p-3 h-100">
                                <div class="small text-uppercase text-body-secondary fw-semibold mb-1">Generation</div>
                                <div class="fw-semibold">@GenerationStateLabel</div>
                            </div>
                        </div>
                    </div>
                    <div class="small text-uppercase text-body-secondary fw-semibold">Simulation status</div>
                    <div class="text-body-secondary">@SimulationStatusDescription</div>
                    <div class="form-check form-switch">
                        <input id="finance-simulation-generation" class="form-check-input" type="checkbox" checked="@RequestedGenerationEnabled" @onchange="HandleGenerationEnabledChangedAsync" disabled="@(!CanEditGenerationEnabled)" />
                        <label class="form-check-label fw-semibold" for="finance-simulation-generation">Generate financial data during simulation</label>
                    </div>
                    <p class="text-body-secondary mb-0">@GenerationToggleHelpText</p>
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-primary" type="button" @onclick="HandleStartSimulationAsync" disabled="@(!CanStartSimulation)">Start</button>
                        <button class="btn btn-outline-secondary" type="button" @onclick="HandlePauseSimulationAsync" disabled="@(!CanPauseSimulation)">Pause</button>
                        @if (SupportsStepForwardOneDay) { <button class="btn btn-outline-primary" type="button" @onclick="HandleStepForwardSimulationAsync" disabled="@(!CanStepForwardSimulation)">Step forward 1 day</button> }
                        <button class="btn btn-outline-danger" type="button" @onclick="HandleStopSimulationAsync" disabled="@(!CanStopSimulation)">Stop</button>
                    </div>
                    @if (RecentSimulationHistory.Count > 0)
                    {
                        <div class="pt-2 border-top">
                            <div class="small text-uppercase text-body-secondary fw-semibold mb-3">Recent simulation history</div>
                            <div class="d-flex flex-column gap-3">
                                @foreach (var run in RecentSimulationHistory)
                                {
                                    <div class="border rounded-3 p-3">
                                        <div class="d-flex flex-wrap justify-content-between gap-2 mb-2">
                                            <div class="fw-semibold">Session @run.SessionId.ToString("N")[..8]</div>
                                            <span class="badge rounded-pill text-bg-secondary">@ResolveSimulationStatusLabel(run.Status)</span>
                                        </div>
                                        <div class="small text-body-secondary mb-3">
                                            Started @run.StartedUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC
                                            @if (run.CompletedUtc.HasValue)
                                            {
                                                <span> | Completed @run.CompletedUtc.Value.ToString("yyyy-MM-dd HH:mm:ss") UTC</span>
                                            }
                                            <span> | Seed @run.Seed</span>
                                        </div>
                                        @if (run.Warnings.Count > 0 || run.Errors.Count > 0 || run.InjectedAnomalies.Count > 0)
                                        {
                                            <div class="small text-body-secondary mb-3">
                                                @if (run.InjectedAnomalies.Count > 0)
                                                {
                                                    <span>Anomalies: @string.Join(", ", run.InjectedAnomalies)</span>
                                                }
                                                @if (run.Warnings.Count > 0)
                                                {
                                                    <span> | Warnings: @string.Join(" | ", run.Warnings)</span>
                                                }
                                                @if (run.Errors.Count > 0)
                                                {
                                                    <span> | Errors: @string.Join(" | ", run.Errors)</span>
                                                }
                                            </div>
                                        }
                                        @if (run.DayLogs.Count > 0)
                                        {
                                            <div class="table-responsive">
                                                <table class="table finance-table mb-0">
                                                    <thead>
                                                        <tr>
                                                            <th scope="col">Day</th>
                                                            <th scope="col">Generated records</th>
                                                            <th scope="col">Anomalies</th>
                                                            <th scope="col">Warnings</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var day in run.DayLogs)
                                                        {
                                                            <tr>
                                                                <td>@day.SimulatedDateUtc.ToString("yyyy-MM-dd")</td>
                                                                <td>@day.GeneratedRecordCount</td>
                                                                <td>@(day.InjectedAnomalies.Count == 0 ? "None" : string.Join(", ", day.InjectedAnomalies))</td>
                                                                <td>@(day.Warnings.Count == 0 ? "None" : string.Join(" | ", day.Warnings))</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </section>
        }
        @if (IsManualSeedConfirmationVisible)
        {
            <section class="wizard-card finance-state-card mb-4" role="alertdialog" aria-labelledby="finance-seed-confirm-title" aria-describedby="finance-seed-confirm-description">
                <div class="d-flex flex-column gap-3">
                    <div>
                        <div class="small text-uppercase text-danger fw-semibold">Confirmation required</div>
                        <h2 id="finance-seed-confirm-title" class="h5 mb-2">Replace existing finance data</h2>
                        <p id="finance-seed-confirm-description" class="text-body-secondary mb-0">
                            @ManualSeedConfirmationMessage
                        </p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <button id="finance-seed-confirm" class="btn btn-danger" type="button" @onclick="ConfirmManualSeedAsync" disabled="@IsSubmittingManualSeed">
                            Confirm replace
                        </button>
                        <button id="finance-seed-cancel" class="btn btn-outline-secondary" type="button" @onclick="CancelManualSeedConfirmation" disabled="@IsSubmittingManualSeed">
                            Cancel
                        </button>
                    </div>
                </div>
            </section>
        }
        <div class="template-grid">
            @foreach (var route in FinanceRoutes.SectionPages)
            {
                <NavLink class="@($"template-card text-decoration-none text-reset {(route.IsVisibleTo(AccessState.MembershipRole) ? string.Empty : "d-none")}")" href="@route.BuildPath(AccessState.CompanyId)" Match="NavLinkMatch.All">
                    <strong>@route.Title</strong>
                    <div class="text-body-secondary mt-2">@route.Description</div>
                </NavLink>
            }
        </div>
    }
</FinancePageLayout>
