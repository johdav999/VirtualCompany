@page "/finance"
@rendermode InteractiveServer
@inherits FinancePageBase

<PageTitle>Finance</PageTitle>

<FinancePageLayout
    IsLoading="@IsLoading"
    AccessState="@AccessState"
    ErrorMessage="@ErrorMessage"
    Title="Finance"
    Description="Review cash, receivables, payables, and the next finance actions for the active company."
    LoadingMessage="Loading finance overview..."
    ShowShellHeader="false"
    ShowShellNavigation="false">
    <FinanceDataState
        IsLoading="@IsOverviewLoading"
        IsEmpty="@IsOverviewEmpty"
        ErrorMessage="@OverviewErrorMessage"
        LoadingTitle="Loading finance overview"
        LoadingMessage="Reading cash, invoices, bills, payments, and exceptions."
        EmptyTitle="No finance activity yet"
        EmptyMessage="Connect finance data or import bills and invoices to start seeing the operating dashboard."
        ErrorTitle="Finance overview is unavailable"
        RetryText="Reload overview"
        OnRetry="@ReloadOverviewAsync">
        @if (Overview is not null)
        {
            <FinanceOverviewPage Overview="@Overview" CompanyId="@AccessState.CompanyId" />
        }
    </FinanceDataState>
</FinancePageLayout>
