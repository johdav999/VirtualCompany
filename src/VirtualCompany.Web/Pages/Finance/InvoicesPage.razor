@page "/finance/invoices"
@page "/finance/invoices/{InvoiceId:guid}"
@inherits FinancePageBase

<PageTitle>Invoices</PageTitle>

<FinancePageLayout
    IsLoading="@IsLoading"
    AccessState="@AccessState"
    ErrorMessage="@ErrorMessage"
    Title="Invoices"
    Description="Track invoices, approval status, and collection work for the active company."
    LoadingMessage="Loading invoices..."
    ShowShellHeader="false"
    ShowShellNavigation="false">
    <section class="invoices-dashboard" aria-labelledby="invoices-heading">
        <div class="finance-overview-header">
            <div>
                <span class="finance-overview-kicker">Finance module</span>
                <h1 id="invoices-heading" class="finance-overview-title">Invoices</h1>
                <p class="finance-overview-subtitle">Track invoices, approval status, and collection work for the active company.</p>
            </div>
            <div class="finance-overview-header__actions">
                <a class="btn finance-overview-button finance-overview-button--primary" href="@FinanceRoutes.WithCompanyContext(FinanceRoutes.Home, AccessState.CompanyId)">Finance overview</a>
                <a class="btn finance-overview-button finance-overview-button--secondary" href="@DashboardHref">Company dashboard</a>
            </div>
        </div>

        <FinanceSectionNav CompanyId="@AccessState.CompanyId!.Value" MembershipRole="@AccessState.MembershipRole" />

        <div class="invoices-layout">
            <article class="invoice-list-card">
                <div class="invoice-list-card__header">
                    <div>
                        <h2>Invoice list</h2>
                        <p>Review invoice status, customer, amount, and due date.</p>
                    </div>
                    <span>@Invoices.Count item@(Invoices.Count == 1 ? string.Empty : "s")</span>
                </div>

                <FinanceDataState
                    IsLoading="@IsListLoading"
                    IsEmpty="@IsListEmpty"
                    ErrorMessage="@ListErrorMessage"
                    LoadingTitle="Loading invoices"
                    LoadingMessage="Fetching invoices."
                    EmptyTitle="No invoices available"
                    EmptyMessage="This company does not have invoice records to review yet."
                    OnRetry="@ReloadAsync">
                    <div class="invoice-list">
                        @foreach (var invoice in InvoiceItems)
                        {
                            <a class="@($"invoice-list-item {(invoice.IsSelected ? "is-selected" : string.Empty)}")" href="@BuildInvoiceHref(invoice.Id)">
                                <span class="@($"invoice-list-item__icon invoice-tone--{invoice.IconTone}")" aria-hidden="true">inv</span>
                                <span class="invoice-list-item__main">
                                    <strong>@invoice.DisplayInvoiceNumber</strong>
                                    <span>@invoice.DisplayCustomerName</span>
                                    <small>@invoice.DateSummary</small>
                                </span>
                                <span class="invoice-list-item__meta">
                                    <strong>@invoice.DisplayAmount</strong>
                                    <span class="@($"invoice-status-badge invoice-status-badge--{invoice.StatusTone}")">@invoice.FriendlyStatusLabel</span>
                                </span>
                                <span class="invoice-list-item__chevron" aria-hidden="true">›</span>
                            </a>
                        }
                    </div>
                </FinanceDataState>
            </article>

            <aside class="invoice-detail-card">
                @if (IsDetailLoading)
                {
                    <FinanceLoadingState Title="Loading invoice detail" Message="Opening the selected invoice." />
                }
                else if (!string.IsNullOrWhiteSpace(DetailErrorMessage))
                {
                    <FinanceErrorState Title="Invoice detail unavailable" Message="@(DetailErrorMessage!)" RetryText="Retry" OnRetry="@ReloadAsync" />
                }
                else if (SelectedInvoice is null)
                {
                    <div class="invoice-detail-empty">
                        <div class="invoice-detail-empty__icon" aria-hidden="true">doc</div>
                        <h2>No invoice selected</h2>
                        <p>Select an invoice to open the detail panel.</p>
                    </div>
                }
                else if (SelectedInvoiceDisplay is { } detail)
                {
                    <div class="invoice-detail-panel">
                        <div class="invoice-detail-panel__header">
                            <div>
                                <h2>@detail.DisplayInvoiceNumber</h2>
                                <p>@detail.DisplayCustomerName</p>
                            </div>
                            <span class="@($"invoice-status-badge invoice-status-badge--{detail.StatusTone}")">@detail.FriendlyStatusLabel</span>
                        </div>

                        <div class="invoice-detail-panel__amount">@detail.DisplayAmount</div>

                        <dl class="invoice-detail-list">
                            <div><dt>Customer</dt><dd>@detail.DisplayCustomerName</dd></div>
                            <div><dt>Issued date</dt><dd>@detail.DisplayIssuedDate</dd></div>
                            <div><dt>Due date</dt><dd>@detail.DisplayDueDate</dd></div>
                            <div><dt>Payment status</dt><dd>@detail.FriendlyStatusLabel</dd></div>
                            <div><dt>Approval status</dt><dd>@detail.ApprovalStatus</dd></div>
                        </dl>

                        <form class="invoice-detail-form" @onsubmit="HandleStatusSaveAsync" @onsubmit:preventDefault="true">
                            <label class="form-label" for="invoice-status-input">Update status</label>
                            <select id="invoice-status-input" class="form-select" @bind="EditableStatus" disabled="@(!CanChangeInvoiceApprovalStatus || IsSavingStatus)">
                                @foreach (var option in EditableStatusOptions)
                                {
                                    <option value="@option">@FormatStatusLabel(option)</option>
                                }
                            </select>
                            @if (!string.IsNullOrWhiteSpace(StatusValidationMessage))
                            {
                                <div class="text-danger small mt-1">@StatusValidationMessage</div>
                            }
                            <div class="form-text">@(CanChangeInvoiceApprovalStatus ? "Save a new invoice status when the review is complete." : "Approval access is required to update invoice status.")</div>
                            <div class="invoice-detail-actions">
                                <button class="btn btn-primary" type="submit" disabled="@(!CanChangeInvoiceApprovalStatus || IsSavingStatus)">Save status</button>
                                @if (detail.CanOpenApproval && detail.ApprovalRequestId is Guid approvalRequestId)
                                {
                                    <a class="btn btn-outline-secondary" href="@BuildApprovalHref(approvalRequestId)">Open approval</a>
                                }
                                @if (detail.CanOpenReview && detail.WorkflowInstanceId is Guid workflowInstanceId)
                                {
                                    <a class="btn btn-outline-secondary" href="@BuildWorkflowHref(workflowInstanceId)">Review invoice</a>
                                }
                            </div>
                        </form>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(StatusSaveMessage))
                    {
                        <div class="alert alert-success" role="status">@StatusSaveMessage</div>
                    }

                    <section class="invoice-detail-section">
                        <h3>Review notes</h3>
                        <p>@detail.ReviewSummary</p>
                    </section>

                    <section class="invoice-detail-section">
                        <h3>Linked document</h3>
                    <FinanceLinkedResourceState
                        Availability="@SelectedInvoice.LinkedDocument.Availability"
                        Message="@SelectedInvoice.LinkedDocument.Message"
                        ResourceTitle="@SelectedInvoice.LinkedDocument.Document?.Title"
                        SecondaryText="@SelectedInvoice.LinkedDocument.Document?.OriginalFileName"
                        TypeText="@SelectedInvoice.LinkedDocument.Document?.ContentType"
                        CanNavigate="@SelectedInvoice.LinkedDocument.CanNavigate"
                        NavigateHref="@(SelectedInvoice.LinkedDocument.Document is null ? null : BuildDocumentHref(SelectedInvoice.LinkedDocument.Document.Id))"
                        ActionText="Open linked document" />
                    </section>

                    <AgentInsightsPanel
                        Title="Agent insights"
                        Subtitle="Finance notes linked to this invoice."
                        EmptyMessage="No agent insights are linked to this invoice."
                        TestId="invoice-agent-insights-panel"
                        Items="@SelectedInvoice.AgentInsights" />
                }
            </aside>
        </div>
    </section>
</FinancePageLayout>
