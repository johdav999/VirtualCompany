@page "/finance/balances"
@inherits FinanceSummaryPageBase<BalancesSummaryViewModel>

<PageTitle>Balances</PageTitle>

<FinancePageLayout
    IsLoading="@IsLoading"
    AccessState="@AccessState"
    ErrorMessage="@ErrorMessage"
    Title="Balances"
    Description="Browse account balances with explicit tenant-scoped routing and module-level navigation."
    LoadingMessage="Loading balances shell...">
    <FinanceDataState
        IsLoading="@IsSummaryLoading"
        IsEmpty="@IsSummaryEmpty"
        ErrorMessage="@SummaryErrorMessage"
        LoadingTitle="Loading balances"
        LoadingMessage="Fetching tenant-scoped balances from finance services."
        EmptyTitle="No balances yet"
        EmptyMessage="No account balances are available for the active tenant."
        RetryText="Reload balances"
        OnRetry="@RetryAsync">
        @if (ViewModel is not null)
        {
            <section class="finance-summary-stack" aria-labelledby="balances-heading">
                <div class="finance-summary-grid">
                    <article class="wizard-card finance-metric-card finance-metric-card--hero">
                        <span class="dashboard-kicker">Total balance</span>
                        <h2 id="balances-heading" class="finance-metric-card__value">@ViewModel.TotalBalance</h2>
                        <p class="text-body-secondary mb-0">As of @ViewModel.AsOf</p>
                    </article>
                    <article class="wizard-card finance-metric-card">
                        <span class="dashboard-kicker">Tracked accounts</span>
                        <div class="finance-metric-card__value finance-metric-card__value--compact">@ViewModel.Accounts.Count</div>
                        <p class="text-body-secondary mb-0">All values are scoped to the active tenant.</p>
                    </article>
                </div>
                <article class="wizard-card">
                    <h2 class="h5">Account balances</h2>
                    <div class="table-responsive">
                        <table class="table finance-table mb-0">
                            <thead>
                                <tr>
                                    <th scope="col">Code</th>
                                    <th scope="col">Account</th>
                                    <th scope="col">Type</th>
                                    <th scope="col">As of</th>
                                    <th scope="col" class="finance-table__number">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var account in ViewModel.Accounts)
                                {
                                    <tr>
                                        <td>@account.AccountCode</td>
                                        <td>@account.AccountName</td>
                                        <td>@account.AccountType</td>
                                        <td>@account.AsOf</td>
                                        <td class="finance-table__number">@account.Amount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </article>
            </section>
        }
    </FinanceDataState>
</FinancePageLayout>
