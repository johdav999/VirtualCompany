@page "/finance/cash-position"
@inherits FinanceSummaryPageBase<CashPositionSummaryViewModel>

<PageTitle>Cash position</PageTitle>

<FinancePageLayout
    IsLoading="@IsLoading"
    AccessState="@AccessState"
    ErrorMessage="@ErrorMessage"
    Title="Cash position"
    Description="See how much cash you have and how long it will last."
    LoadingMessage="Loading cash position..."
    ShowShellHeader="false"
    ShowShellNavigation="false">
    <FinanceDataState
        IsLoading="@IsSummaryLoading"
        IsEmpty="@IsSummaryEmpty"
        ErrorMessage="@SummaryErrorMessage"
        LoadingTitle="Loading cash position"
        LoadingMessage="Getting your latest cash details."
        EmptyTitle="No cash position yet"
        EmptyMessage="No cash position summary is available yet."
        RetryText="Reload cash position"
        OnRetry="@RetryAsync">
        @if (ViewModel is not null)
        {
            <section class="cash-position-dashboard" aria-labelledby="cash-position-heading">
                <div class="finance-overview-header">
                    <div>
                        <span class="finance-overview-kicker">Finance module</span>
                        <h1 id="cash-position-heading" class="finance-overview-title">Cash position</h1>
                        <p class="finance-overview-subtitle">See how much cash you have and how long it will last.</p>
                    </div>
                    <div class="finance-overview-header__actions">
                        <a class="btn finance-overview-button finance-overview-button--primary" href="@FinanceRoutes.WithCompanyContext(FinanceRoutes.Home, AccessState.CompanyId)">Finance overview</a>
                        <a class="btn finance-overview-button finance-overview-button--secondary" href="@DashboardHref">Company dashboard</a>
                    </div>
                </div>

                <FinanceSectionNav CompanyId="@AccessState.CompanyId!.Value" MembershipRole="@AccessState.MembershipRole" />

                <div class="cash-position-grid">
                    <article class="cash-position-card cash-position-card--wide">
                        <div class="cash-position-card__icon cash-position-card__icon--positive" aria-hidden="true">$</div>
                        <div class="cash-position-card__body">
                            <p class="cash-position-card__label">Available cash</p>
                            <div class="cash-position-card__value">@ViewModel.AvailableBalance</div>
                            <p class="cash-position-card__muted">As of @FormattedAsOf</p>
                        </div>
                        <div class="cash-position-card__icon cash-position-card__icon--positive cash-position-card__icon--end" aria-hidden="true">$</div>
                    </article>

                    <article class="cash-position-card">
                        <div class="cash-position-card__icon cash-position-card__icon--neutral" aria-hidden="true">avg</div>
                        <div class="cash-position-card__body">
                            <h2 class="cash-position-card__title">@ViewModel.MonthlySpendingTitle</h2>
                            <div class="cash-position-card__value cash-position-card__value--medium">@ViewModel.AverageMonthlyBurn</div>
                            <p class="cash-position-card__muted">@ViewModel.MonthlySpendingDescription</p>
                            <p class="cash-position-card__strong">@ViewModel.RunwayDescription</p>
                        </div>
                    </article>

                    <article class="cash-position-card">
                        <div class="cash-position-card__icon cash-position-card__icon--@ViewModel.FriendlyHealthTone" aria-hidden="true">ok</div>
                        <div class="cash-position-card__body">
                            <h2 class="cash-position-card__title">@ViewModel.CashHealthTitle</h2>
                            <span class="cash-position-status cash-position-status--@ViewModel.FriendlyHealthTone">@ViewModel.FriendlyHealthLabel</span>
                            <p class="cash-position-card__muted mt-2">@ViewModel.CashHealthMessage</p>
                            @if (!string.IsNullOrWhiteSpace(ViewModel.ConfidenceText))
                            {
                                <p class="cash-position-card__muted mb-0">@ViewModel.ConfidenceText</p>
                            }
                        </div>
                    </article>

                    <article class="cash-position-card cash-position-card--stacked">
                        <div class="cash-position-card__header">
                            <h2 class="cash-position-card__title">@ViewModel.CashGuideTitle</h2>
                            <div class="cash-position-card__icon cash-position-card__icon--warning cash-position-card__icon--small" aria-hidden="true">!</div>
                        </div>
                        <dl class="cash-position-guide-list">
                            <div><dt>@ViewModel.WarningCashLabel</dt><dd>@ViewModel.WarningThreshold</dd></div>
                            <div><dt>@ViewModel.CriticalCashLabel</dt><dd>@ViewModel.CriticalThreshold</dd></div>
                            <div><dt>@ViewModel.WarningRunwayLabel</dt><dd>@ViewModel.WarningRunway</dd></div>
                            <div><dt>@ViewModel.CriticalRunwayLabel</dt><dd>@ViewModel.CriticalRunway</dd></div>
                        </dl>
                        <p class="cash-position-card__muted mb-0">@ViewModel.CashGuideHelperText</p>
                    </article>

                    <article class="cash-position-card cash-position-card--stacked">
                        <div class="cash-position-card__header">
                            <h2 class="cash-position-card__title">@ViewModel.MeaningCardTitle</h2>
                            <div class="cash-position-card__icon cash-position-card__icon--@ViewModel.FriendlyHealthTone cash-position-card__icon--small" aria-hidden="true">!</div>
                        </div>
                        <div class="cash-position-meaning">
                            <div class="cash-position-meaning__headline">
                                <span class="cash-position-card__icon cash-position-card__icon--@ViewModel.FriendlyHealthTone cash-position-card__icon--tiny" aria-hidden="true">ok</span>
                                <strong>@ViewModel.MeaningTitle</strong>
                            </div>
                            @foreach (var paragraph in ViewModel.MeaningParagraphs)
                            {
                                <p>@paragraph</p>
                            }
                            <p class="cash-position-card__muted mb-0">Status: @ViewModel.MeaningStatus</p>
                        </div>
                    </article>
                </div>
            </section>
        }
    </FinanceDataState>
</FinancePageLayout>
