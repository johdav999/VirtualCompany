@page "/finance/admin/counterparties"
@inherits FinancePageBase

<PageTitle>Finance Counterparties</PageTitle>

<FinancePageLayout
    IsLoading="@IsLoading"
    AccessState="@AccessState"
    ErrorMessage="@ErrorMessage"
    Title="Finance counterparties"
    Description="Manage customer and supplier master data used by invoices, bills, and finance transactions."
    LoadingMessage="Loading finance counterparties...">
    <div class="row g-4 align-items-start">
        <div class="col-lg-5">
            <div class="wizard-card wizard-card--compact">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="btn-group" role="group" aria-label="Counterparty type">
                        <button type="button" class="btn @(SelectedType == "customer" ? "btn-primary" : "btn-outline-primary")" @onclick='() => HandleTypeChangedAsync("customer")'>Customers</button>
                        <button type="button" class="btn @(SelectedType == "supplier" ? "btn-primary" : "btn-outline-primary")" @onclick='() => HandleTypeChangedAsync("supplier")'>Suppliers</button>
                    </div>
                    <button type="button" class="btn btn-outline-secondary" @onclick="HandleNewAsync" disabled="@(!CanEdit)">New</button>
                </div>

                <FinanceDataState
                    IsLoading="@IsListLoading"
                    IsEmpty="@(!IsListLoading && string.IsNullOrWhiteSpace(ListErrorMessage) && Items.Count == 0)"
                    ErrorMessage="@ListErrorMessage"
                    LoadingTitle="Loading counterparties"
                    LoadingMessage="Fetching finance counterparties for the selected company."
                    EmptyTitle="No counterparties available"
                    EmptyMessage="Create a finance counterparty to start populating customer and supplier master data."
                    OnRetry="@ReloadAsync">
                    <div class="list-group">
                        @foreach (var item in Items)
                        {
                            <button type="button" class="@(SelectedId == item.Id ? "list-group-item list-group-item-action active" : "list-group-item list-group-item-action")" @onclick="() => HandleSelectAsync(item.Id)">
                                <div class="d-flex justify-content-between gap-3">
                                    <div>
                                        <div class="fw-semibold">@item.Name</div>
                                        <div class="small text-body-secondary">@FormatOptionalValue(item.Email)</div>
                                        <div class="small text-body-secondary">@BuildListMetadata(item)</div>
                                    </div>
                                    <div class="text-end small">
                                        <div>@FormatOptionalValue(item.PaymentTerms)</div>
                                        <div>@FormatOptionalValue(item.PreferredPaymentMethod)</div>
                                        <div>@FormatOptionalValue(item.DefaultAccountMapping)</div>
                                    </div>
                                </div>
                            </button>
                        }
                    </div>
                </FinanceDataState>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="wizard-card wizard-card--compact">
                <h2 class="h5 mb-3">@((IsCreatingNew ? "Create" : "Edit")) @TitleCase(SelectedType)</h2>

                @if (!string.IsNullOrWhiteSpace(SaveMessage))
                {
                    <div class="alert alert-success" role="status">@SaveMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(ValidationMessage))
                {
                    <div class="alert alert-danger" role="alert">@ValidationMessage</div>
                }

                <EditForm Model="@Editor" OnValidSubmit="@HandleSaveAsync">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="counterparty-name">Name</label>
                            <InputText id="counterparty-name" class="form-control" @bind-Value="Editor.Name" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="counterparty-email">Email</label>
                            <InputText id="counterparty-email" class="form-control" @bind-Value="Editor.Email" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="counterparty-payment-terms">Payment terms</label>
                            <InputText id="counterparty-payment-terms" class="form-control" @bind-Value="Editor.PaymentTerms" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="counterparty-tax-id">Tax ID</label>
                            <InputText id="counterparty-tax-id" class="form-control" @bind-Value="Editor.TaxId" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="counterparty-credit-limit">Credit limit</label>
                            <InputNumber id="counterparty-credit-limit" class="form-control" @bind-Value="Editor.CreditLimit" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="counterparty-payment-method">Preferred payment method</label>
                            <InputText id="counterparty-payment-method" class="form-control" @bind-Value="Editor.PreferredPaymentMethod" />
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="counterparty-account-mapping">Default account mapping</label>
                            <InputText id="counterparty-account-mapping" class="form-control" @bind-Value="Editor.DefaultAccountMapping" />
                            <div class="form-text">Use the existing account code format already used by finance mappings.</div>
                        </div>
                        @if (!IsCreatingNew && Selected is not null)
                        {
                            <div class="col-12">
                                <dl class="row mb-0">
                                    <dt class="col-sm-3">Email</dt>
                                    <dd class="col-sm-9">@FormatOptionalValue(Selected.Email)</dd>
                                    <dt class="col-sm-3">Payment terms</dt>
                                    <dd class="col-sm-9">@FormatOptionalValue(Selected.PaymentTerms)</dd>
                                    <dt class="col-sm-3">Tax ID</dt>
                                    <dd class="col-sm-9">@FormatOptionalValue(Selected.TaxId)</dd>
                                    <dt class="col-sm-3">Credit limit</dt>
                                    <dd class="col-sm-9">@FormatCreditLimit(Selected.CreditLimit)</dd>
                                    <dt class="col-sm-3">Payment method</dt>
                                    <dd class="col-sm-9">@FormatOptionalValue(Selected.PreferredPaymentMethod)</dd>
                                    <dt class="col-sm-3">Account mapping</dt>
                                    <dd class="col-sm-9">@FormatOptionalValue(Selected.DefaultAccountMapping)</dd>
                                    <dt class="col-sm-3">Type</dt>
                                    <dd class="col-sm-9">@TitleCase(Selected.CounterpartyType)</dd>
                                    <dt class="col-sm-3">Created</dt>
                                    <dd class="col-sm-9">@Selected.CreatedUtc.ToString("u")</dd>
                                    <dt class="col-sm-3">Updated</dt>
                                    <dd class="col-sm-9">@Selected.UpdatedUtc.ToString("u")</dd>
                                </dl>
                            </div>
                        }
                        <div class="col-12 d-flex gap-2">
                            <button type="submit" class="btn btn-primary" disabled="@(!CanEdit || IsSaving)">@(IsSaving ? "Saving..." : "Save")</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="HandleNewAsync">Reset</button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</FinancePageLayout>
