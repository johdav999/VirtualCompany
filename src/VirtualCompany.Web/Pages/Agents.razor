@page "/agents"
@using System.ComponentModel.DataAnnotations
@using System.Text.Json
@using System.Text.Json.Nodes
@using Microsoft.AspNetCore.Components
@inject OnboardingApiClient OnboardingApiClient
@inject AgentApiClient AgentApiClient
@inject NavigationManager Navigation

<PageTitle>Agents</PageTitle>

@if (isLoading)
{
    <section class="py-4">
        <h1>Agent management</h1>
        <p class="text-body-secondary mb-0">Loading template catalog and company roster...</p>
    </section>
}
else if (CompanyId is null)
{
    <section class="py-4 dashboard-hero">
        <div class="wizard-card">
            <h1>Select a company</h1>
            <p class="text-body-secondary">Choose the company where you want to browse templates and hire agents.</p>

            @if (activeMemberships.Count == 0)
            {
                <p class="mb-0">No active company memberships are available yet.</p>
            }
            else
            {
                <div class="template-grid">
                    @foreach (var membership in activeMemberships)
                    {
                        <a class="template-card text-decoration-none text-reset" href="@($"/agents?companyId={membership.CompanyId}")">
                            <strong>@membership.CompanyName</strong>
                            <div class="text-body-secondary mt-2">Role: @membership.MembershipRole</div>
                        </a>
                    }
                </div>
            }
        </div>
    </section>
}
else
{
    <section class="py-4 dashboard-hero">
        <div class="agent-layout">
            <div class="wizard-card">
                <span class="dashboard-kicker">Template catalog</span>
                <h1>Hire agents for @(companyAccess?.CompanyName ?? "your company")</h1>
                <p class="text-body-secondary">Start from seeded templates, customize identity fields and avatar references, and create an active company-owned roster entry.</p>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(successMessage))
                {
                    <div class="alert alert-success">@successMessage</div>
                }

                <div class="agent-template-grid mt-4">
                    @foreach (var template in templates)
                    {
                        var isSelected = string.Equals(selectedTemplateId, template.TemplateId, StringComparison.OrdinalIgnoreCase);
                        <button class="template-card agent-template-card @(isSelected ? "is-selected" : null)"
                                type="button"
                                @onclick="@(() => SelectTemplate(template.TemplateId))">
                            <div class="agent-template-header">
                                <strong>@template.RoleName</strong>
                                <span class="badge text-bg-light">@template.DefaultSeniority</span>
                            </div>
                            <div class="text-body-secondary">@template.Department</div>
                            <p class="mb-0 mt-3">@template.PersonaSummary</p>
                        </button>
                    }
                </div>
            </div>

            <div class="wizard-card">
                <h2 class="h4 mb-3">Customize and hire</h2>

                @if (selectedTemplate is null)
                {
                    <p class="text-body-secondary mb-0">Select a template to prepare the hire form.</p>
                }
                else
                {
                    <EditForm Model="@hireModel" OnValidSubmit="@HandleHireAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label" for="display-name">Name</label>
                            <InputText id="display-name" class="form-control" @bind-Value="hireModel.DisplayName" />
                            <ValidationMessage For="@(() => hireModel.DisplayName)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="avatar-url">Avatar URL or file reference</label>
                            <InputText id="avatar-url" class="form-control" @bind-Value="hireModel.AvatarUrl" />
                            <div class="form-text">Use an external <code>https://</code> URL or a file/object-storage reference. Uploads and inline image data are not supported.</div>
                            <ValidationMessage For="@(() => hireModel.AvatarUrl)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="department">Department</label>
                            <InputText id="department" class="form-control" @bind-Value="hireModel.Department" />
                            <ValidationMessage For="@(() => hireModel.Department)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="role-name">Role</label>
                            <InputText id="role-name" class="form-control" @bind-Value="hireModel.RoleName" />
                            <ValidationMessage For="@(() => hireModel.RoleName)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="seniority">Seniority</label>
                            <InputSelect id="seniority" class="form-select" @bind-Value="hireModel.Seniority">
                                @foreach (var option in seniorityOptions)
                                {
                                    <option value="@option">@option</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => hireModel.Seniority)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="personality">Personality</label>
                            <InputTextArea id="personality" class="form-control" rows="4" @bind-Value="hireModel.Personality" />
                            <ValidationMessage For="@(() => hireModel.Personality)" />
                        </div>

                        <div class="dashboard-actions">
                            <button class="btn btn-primary" type="submit" disabled="@isSubmitting">Hire agent</button>
                            <button class="btn btn-outline-secondary" type="button" @onclick="@ResetSelectedTemplate">Reset defaults</button>
                        </div>
                    </EditForm>
                }
            </div>
        </div>

        <div class="wizard-card mt-4">
            <div class="agent-roster-header">
                <div>
                    <span class="dashboard-kicker">Operating profile</span>
                    <h2 class="h4 mb-0 mt-2">Agent configuration</h2>
                </div>
            </div>

            @if (!CanManageProfiles)
            {
                <p class="text-body-secondary mb-0 mt-3">Owner or admin membership is required to manage operating profiles.</p>
            }
            else if (selectedAgentProfile is null)
            {
                <p class="text-body-secondary mb-0 mt-3">Select an agent from the roster to load the operating profile editor.</p>
            }
            else
            {
                @if (!string.IsNullOrWhiteSpace(profileErrorMessage))
                {
                    <div class="alert alert-danger mt-3">@profileErrorMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(profileSuccessMessage))
                {
                    <div class="alert alert-success mt-3">@profileSuccessMessage</div>
                }

                <EditForm Model="@profileModel" OnValidSubmit="@HandleProfileSaveAsync" class="mt-4">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="profile-status">Status</label>
                            <InputSelect id="profile-status" class="form-select" @bind-Value="profileModel.Status">
                                @foreach (var status in statusOptions)
                                {
                                    <option value="@status">@status</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => profileModel.Status)" />
                            <div class="form-text">Archived agents are excluded from new task assignment. Other statuses remain editable for downstream orchestration.</div>
                            @foreach (var error in GetProfileErrors(nameof(AgentOperatingProfileFormModel.Status)))
                            {
                                <div class="text-danger small mt-1">@error</div>
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="profile-updated">Last updated</label>
                            <input id="profile-updated" class="form-control" value="@selectedAgentProfile.UpdatedUtc.ToLocalTime().ToString("g")" disabled />
                        </div>
                    </div>

                    <div class="mt-3">
                        <label class="form-label" for="role-brief">Role brief</label>
                        <InputTextArea id="role-brief" class="form-control" rows="3" @bind-Value="profileModel.RoleBrief" />
                        <ValidationMessage For="@(() => profileModel.RoleBrief)" />
                        @foreach (var error in GetProfileErrors(nameof(AgentOperatingProfileFormModel.RoleBrief)))
                        {
                            <div class="text-danger small mt-1">@error</div>
                        }
                    </div>

                    @RenderJsonEditor("Objectives", "Objectives", () => profileModel.ObjectivesJson)
                    @RenderJsonEditor("KPIs", "Kpis", () => profileModel.KpisJson)
                    @RenderJsonEditor("Tool permissions", "ToolPermissions", () => profileModel.ToolPermissionsJson)
                    @RenderJsonEditor("Data scopes", "DataScopes", () => profileModel.DataScopesJson)
                    @RenderJsonEditor("Approval thresholds", "ApprovalThresholds", () => profileModel.ApprovalThresholdsJson)
                    @RenderJsonEditor("Escalation rules", "EscalationRules", () => profileModel.EscalationRulesJson)
                    @RenderJsonEditor("Trigger logic", "TriggerLogic", () => profileModel.TriggerLogicJson)
                    @RenderJsonEditor("Working hours", "WorkingHours", () => profileModel.WorkingHoursJson)

                    <div class="dashboard-actions mt-3">
                        <button class="btn btn-primary" type="submit" disabled="@isSavingProfile">Save operating profile</button>
                    </div>
                </EditForm>
            }
        </div>

        <div class="wizard-card mt-4">
            <div class="agent-roster-header">
                <div>
                    <span class="dashboard-kicker">Company roster</span>
                    <h2 class="h4 mb-0 mt-2">Active agents</h2>
                </div>
                <span class="badge text-bg-light">@roster.Count total</span>
            </div>

            @if (roster.Count == 0)
            {
                <p class="text-body-secondary mb-0 mt-3">No agents have been hired for this company yet.</p>
            }
            else
            {
                <div class="agent-roster-grid mt-4">
                    @foreach (var agent in roster)
                    {
                        <button type="button"
                                class="template-card text-start @(selectedAgentId == agent.Id ? "is-selected" : null)"
                                disabled="@(!CanManageProfiles && selectedAgentId != agent.Id)"
                                @onclick="@(() => SelectAgentAsync(agent.Id))">
                            <div class="agent-template-header">
                                <strong>@agent.DisplayName</strong>
                                <span class="badge text-bg-success">@agent.Status</span>
                            </div>
                            <div class="text-body-secondary mt-2">@agent.RoleName | @agent.Department</div>
                            <div class="text-body-secondary">@agent.Seniority</div>
                            @if (!string.IsNullOrWhiteSpace(agent.AvatarUrl))
                            {
                                <div class="text-body-secondary small mt-2">Avatar reference: @agent.AvatarUrl</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(agent.Personality))
                            {
                                <p class="mb-0 mt-3">@agent.Personality</p>
                            }
                        </button>
                    }
                </div>
            }
        </div>        
    </section>
}

@code {
    [SupplyParameterFromQuery(Name = "companyId")]
    public Guid? CompanyId { get; set; }

    private static readonly JsonSerializerOptions JsonEditorOptions = new(JsonSerializerDefaults.Web) { WriteIndented = true };
    private readonly string[] seniorityOptions = [ "junior", "mid", "senior", "lead", "executive" ];
    private readonly string[] statusOptions = [ "active", "paused", "restricted", "archived" ];
    private bool isLoading = true;
    private bool isSubmitting;
    private bool isSavingProfile;
    private string? errorMessage;
    private string? successMessage;
    private string? profileErrorMessage;
    private string? profileSuccessMessage;
    private CurrentUserContextViewModel? currentUser;
    private CompanyAccessViewModel? companyAccess;
    private List<AgentTemplateCatalogItemViewModel> templates = [];
    private List<CompanyAgentSummaryViewModel> roster = [];
    private HireAgentFormModel hireModel = new();
    private AgentOperatingProfileViewModel? selectedAgentProfile;
    private AgentOperatingProfileFormModel profileModel = new();
    private Dictionary<string, string[]> profileErrors = new(StringComparer.OrdinalIgnoreCase);
    private Guid? selectedAgentId;
    private string? selectedTemplateId;

    private IReadOnlyList<CompanyMembershipViewModel> activeMemberships =>
        currentUser?.Memberships.Where(x => string.Equals(x.Status, "active", StringComparison.OrdinalIgnoreCase)).ToList()
        ?? [];

    private AgentTemplateCatalogItemViewModel? selectedTemplate =>
        templates.FirstOrDefault(x => string.Equals(x.TemplateId, selectedTemplateId, StringComparison.OrdinalIgnoreCase));

    private bool CanManageProfiles =>
        string.Equals(companyAccess?.MembershipRole, "owner", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(companyAccess?.MembershipRole, "admin", StringComparison.OrdinalIgnoreCase);


    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            currentUser = await OnboardingApiClient.GetCurrentUserContextAsync();

            if (CompanyId is null && currentUser?.ActiveCompany is not null)
            {
                Navigation.NavigateTo($"/agents?companyId={currentUser.ActiveCompany.CompanyId}", replace: true);
                return;
            }

            if (CompanyId is Guid companyId)
            {
                companyAccess = await OnboardingApiClient.GetCompanyAccessAsync(companyId);
                if (companyAccess is null)
                {
                    errorMessage = "The selected company could not be loaded.";
                    templates = [];
                    roster = [];
                }
                else
                {
                    templates = (await AgentApiClient.GetTemplatesAsync(companyId)).ToList();
                    roster = (await AgentApiClient.GetRosterAsync(companyId)).ToList();

                    if (selectedTemplateId is null || templates.All(x => !string.Equals(x.TemplateId, selectedTemplateId, StringComparison.OrdinalIgnoreCase)))
                    {
                        selectedTemplateId = templates.FirstOrDefault()?.TemplateId;
                        ResetSelectedTemplate();
                    }

                    if (CanManageProfiles && roster.Count > 0)
                    {
                        var nextSelectedAgent = selectedAgentId.HasValue
                            ? roster.FirstOrDefault(x => x.Id == selectedAgentId.Value) ?? roster[0]
                            : roster[0];

                        await SelectAgentAsync(nextSelectedAgent.Id);
                    }
                    else
                    {
                        selectedAgentId = null;
                        selectedAgentProfile = null;
                        profileModel = new AgentOperatingProfileFormModel();
                    }
                }
            }
        }
        catch (OnboardingApiException ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SelectTemplate(string templateId)
    {
        selectedTemplateId = templateId;
        ResetSelectedTemplate();
    }

    private void ResetSelectedTemplate()
    {
        if (selectedTemplate is null)
        {
            hireModel = new HireAgentFormModel();
            return;
        }

        hireModel = new HireAgentFormModel
        {
            TemplateId = selectedTemplate.TemplateId,
            DisplayName = selectedTemplate.RoleName,
            AvatarUrl = selectedTemplate.AvatarUrl,
            Department = selectedTemplate.Department,
            RoleName = selectedTemplate.RoleName,
            Personality = selectedTemplate.PersonaSummary,
            Seniority = selectedTemplate.DefaultSeniority
        };
    }

    private async Task SelectAgentAsync(Guid agentId)
    {
        if (CompanyId is not Guid companyId)
        {
            return;
        }

        selectedAgentId = agentId;
        profileErrorMessage = null;
        profileSuccessMessage = null;
        profileErrors.Clear();

        if (!CanManageProfiles)
        {
            return;
        }

        try
        {
            selectedAgentProfile = await AgentApiClient.GetOperatingProfileAsync(companyId, agentId);
            profileModel = AgentOperatingProfileFormModel.FromViewModel(selectedAgentProfile);
        }
        catch (OnboardingApiException ex)
        {
            selectedAgentProfile = null;
            profileModel = new AgentOperatingProfileFormModel();
            profileErrorMessage = ex.Message;
        }
    }

    private async Task HandleProfileSaveAsync()
    {
        if (CompanyId is not Guid companyId || selectedAgentId is not Guid agentId)
        {
            return;
        }

        if (!profileModel.TryCreateRequest(out var request, out var localErrors))
        {
            profileErrors = localErrors;
            profileErrorMessage = "Fix the highlighted operating profile fields and try again.";
            profileSuccessMessage = null;
            return;
        }

        isSavingProfile = true;
        profileErrorMessage = null;
        profileSuccessMessage = null;
        profileErrors.Clear();

        try
        {
            selectedAgentProfile = await AgentApiClient.UpdateOperatingProfileAsync(companyId, agentId, request);
            profileModel = AgentOperatingProfileFormModel.FromViewModel(selectedAgentProfile);
            roster = (await AgentApiClient.GetRosterAsync(companyId)).ToList();
            profileSuccessMessage = $"{selectedAgentProfile.DisplayName} operating profile was saved.";
        }
        catch (OnboardingApiException ex)
        {
            profileErrorMessage = ex.Message;
            profileErrors = ex.Errors.ToDictionary(x => x.Key, x => x.Value, StringComparer.OrdinalIgnoreCase);
        }
        finally
        {
            isSavingProfile = false;
        }
    }

    private IReadOnlyList<string> GetProfileErrors(string key)
    {
        var matched = profileErrors
            .Where(entry =>
                string.Equals(entry.Key, key, StringComparison.OrdinalIgnoreCase) ||
                entry.Key.StartsWith($"{key}.", StringComparison.OrdinalIgnoreCase) ||
                entry.Key.StartsWith($"{key}[", StringComparison.OrdinalIgnoreCase))
            .SelectMany(entry => entry.Value)
            .Distinct(StringComparer.Ordinal)
            .ToArray();

        return matched.Length == 0
            ? []
            : matched;
    }

    private RenderFragment RenderJsonEditor(string label, string fieldName, Func<string> valueAccessor) => builder =>
    {
        var sequence = 0;

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "mt-3");

        builder.OpenElement(sequence++, "label");
        builder.AddAttribute(sequence++, "class", "form-label");
        builder.AddAttribute(sequence++, "for", fieldName);
        builder.AddContent(sequence++, label);
        builder.CloseElement();

        builder.OpenElement(sequence++, "textarea");
        builder.AddAttribute(sequence++, "id", fieldName);
        builder.AddAttribute(sequence++, "class", "form-control");
        builder.AddAttribute(sequence++, "rows", "8");
        builder.AddAttribute(sequence++, "value", valueAccessor());
        builder.AddAttribute(sequence++, "onchange", EventCallback.Factory.CreateBinder<string>(this, value =>
        {
            switch (fieldName)
            {
                case "Objectives": profileModel.ObjectivesJson = value; break;
                case "Kpis": profileModel.KpisJson = value; break;
                case "ToolPermissions": profileModel.ToolPermissionsJson = value; break;
                case "DataScopes": profileModel.DataScopesJson = value; break;
                case "ApprovalThresholds": profileModel.ApprovalThresholdsJson = value; break;
                case "EscalationRules": profileModel.EscalationRulesJson = value; break;
                case "TriggerLogic": profileModel.TriggerLogicJson = value; break;
                case "WorkingHours": profileModel.WorkingHoursJson = value; break;
            }
        }, valueAccessor()));
        builder.CloseElement();

        foreach (var error in GetProfileErrors(fieldName))
        {
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "text-danger small mt-1");
            builder.AddContent(sequence++, error);
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private async Task HandleHireAsync()
    {
        if (CompanyId is not Guid companyId)
        {
            return;
        }

        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var result = await AgentApiClient.CreateAgentFromTemplateAsync(companyId, hireModel.ToRequest());
            roster = (await AgentApiClient.GetRosterAsync(companyId)).ToList();
            successMessage = $"{result.Agent.DisplayName} was hired and added to the company roster.";

            if (CanManageProfiles)
            {
                await SelectAgentAsync(result.Agent.Id);
            }
            else
            {
                selectedAgentId = result.Agent.Id;
            }

            ResetSelectedTemplate();
        }
        catch (OnboardingApiException ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class HireAgentFormModel : IValidatableObject
    {
        [Required, StringLength(100)]
        public string TemplateId { get; set; } = string.Empty;

        [Required, StringLength(200)]
        public string DisplayName { get; set; } = string.Empty;

        [StringLength(2048)]
        public string? AvatarUrl { get; set; }

        [StringLength(100)]
        public string? Department { get; set; }

        [StringLength(100)]
        public string? RoleName { get; set; }

        [StringLength(1000)]
        public string? Personality { get; set; }

        [StringLength(32)]
        public string? Seniority { get; set; }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (string.IsNullOrWhiteSpace(AvatarUrl))
            {
                yield break;
            }

            var trimmed = AvatarUrl.Trim();
            if (trimmed.StartsWith("data:", StringComparison.OrdinalIgnoreCase) ||
                trimmed.StartsWith("blob:", StringComparison.OrdinalIgnoreCase) ||
                (trimmed.Length >= 256 &&
                 !trimmed.Contains("/", StringComparison.Ordinal) &&
                 !trimmed.Contains("\\", StringComparison.Ordinal) &&
                 !trimmed.Contains(".", StringComparison.Ordinal) &&
                 (trimmed.StartsWith("iVBORw0KGgo", StringComparison.Ordinal) ||
                  trimmed.StartsWith("/9j/", StringComparison.Ordinal) ||
                  trimmed.StartsWith("R0lGOD", StringComparison.Ordinal) ||
                  trimmed.StartsWith("PHN2Zy", StringComparison.Ordinal))))
            {
                yield return new ValidationResult("AvatarUrl must be an external http/https URL or a file/storage reference, not inline image data.", [nameof(AvatarUrl)]);
                yield break;
            }

            if ((trimmed.Contains("://", StringComparison.Ordinal) || trimmed.StartsWith("http:", StringComparison.OrdinalIgnoreCase) || trimmed.StartsWith("https:", StringComparison.OrdinalIgnoreCase)) &&
                (!Uri.TryCreate(trimmed, UriKind.Absolute, out var uri) || (uri.Scheme != Uri.UriSchemeHttp && uri.Scheme != Uri.UriSchemeHttps)))
            {
                yield return new ValidationResult("AvatarUrl must be a valid absolute http/https URL or a file/storage reference.", [nameof(AvatarUrl)]);
            }
        }

        public CreateAgentFromTemplateRequest ToRequest() =>
            new()
            {
                TemplateId = TemplateId,
                DisplayName = DisplayName,
                AvatarUrl = AvatarUrl,
                Department = Department,
                RoleName = RoleName,
                Personality = Personality,
                Seniority = Seniority
            };
    }

    private sealed class AgentOperatingProfileFormModel
    {
        [Required, StringLength(32)]
        public string Status { get; set; } = "active";

        [StringLength(4000)]
        public string? RoleBrief { get; set; }

        public string ObjectivesJson { get; set; } = "{}";
        public string KpisJson { get; set; } = "{}";
        public string ToolPermissionsJson { get; set; } = "{}";
        public string DataScopesJson { get; set; } = "{}";
        public string ApprovalThresholdsJson { get; set; } = "{}";
        public string EscalationRulesJson { get; set; } = "{}";
        public string TriggerLogicJson { get; set; } = "{}";
        public string WorkingHoursJson { get; set; } = "{}";

        public static AgentOperatingProfileFormModel FromViewModel(AgentOperatingProfileViewModel model) =>
            new()
            {
                Status = model.Status,
                RoleBrief = model.RoleBrief,
                ObjectivesJson = Serialize(model.Objectives),
                KpisJson = Serialize(model.Kpis),
                ToolPermissionsJson = Serialize(model.ToolPermissions),
                DataScopesJson = Serialize(model.DataScopes),
                ApprovalThresholdsJson = Serialize(model.ApprovalThresholds),
                EscalationRulesJson = Serialize(model.EscalationRules),
                TriggerLogicJson = Serialize(model.TriggerLogic),
                WorkingHoursJson = Serialize(model.WorkingHours)
            };

        public bool TryCreateRequest(out UpdateAgentOperatingProfileRequest request, out Dictionary<string, string[]> errors)
        {
            var collectedErrors = new Dictionary<string, List<string>>(StringComparer.OrdinalIgnoreCase);

            var objectives = ParseJson("Objectives", ObjectivesJson, collectedErrors);
            var kpis = ParseJson("Kpis", KpisJson, collectedErrors);
            var toolPermissions = ParseJson("ToolPermissions", ToolPermissionsJson, collectedErrors);
            var dataScopes = ParseJson("DataScopes", DataScopesJson, collectedErrors);
            var approvalThresholds = ParseJson("ApprovalThresholds", ApprovalThresholdsJson, collectedErrors);
            var escalationRules = ParseJson("EscalationRules", EscalationRulesJson, collectedErrors);
            var triggerLogic = ParseJson("TriggerLogic", TriggerLogicJson, collectedErrors);
            var workingHours = ParseJson("WorkingHours", WorkingHoursJson, collectedErrors);

            if (collectedErrors.Count > 0)
            {
                request = new UpdateAgentOperatingProfileRequest();
                errors = collectedErrors.ToDictionary(x => x.Key, x => x.Value.ToArray(), StringComparer.OrdinalIgnoreCase);
                return false;
            }

            request = new UpdateAgentOperatingProfileRequest
            {
                Status = Status,
                RoleBrief = RoleBrief,
                Objectives = objectives,
                Kpis = kpis,
                ToolPermissions = toolPermissions,
                DataScopes = dataScopes,
                ApprovalThresholds = approvalThresholds,
                EscalationRules = escalationRules,
                TriggerLogic = triggerLogic,
                WorkingHours = workingHours
            };

            errors = new Dictionary<string, string[]>();
            return true;
        }

        private static Dictionary<string, JsonNode?> ParseJson(
            string fieldName,
            string value,
            IDictionary<string, List<string>> errors)
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                return new Dictionary<string, JsonNode?>(StringComparer.OrdinalIgnoreCase);
            }

            try
            {
                var payload = JsonSerializer.Deserialize<Dictionary<string, JsonNode?>>(value, JsonEditorOptions);
                if (payload is null)
                {
                    AddError(errors, fieldName, $"{fieldName} must be a JSON object.");
                    return new Dictionary<string, JsonNode?>(StringComparer.OrdinalIgnoreCase);
                }

                return new Dictionary<string, JsonNode?>(payload, StringComparer.OrdinalIgnoreCase);
            }
            catch (JsonException)
            {
                AddError(errors, fieldName, $"{fieldName} must be valid JSON.");
                return new Dictionary<string, JsonNode?>(StringComparer.OrdinalIgnoreCase);
            }
        }

        private static string Serialize(IDictionary<string, JsonNode?> payload) =>
            JsonSerializer.Serialize(payload, JsonEditorOptions);

        private static void AddError(IDictionary<string, List<string>> errors, string key, string message)
        {
            if (!errors.TryGetValue(key, out var messages))
            {
                messages = [];
                errors[key] = messages;
            }

            messages.Add(message);
        }
    }
}