@page "/agents/manage"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Text.Json
@using System.Text.Json.Nodes
@using Microsoft.AspNetCore.Components
@inject OnboardingApiClient OnboardingApiClient
@inject AgentApiClient AgentApiClient
@inject NavigationManager Navigation

<PageTitle>Agents</PageTitle>

@if (isLoading)
{
    <section class="py-4">
        <h1>Agent management</h1>
        <p class="text-body-secondary mb-0">Loading template catalog and company roster...</p>
    </section>
}
else if (CompanyId is null)
{
    <section class="py-4 dashboard-hero">
        <div class="wizard-card">
            <h1>Select a company</h1>
            <p class="text-body-secondary">Choose the company where you want to browse templates and hire agents.</p>

            @if (activeMemberships.Count == 0)
            {
                <p class="mb-0">No active company memberships are available yet.</p>
            }
            else
            {
                <div class="template-grid">
                    @foreach (var membership in activeMemberships)
                    {
                        <a class="template-card text-decoration-none text-reset" href="@($"/agents/manage?companyId={membership.CompanyId}")">
                            <strong>@membership.CompanyName</strong>
                            <div class="text-body-secondary mt-2">Role: @membership.MembershipRole</div>
                        </a>
                    }
                </div>
            }
        </div>
    </section>
}
else
{
    var canViewDirectory = CanViewDirectory;
    <section class="py-4 dashboard-hero">
        <div class="agent-layout">
            <div class="wizard-card">
                <span class="dashboard-kicker">Template catalog</span>
                <h1>Hire agents for @(companyAccess?.CompanyName ?? "your company")</h1>
                <p class="text-body-secondary">Start from seeded templates, customize identity fields and avatar references, and create an active company-owned roster entry.</p>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(successMessage))
                {
                    <div class="alert alert-success">@successMessage</div>
                }

                <div class="agent-template-grid mt-4">
                    @foreach (var template in templates)
                    {
                        var isSelected = string.Equals(selectedTemplateId, template.TemplateId, StringComparison.OrdinalIgnoreCase);
                        <button class="template-card agent-template-card @(isSelected ? "is-selected" : null)"
                                type="button"
                                @onclick="@(() => SelectTemplate(template.TemplateId))">
                            <div class="agent-template-header">
                                <strong>@template.RoleName</strong>
                                <span class="badge text-bg-light">@template.DefaultSeniority</span>
                            </div>
                            <div class="text-body-secondary">@template.Department</div>
                            <p class="mb-0 mt-3">@template.PersonaSummary</p>
                        </button>
                    }
                </div>
            </div>

            <div class="wizard-card">
                <h2 class="h4 mb-3">Customize and hire</h2>

                @if (selectedTemplate is null)
                {
                    <p class="text-body-secondary mb-0">Select a template to prepare the hire form.</p>
                }
                else
                {
                    <EditForm Model="@hireModel" OnValidSubmit="@HandleHireAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label" for="display-name">Name</label>
                            <InputText id="display-name" class="form-control" @bind-Value="hireModel.DisplayName" />
                            <ValidationMessage For="@(() => hireModel.DisplayName)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="avatar-url">Avatar URL or file reference</label>
                            <InputText id="avatar-url" class="form-control" @bind-Value="hireModel.AvatarUrl" />
                            <div class="form-text">Use an external <code>https://</code> URL or a file/object-storage reference. Uploads and inline image data are not supported.</div>
                            <ValidationMessage For="@(() => hireModel.AvatarUrl)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="department">Department</label>
                            <InputText id="department" class="form-control" @bind-Value="hireModel.Department" />
                            <ValidationMessage For="@(() => hireModel.Department)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="role-name">Role</label>
                            <InputText id="role-name" class="form-control" @bind-Value="hireModel.RoleName" />
                            <ValidationMessage For="@(() => hireModel.RoleName)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="seniority">Seniority</label>
                            <InputSelect id="seniority" class="form-select" @bind-Value="hireModel.Seniority">
                                @foreach (var option in seniorityOptions)
                                {
                                    <option value="@option">@option</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => hireModel.Seniority)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="personality">Personality</label>
                            <InputTextArea id="personality" class="form-control" rows="4" @bind-Value="hireModel.Personality" />
                            <ValidationMessage For="@(() => hireModel.Personality)" />
                        </div>

                        <div class="dashboard-actions">
                            <button class="btn btn-primary" type="submit" disabled="@isSubmitting">Hire agent</button>
                            <button class="btn btn-outline-secondary" type="button" @onclick="@ResetSelectedTemplate">Reset defaults</button>
                        </div>
                    </EditForm>
                }
            </div>
        </div>

        @if (CanManageProfiles)
        {
            <div class="wizard-card mt-4">
                <div class="agent-roster-header">
                    <div>
                        <span class="dashboard-kicker">Operating profile</span>
                        <h2 class="h4 mb-0 mt-2">Agent configuration</h2>
                    </div>
                    <p class="text-body-secondary mb-0">Use the canonical profile page for identity, activity, and future analytics. This editor remains focused on operating configuration.</p>
                </div>

                @if (selectedAgentProfile is null)
                {
                    <p class="text-body-secondary mb-0 mt-3">Select an agent from the roster to load the operating profile editor.</p>
                }
                else
                {
                    @if (!string.IsNullOrWhiteSpace(profileErrorMessage))
                    {
                        <div class="alert alert-danger mt-3">@profileErrorMessage</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(profileSuccessMessage))
                    {
                        <div class="alert alert-success mt-3">@profileSuccessMessage</div>
                    }

                    <EditForm Model="@profileModel" OnValidSubmit="@HandleProfileSaveAsync" class="mt-4">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" for="profile-status">Status</label>
                                <InputSelect id="profile-status" class="form-select" @bind-Value="profileModel.Status" disabled="@(!CanEditSelectedAgentStatus)">
                                    @foreach (var status in GetStatusOptionsForSelectedAgent())
                                    {
                                        <option value="@status">@status</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => profileModel.Status)" />
                                <div class="form-text">
                                    Paused and archived agents are excluded from new task assignment.
                                    @if (selectedAgentProfile.Visibility.CanPauseOrRestrictAgent)
                                    {
                                        <span> Owner and admin memberships can manage all status states.</span>
                                    }
                                    else
                                    {
                                        <span> Your membership can only move agents between active and paused while they remain outside restricted or archived states.</span>
                                    }
                                </div>
                                @foreach (var error in GetProfileErrors(nameof(AgentOperatingProfileFormModel.Status)))
                                {
                                    <div class="text-danger small mt-1">@error</div>
                                }
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="profile-autonomy">Autonomy</label>
                                <InputSelect id="profile-autonomy" class="form-select" @bind-Value="profileModel.AutonomyLevel" disabled="@(!selectedAgentProfile.Visibility.CanEditSensitiveGovernance)">
                                    @foreach (var level in GetAutonomyOptionsForSelectedAgent())
                                    {
                                        <option value="@level">@ToDisplayText(level)</option>
                                    }
                                </InputSelect>
                                <div class="form-text">
                                    @if (selectedAgentProfile.Visibility.CanEditSensitiveGovernance)
                                    {
                                        <span>Autonomy, tools, scopes, thresholds, escalation, and trigger logic are governance settings.</span>
                                    }
                                    else
                                    {
                                        <span>Autonomy changes require owner or admin access.</span>
                                    }
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="profile-updated">Last updated</label>
                                <input id="profile-updated" class="form-control" value="@selectedAgentProfile.UpdatedUtc.ToLocalTime().ToString("g")" disabled />
                            </div>
                        </div>

                        <div class="mt-3">
                            <label class="form-label" for="role-brief">Role brief</label>
                            <InputTextArea id="role-brief" class="form-control" rows="3" @bind-Value="profileModel.RoleBrief" disabled="@(!selectedAgentProfile.Visibility.CanEditRoleBrief)" />
                            <ValidationMessage For="@(() => profileModel.RoleBrief)" />
                            @foreach (var error in GetProfileErrors(nameof(AgentOperatingProfileFormModel.RoleBrief)))
                            {
                                <div class="text-danger small mt-1">@error</div>
                            }
                        </div>

                        @RenderJsonEditor("Objectives", "Objectives", () => profileModel.ObjectivesJson, !selectedAgentProfile.Visibility.CanEditObjectives)
                        @RenderJsonEditor("KPIs", "Kpis", () => profileModel.KpisJson, !selectedAgentProfile.Visibility.CanEditKpis)

                        @if (selectedAgentProfile.Visibility.CanViewPermissions)
                        {
                            @RenderJsonEditor("Tool permissions", "ToolPermissions", () => profileModel.ToolPermissionsJson, !selectedAgentProfile.Visibility.CanEditSensitiveGovernance)
                            @RenderJsonEditor("Data scopes", "DataScopes", () => profileModel.DataScopesJson, !selectedAgentProfile.Visibility.CanEditSensitiveGovernance)
                        }
                        else
                        {
                            <p class="text-body-secondary mt-3 mb-0">Tool permissions and data scopes are hidden for your membership role.</p>
                        }

                        @if (selectedAgentProfile.Visibility.CanViewThresholds)
                        {
                            @RenderJsonEditor("Approval thresholds", "ApprovalThresholds", () => profileModel.ApprovalThresholdsJson, !selectedAgentProfile.Visibility.CanEditSensitiveGovernance)
                            @RenderJsonEditor("Escalation rules", "EscalationRules", () => profileModel.EscalationRulesJson, !selectedAgentProfile.Visibility.CanEditSensitiveGovernance)
                            @RenderJsonEditor("Trigger logic", "TriggerLogic", () => profileModel.TriggerLogicJson, !selectedAgentProfile.Visibility.CanEditSensitiveGovernance)
                        }
                        else
                        {
                            <p class="text-body-secondary mt-3 mb-0">Approval thresholds, escalation rules, and trigger logic are hidden for your membership role.</p>
                        }

                        @if (selectedAgentProfile.Visibility.CanViewWorkingHours)
                        {
                            @RenderJsonEditor("Working hours", "WorkingHours", () => profileModel.WorkingHoursJson, !selectedAgentProfile.Visibility.CanEditWorkingHours)
                        }
                        else
                        {
                            <p class="text-body-secondary mt-3 mb-0">Working hours are hidden for your membership role.</p>
                        }

                        <div class="dashboard-actions mt-3">
                            <button class="btn btn-primary" type="submit" disabled="@isSavingProfile">Save operating profile</button>
                            <a class="btn btn-outline-secondary" href="@BuildProfileUri(selectedAgentId ?? Guid.Empty)">Open canonical profile</a>
                        </div>
                    </EditForm>
                }
            }
            </div>
        }

        <div class="wizard-card mt-4">
            <div class="agent-roster-header">
                <div>
                    <span class="dashboard-kicker">Company roster</span>
                    <h2 class="h4 mb-0 mt-2">Company agents</h2>
                </div>
                <span class="badge text-bg-light">@rosterResponse.Items.Count total</span>
            </div>

            @if (!canViewDirectory)
            {
                <p class="text-body-secondary mb-0 mt-3">Manager, admin, or owner membership is required to view the agent roster.</p>
            }
            else
            {
                <div class="agent-filter-bar mt-4">
                    <div>
                        <label class="form-label" for="department-filter">Department</label>
                        <InputSelect id="department-filter" class="form-select" @bind-Value="Department">
                            <option value="">All departments</option>
                            @foreach (var department in rosterResponse.Departments)
                            {
                                <option value="@department">@department</option>
                            }
                        </InputSelect>
                    </div>
                    <div>
                        <label class="form-label" for="status-filter">Status</label>
                        <InputSelect id="status-filter" class="form-select" @bind-Value="Status">
                            <option value="">All statuses</option>
                            @foreach (var status in rosterResponse.Statuses)
                            {
                                <option value="@status">@GetStatusLabel(status)</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="dashboard-actions">
                        <button class="btn btn-primary" type="button" @onclick="ApplyFilters">Apply filters</button>
                        <button class="btn btn-outline-secondary" type="button" @onclick="ClearFilters">Clear</button>
                    </div>
                </div>

                @if (rosterResponse.Items.Count == 0)
                {
                    <p class="text-body-secondary mb-0 mt-4">No agents match the selected filters.</p>
                }
                else
                {
                    <div class="table-responsive mt-4">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th scope="col">Name</th>
                                    <th scope="col">Role</th>
                                    <th scope="col">Department</th>
                                    <th scope="col">Status</th>
                                    <th scope="col">Autonomy</th>
                                    <th scope="col">Workload and health</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var agent in rosterResponse.Items)
                                {
                                    <tr class="@(selectedAgentId == agent.Id ? "table-active" : null)">
                                        <th scope="row">
                                            <a class="fw-semibold text-decoration-none" href="@GetProfileRoute(agent)">@agent.DisplayName</a>
                                            @if (CanManageProfiles)
                                            {
                                                <div class="mt-2">
                                                    <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="@(() => OpenEditor(agent.Id))">Configure</button>
                                                </div>
                                            }
                                            @if (IsDirectChatEligible(agent.Status))
                                            {
                                                <div class="mt-2"><a class="btn btn-sm btn-primary" href="@BuildChatUri(agent.CompanyId, agent.Id)">Chat</a></div>
                                            }
                                        </th>
                                        <td>@agent.RoleName</td>
                                        <td>@agent.Department</td>
                                        <td>
                                            <span class="badge @GetStatusBadgeCss(agent.Status)">@GetStatusLabel(agent.Status)</span>
                                        </td>
                                        <td>@ToDisplayText(agent.AutonomyLevel)</td>
                                        <td>
                                            <div class="fw-semibold @GetHealthCss(agent.WorkloadSummary.HealthStatus)">@agent.WorkloadSummary.Summary</div>
                                            <div class="small text-body-secondary mt-1">@FormatRosterActivity(agent.WorkloadSummary.LastActivityUtc)</div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>
    </section>
}

@code {
    [SupplyParameterFromQuery(Name = "companyId")]
    public Guid? CompanyId { get; set; }

    [SupplyParameterFromQuery(Name = "department")]
    public string? Department { get; set; }

    [SupplyParameterFromQuery(Name = "status")]
    public string? Status { get; set; }

    [SupplyParameterFromQuery(Name = "agentId")]
    public Guid? AgentId { get; set; }

    private static readonly JsonSerializerOptions JsonEditorOptions = new(JsonSerializerDefaults.Web) { WriteIndented = true };
    private readonly string[] seniorityOptions = [ "junior", "mid", "senior", "lead", "executive" ];
    private readonly string[] autonomyOptions = [ "level_0", "level_1", "level_2", "level_3" ];
    private readonly string[] statusOptions = [ "active", "paused", "restricted", "archived" ];
    private bool isLoading = true;
    private bool isSubmitting;
    private bool isSavingProfile;
    private string? errorMessage;
    private string? successMessage;
    private string? profileErrorMessage;
    private string? profileSuccessMessage;
    private CurrentUserContextViewModel? currentUser;
    private CompanyAccessViewModel? companyAccess;
    private List<AgentTemplateCatalogItemViewModel> templates = [];
    private AgentRosterResponseViewModel rosterResponse = new();
    private HireAgentFormModel hireModel = new();
    private AgentOperatingProfileViewModel? selectedAgentProfile;
    private AgentOperatingProfileFormModel profileModel = new();
    private Dictionary<string, string[]> profileErrors = new(StringComparer.OrdinalIgnoreCase);
    private Guid? selectedAgentId;
    private string? selectedTemplateId;

    private IReadOnlyList<CompanyMembershipViewModel> activeMemberships =>
        currentUser?.Memberships.Where(x => string.Equals(x.Status, "active", StringComparison.OrdinalIgnoreCase)).ToList()
        ?? [];

    private AgentTemplateCatalogItemViewModel? selectedTemplate =>
        templates.FirstOrDefault(x => string.Equals(x.TemplateId, selectedTemplateId, StringComparison.OrdinalIgnoreCase));

    // Owner, admin, and manager memberships can open the operating-profile experience.
    private bool CanManageProfiles =>
        string.Equals(companyAccess?.MembershipRole, "owner", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(companyAccess?.MembershipRole, "admin", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(companyAccess?.MembershipRole, "manager", StringComparison.OrdinalIgnoreCase);

    private bool CanEditSelectedAgentStatus =>
        selectedAgentProfile is not null &&
        selectedAgentProfile.Visibility.CanEditStatus &&
        (selectedAgentProfile.Visibility.CanPauseOrRestrictAgent || IsManagerEditableStatus(selectedAgentProfile.Status));

    private IEnumerable<string> GetStatusOptionsForSelectedAgent() =>
        EnsureCurrentOption(statusOptions, selectedAgentProfile?.Status, IsManagerEditableStatus, selectedAgentProfile?.Visibility.CanPauseOrRestrictAgent == true);

    private IEnumerable<string> GetAutonomyOptionsForSelectedAgent() => EnsureCurrentOption(autonomyOptions, selectedAgentProfile?.AutonomyLevel, static _ => true, true);

    private bool CanViewDirectory =>
        CanManageProfiles ||
        string.Equals(companyAccess?.MembershipRole, "manager", StringComparison.OrdinalIgnoreCase);

    private string BuildProfileUri(Guid agentId) => $"/agents/{agentId}?companyId={CompanyId}";


    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            currentUser = await OnboardingApiClient.GetCurrentUserContextAsync();

            if (CompanyId is null && currentUser?.ActiveCompany is not null)
            {
                NavigateIfChanged($"/agents/manage?companyId={currentUser.ActiveCompany.CompanyId}");
                return;
            }

            if (CompanyId is Guid companyId)
            {
                companyAccess = await OnboardingApiClient.GetCompanyAccessAsync(companyId);
                if (companyAccess is null)
                {
                    errorMessage = "The selected company could not be loaded.";
                    templates = [];
                    rosterResponse = new AgentRosterResponseViewModel();
                }
                else
                {
                    templates = (await AgentApiClient.GetTemplatesAsync(companyId)).ToList();

                    if (selectedTemplateId is null || templates.All(x => !string.Equals(x.TemplateId, selectedTemplateId, StringComparison.OrdinalIgnoreCase)))
                    {
                        selectedTemplateId = templates.FirstOrDefault()?.TemplateId;
                        ResetSelectedTemplate();
                    }
                    rosterResponse = CanViewDirectory
                        ? await AgentApiClient.GetRosterViewAsync(companyId, Department, Status)
                        : new AgentRosterResponseViewModel();

                    if (CanManageProfiles && rosterResponse.Items.Count > 0)
                    {
                        var nextSelectedAgent = AgentId
                            ?? selectedAgentId
                            ?? rosterResponse.Items[0].Id;

                        await SelectAgentAsync(nextSelectedAgent);
                    }
                    else
                    {
                        selectedAgentId = null;
                        selectedAgentProfile = null;
                        profileModel = new AgentOperatingProfileFormModel();
                        profileErrors.Clear();
                    }
                }
            }
        }
        catch (OnboardingApiException ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SelectTemplate(string templateId)
    {
        selectedTemplateId = templateId;
        ResetSelectedTemplate();
    }

    private void ResetSelectedTemplate()
    {
        if (selectedTemplate is null)
        {
            hireModel = new HireAgentFormModel();
            return;
        }

        hireModel = new HireAgentFormModel
        {
            TemplateId = selectedTemplate.TemplateId,
            DisplayName = selectedTemplate.RoleName,
            AvatarUrl = selectedTemplate.AvatarUrl,
            Department = selectedTemplate.Department,
            RoleName = selectedTemplate.RoleName,
            Personality = selectedTemplate.PersonaSummary,
            Seniority = selectedTemplate.DefaultSeniority
        };
    }

    private async Task SelectAgentAsync(Guid agentId)
    {
        if (CompanyId is not Guid companyId)
        {
            return;
        }

        selectedAgentId = agentId;
        profileErrorMessage = null;
        profileSuccessMessage = null;
        profileErrors.Clear();

        if (!CanManageProfiles)
        {
            return;
        }

        try
        {
            selectedAgentProfile = await AgentApiClient.GetOperatingProfileAsync(companyId, agentId);
            profileModel = AgentOperatingProfileFormModel.FromViewModel(selectedAgentProfile);
            NavigateIfChanged(BuildAgentsUri(companyId, Department, Status, agentId));
        }
        catch (OnboardingApiException ex)
        {
            selectedAgentProfile = null;
            profileModel = new AgentOperatingProfileFormModel();
            profileErrorMessage = ex.Message;
        }
    }

    private async Task HandleProfileSaveAsync()
    {
        if (CompanyId is not Guid companyId || selectedAgentId is not Guid agentId)
        {
            return;
        }

        if (selectedAgentProfile is null)
        {
            profileErrorMessage = "Select an agent profile before saving.";
            profileSuccessMessage = null;
            return;
        }

        if (!profileModel.TryCreateRequest(selectedAgentProfile.Visibility, out var request, out var localErrors))
        {
            profileErrors = localErrors;
            profileErrorMessage = "Fix the highlighted operating profile fields and try again.";
            profileSuccessMessage = null;
            return;
        }

        isSavingProfile = true;
        profileErrorMessage = null;
        profileSuccessMessage = null;
        profileErrors.Clear();

        try
        {
            selectedAgentProfile = await AgentApiClient.UpdateOperatingProfileAsync(companyId, agentId, request);
            profileModel = AgentOperatingProfileFormModel.FromViewModel(selectedAgentProfile);
            rosterResponse = await AgentApiClient.GetRosterViewAsync(companyId, Department, Status);
            profileSuccessMessage = $"{selectedAgentProfile.DisplayName} operating profile was saved.";
        }
        catch (OnboardingApiException ex)
        {
            profileErrorMessage = ex.Message;
            profileErrors = ex.Errors.ToDictionary(x => x.Key, x => x.Value, StringComparer.OrdinalIgnoreCase);
        }
        finally
        {
            isSavingProfile = false;
        }
    }

    private IReadOnlyList<string> GetProfileErrors(string key)
    {
        var matched = profileErrors
            .Where(entry =>
                string.Equals(entry.Key, key, StringComparison.OrdinalIgnoreCase) ||
                entry.Key.StartsWith($"{key}.", StringComparison.OrdinalIgnoreCase) ||
                entry.Key.StartsWith($"{key}[", StringComparison.OrdinalIgnoreCase))
            .SelectMany(entry => entry.Value)
            .Distinct(StringComparer.Ordinal)
            .ToArray();

        return matched.Length == 0
            ? []
            : matched;
    }

    private static string GetStatusBadgeCss(string? status) =>
        status?.Trim().ToLowerInvariant() switch
        {
            "active" => "text-bg-success",
            "paused" => "text-bg-warning",
            "restricted" => "text-bg-secondary",
            "archived" => "text-bg-dark",
            _ => "text-bg-light"
        };

    private static string GetStatusLabel(string? status) =>
        status?.Trim().ToLowerInvariant() switch
        {
            "active" => "Active",
            "paused" => "Paused",
            "restricted" => "Restricted",
            "archived" => "Archived",
            _ => string.IsNullOrWhiteSpace(status) ? "Unknown" : status.Trim()
        };

    private static string GetHealthCss(string? healthStatus) =>
        healthStatus?.Trim().ToLowerInvariant() switch
        {
            "healthy" => "agent-health-healthy",
            "unknown" => "text-body-secondary",
            "archived" => "agent-health-archived",
            _ => "agent-health-attention"
        };

    private string GetProfileRoute(AgentRosterItemViewModel agent) => string.IsNullOrWhiteSpace(agent.ProfileRoute) ? BuildProfileUri(agent.Id) : agent.ProfileRoute!;
    private static string ToDisplayText(string? value) =>
        string.IsNullOrWhiteSpace(value)
            ? "Unknown"
            : value.Replace("_", " ", StringComparison.Ordinal).Trim();

    private void ApplyFilters()
    {
        if (CompanyId is Guid selectedCompanyId && rosterResponse.Items.Count == 0)
        {
            selectedAgentId = null;
        }
        if (CompanyId is Guid companyIdForNavigation)
        {
            Navigation.NavigateTo(BuildAgentsUri(companyIdForNavigation, Department, Status, AgentId));
        }
    }

    private void ClearFilters()
    {
        Department = null;
        Status = null;
        ApplyFilters();
    }

    private static bool IsSupportedStatus(string? status) =>
        status?.Trim().ToLowerInvariant() is
            "active" or
            "paused" or
            "restricted" or
            "archived";

    private static string FormatRosterActivity(DateTime? lastActivityUtc) =>
        lastActivityUtc is null ? "No recent activity" : $"Last activity {lastActivityUtc.Value.ToLocalTime():g}";
    private static bool IsDirectChatEligible(string? status) =>
        !string.Equals(status, "paused", StringComparison.OrdinalIgnoreCase) &&
        !string.Equals(status, "archived", StringComparison.OrdinalIgnoreCase);

    private static string BuildChatUri(Guid companyId, Guid agentId)
    {
        return $"/agents/{agentId}/chat?companyId={companyId}";
    }


    private string BuildAgentsUri(Guid companyId, string? department, string? status, Guid? agentId)
    {
        var query = new List<string> { $"companyId={companyId}" };

        if (!string.IsNullOrWhiteSpace(department))
        {
            query.Add($"department={Uri.EscapeDataString(department)}");
        }

        if (!string.IsNullOrWhiteSpace(status))
        {
            query.Add($"status={Uri.EscapeDataString(status)}");
        }

        if (agentId is Guid selectedAgent)
        {
            query.Add($"agentId={selectedAgent}");
        }

        return $"/agents/manage?{string.Join("&", query)}";
    }

    private void NavigateIfChanged(string targetUri)
    {
        var currentRelativeUri = Navigation.ToBaseRelativePath(Navigation.Uri);
        var targetRelativeUri = Navigation.ToBaseRelativePath(Navigation.ToAbsoluteUri(targetUri).ToString());

        if (string.Equals(currentRelativeUri, targetRelativeUri, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        Navigation.NavigateTo(targetUri, replace: true);
    }

    private void OpenEditor(Guid agentId) => Navigation.NavigateTo(BuildAgentsUri(CompanyId!.Value, Department, Status, agentId));

    private static IEnumerable<string> EnsureCurrentOption(IEnumerable<string> options, string? currentValue, Func<string, bool> predicate, bool allowAll)
    {
        var resolved = allowAll
            ? options.ToList()
            : options.Where(predicate).ToList();

        if (!string.IsNullOrWhiteSpace(currentValue) &&
            !resolved.Contains(currentValue.Trim(), StringComparer.OrdinalIgnoreCase))
        {
            resolved.Add(currentValue.Trim());
        }

        return resolved;
    }

    private static bool IsManagerEditableStatus(string? status) => string.Equals(status, "active", StringComparison.OrdinalIgnoreCase) || string.Equals(status, "paused", StringComparison.OrdinalIgnoreCase);

    private RenderFragment RenderJsonEditor(string label, string fieldName, Func<string> valueAccessor, bool isReadOnly = false) => builder =>
    {
        var sequence = 0;

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "mt-3");

        builder.OpenElement(sequence++, "label");
        builder.AddAttribute(sequence++, "class", "form-label");
        builder.AddAttribute(sequence++, "for", fieldName);
        builder.AddContent(sequence++, label);
        builder.CloseElement();

        builder.OpenElement(sequence++, "textarea");
        builder.AddAttribute(sequence++, "id", fieldName);
        builder.AddAttribute(sequence++, "class", "form-control");
        builder.AddAttribute(sequence++, "rows", "8");
        builder.AddAttribute(sequence++, "value", valueAccessor());
        builder.AddAttribute(sequence++, "disabled", isReadOnly);
        builder.AddAttribute(sequence++, "onchange", EventCallback.Factory.CreateBinder<string>(this, value =>
        {
            switch (fieldName)
            {
                case "Objectives": profileModel.ObjectivesJson = value; break;
                case "Kpis": profileModel.KpisJson = value; break;
                case "ToolPermissions": profileModel.ToolPermissionsJson = value; break;
                case "DataScopes": profileModel.DataScopesJson = value; break;
                case "ApprovalThresholds": profileModel.ApprovalThresholdsJson = value; break;
                case "EscalationRules": profileModel.EscalationRulesJson = value; break;
                case "TriggerLogic": profileModel.TriggerLogicJson = value; break;
                case "WorkingHours": profileModel.WorkingHoursJson = value; break;
            }
        }, valueAccessor()));
        builder.CloseElement();

        foreach (var error in GetProfileErrors(fieldName))
        {
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "text-danger small mt-1");
            builder.AddContent(sequence++, error);
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private async Task HandleHireAsync()
    {
        if (CompanyId is not Guid companyId)
        {
            return;
        }

        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var result = await AgentApiClient.CreateAgentFromTemplateAsync(companyId, hireModel.ToRequest());
            rosterResponse = await AgentApiClient.GetRosterViewAsync(companyId, Department, Status);
            successMessage = $"{result.Agent.DisplayName} was hired and added to the company roster.";

            if (CanManageProfiles)
            {
                await SelectAgentAsync(result.Agent.Id);
            }
            else
            {
                selectedAgentId = result.Agent.Id;
            }

            ResetSelectedTemplate();
        }
        catch (OnboardingApiException ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class HireAgentFormModel : IValidatableObject
    {
        [Required, StringLength(100)]
        public string TemplateId { get; set; } = string.Empty;

        [Required, StringLength(200)]
        public string DisplayName { get; set; } = string.Empty;

        [StringLength(2048)]
        public string? AvatarUrl { get; set; }

        [StringLength(100)]
        public string? Department { get; set; }

        [StringLength(100)]
        public string? RoleName { get; set; }

        [StringLength(1000)]
        public string? Personality { get; set; }

        [StringLength(32)]
        public string? Seniority { get; set; }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (string.IsNullOrWhiteSpace(AvatarUrl))
            {
                yield break;
            }

            var trimmed = AvatarUrl.Trim();
            if (trimmed.StartsWith("data:", StringComparison.OrdinalIgnoreCase) ||
                trimmed.StartsWith("blob:", StringComparison.OrdinalIgnoreCase) ||
                (trimmed.Length >= 256 &&
                 !trimmed.Contains("/", StringComparison.Ordinal) &&
                 !trimmed.Contains("\\", StringComparison.Ordinal) &&
                 !trimmed.Contains(".", StringComparison.Ordinal) &&
                 (trimmed.StartsWith("iVBORw0KGgo", StringComparison.Ordinal) ||
                  trimmed.StartsWith("/9j/", StringComparison.Ordinal) ||
                  trimmed.StartsWith("R0lGOD", StringComparison.Ordinal) ||
                  trimmed.StartsWith("PHN2Zy", StringComparison.Ordinal))))
            {
                yield return new ValidationResult("AvatarUrl must be an external http/https URL or a file/storage reference, not inline image data.", [nameof(AvatarUrl)]);
                yield break;
            }

            if ((trimmed.Contains("://", StringComparison.Ordinal) || trimmed.StartsWith("http:", StringComparison.OrdinalIgnoreCase) || trimmed.StartsWith("https:", StringComparison.OrdinalIgnoreCase)) &&
                (!Uri.TryCreate(trimmed, UriKind.Absolute, out var uri) || (uri.Scheme != Uri.UriSchemeHttp && uri.Scheme != Uri.UriSchemeHttps)))
            {
                yield return new ValidationResult("AvatarUrl must be a valid absolute http/https URL or a file/storage reference.", [nameof(AvatarUrl)]);
            }
        }

        public CreateAgentFromTemplateRequest ToRequest() =>
            new()
            {
                TemplateId = TemplateId,
                DisplayName = DisplayName,
                AvatarUrl = AvatarUrl,
                Department = Department,
                RoleName = RoleName,
                Personality = Personality,
                Seniority = Seniority
            };
    }

    private sealed class AgentOperatingProfileFormModel : IValidatableObject
    {
        [Required, StringLength(32)]
        public string Status { get; set; } = "active";

        [StringLength(4000)]
        public string? RoleBrief { get; set; }

        [StringLength(32)]
        public string AutonomyLevel { get; set; } = "level_0";

        public string ObjectivesJson { get; set; } = "{}";
        public string KpisJson { get; set; } = "{}";
        public string ToolPermissionsJson { get; set; } = "{}";
        public string DataScopesJson { get; set; } = "{}";
        public string ApprovalThresholdsJson { get; set; } = "{}";
        public string EscalationRulesJson { get; set; } = "{}";
        public string TriggerLogicJson { get; set; } = "{}";
        public string WorkingHoursJson { get; set; } = "{}";

        public static AgentOperatingProfileFormModel FromViewModel(AgentOperatingProfileViewModel model) =>
            new()
            {
                Status = NormalizeStatus(model.Status),
                AutonomyLevel = NormalizeToken(model.AutonomyLevel),
                RoleBrief = model.RoleBrief,
                ObjectivesJson = Serialize(model.Objectives),
                KpisJson = Serialize(model.Kpis),
                ToolPermissionsJson = Serialize(model.ToolPermissions),
                DataScopesJson = Serialize(model.DataScopes),
                ApprovalThresholdsJson = Serialize(model.ApprovalThresholds),
                EscalationRulesJson = Serialize(model.EscalationRules),
                TriggerLogicJson = Serialize(model.TriggerLogic),
                WorkingHoursJson = Serialize(model.WorkingHours)
            };

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (!IsSupportedStatus(Status))
            {
                yield return new ValidationResult(
                    "Status must be one of active, paused, restricted, or archived.",
                    [nameof(Status)]);
            }

            if (!IsSupportedAutonomyLevel(AutonomyLevel))
            {
                yield return new ValidationResult(
                    "AutonomyLevel must be one of level_0, level_1, level_2, or level_3.",
                    [nameof(AutonomyLevel)]);
            }
        }

        public bool TryCreateRequest(
            AgentProfileVisibilityViewModel visibility,
            out UpdateAgentOperatingProfileRequest request,
            out Dictionary<string, string[]> errors)
        {
            var collectedErrors = new Dictionary<string, List<string>>(StringComparer.OrdinalIgnoreCase);

            var objectives = visibility.CanEditObjectives ? ParseJson("Objectives", ObjectivesJson, collectedErrors) : null;
            var kpis = visibility.CanEditKpis ? ParseJson("Kpis", KpisJson, collectedErrors) : null;
            var toolPermissions = visibility.CanEditSensitiveGovernance ? ParseJson("ToolPermissions", ToolPermissionsJson, collectedErrors) : null;
            var dataScopes = visibility.CanEditSensitiveGovernance ? ParseJson("DataScopes", DataScopesJson, collectedErrors) : null;
            var approvalThresholds = visibility.CanEditSensitiveGovernance ? ParseJson("ApprovalThresholds", ApprovalThresholdsJson, collectedErrors) : null;
            var escalationRules = visibility.CanEditSensitiveGovernance ? ParseJson("EscalationRules", EscalationRulesJson, collectedErrors) : null;
            var triggerLogic = visibility.CanEditSensitiveGovernance ? ParseJson("TriggerLogic", TriggerLogicJson, collectedErrors) : null;
            var workingHours = visibility.CanEditWorkingHours ? ParseJson("WorkingHours", WorkingHoursJson, collectedErrors) : null;

            if (collectedErrors.Count > 0)
            {
                request = new UpdateAgentOperatingProfileRequest();
                errors = collectedErrors.ToDictionary(x => x.Key, x => x.Value.ToArray(), StringComparer.OrdinalIgnoreCase);
                return false;
            }

            request = new UpdateAgentOperatingProfileRequest
            {
                Status = NormalizeStatus(Status),
                RoleBrief = visibility.CanEditRoleBrief ? RoleBrief : null,
                AutonomyLevel = visibility.CanEditSensitiveGovernance ? NormalizeToken(AutonomyLevel) : null,
                Objectives = objectives,
                Kpis = kpis,
                ToolPermissions = toolPermissions,
                DataScopes = dataScopes,
                ApprovalThresholds = approvalThresholds,
                EscalationRules = escalationRules,
                TriggerLogic = triggerLogic,
                WorkingHours = workingHours
            };

            errors = new Dictionary<string, string[]>();
            return true;
        }

        private static Dictionary<string, JsonNode?> ParseJson(
            string fieldName,
            string value,
            IDictionary<string, List<string>> errors)
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                return new Dictionary<string, JsonNode?>(StringComparer.OrdinalIgnoreCase);
            }

            try
            {
                var payload = JsonSerializer.Deserialize<Dictionary<string, JsonNode?>>(value, JsonEditorOptions);
                if (payload is null)
                {
                    AddError(errors, fieldName, $"{fieldName} must be a JSON object.");
                    return new Dictionary<string, JsonNode?>(StringComparer.OrdinalIgnoreCase);
                }

                return new Dictionary<string, JsonNode?>(payload, StringComparer.OrdinalIgnoreCase);
            }
            catch (JsonException)
            {
                AddError(errors, fieldName, $"{fieldName} must be valid JSON.");
                return new Dictionary<string, JsonNode?>(StringComparer.OrdinalIgnoreCase);
            }
        }

        private static string Serialize(IDictionary<string, JsonNode?> payload) =>
            JsonSerializer.Serialize(payload, JsonEditorOptions);

        private static string NormalizeStatus(string? status) =>
            string.IsNullOrWhiteSpace(status) ? string.Empty : status.Trim().ToLowerInvariant();

        private static string NormalizeToken(string? value) =>
            string.IsNullOrWhiteSpace(value) ? string.Empty : value.Trim().ToLowerInvariant();

        private static bool IsSupportedAutonomyLevel(string? autonomyLevel) =>
            autonomyLevel?.Trim().ToLowerInvariant() is
                "level_0" or
                "level_1" or
                "level_2" or
                "level_3";

        private static void AddError(IDictionary<string, List<string>> errors, string key, string message)
        {
            if (!errors.TryGetValue(key, out var messages))
            {
                messages = [];
                errors[key] = messages;
            }

            messages.Add(message);
        }
    }
}
