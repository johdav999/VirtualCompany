@using System.Diagnostics
@using System.Diagnostics.Metrics
@inject ExecutiveCockpitApiClient ApiClient
@inject ILogger<ExecutiveCockpitDashboard> Logger
@inject FinanceApiClient FinanceApiClient
@inject NavigationManager Navigation

<section class="dashboard-detail-stack">
    @if (isLoading)
    {
        <div class="wizard-card wizard-card--compact cockpit-card cockpit-card--wide">
            <h2 class="h5">Executive cockpit</h2>
            <p class="text-body-secondary mb-0">Loading company-wide dashboard...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="wizard-card wizard-card--compact cockpit-card cockpit-card--wide">
            <h2 class="h5">Executive cockpit</h2>
            <div class="alert alert-danger mb-0">@errorMessage</div>
        </div>
    }
    else if (dashboard is null)
    {
        <div class="wizard-card wizard-card--compact cockpit-card cockpit-card--wide">
            <h2 class="h5">Executive cockpit</h2>
            <p class="text-body-secondary mb-0">Dashboard access is not available for this company.</p>
        </div>
    }
    else
    {
        <div class="dashboard-snapshot-grid" data-testid="dashboard-snapshot-grid">
            <article class="wizard-card wizard-card--compact cockpit-card dashboard-snapshot-panel" data-testid="executive-cockpit-finance-widget">
                <div class="cockpit-card__header">
                    <div>
                        <h2 class="h5 mb-1">Finance snapshot</h2>
                        <p class="text-body-secondary mb-0">Cash balance plus receivable and payable signals for the active company.</p>
                    </div>
                    <div class="cockpit-toolbar">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshFinanceSnapshotAsync" disabled="@IsWidgetLoading("finance-snapshot")">Refresh snapshot</button>
                        @if (dashboard.Finance is not null)
                        {
                            <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshFinanceWidgetAsync" disabled="@IsWidgetLoading("finance")">Refresh finance</button>
                        }
                    </div>
                </div>
                @WidgetStatus("finance-snapshot")
                <div class="mt-3">
                    <FinanceSnapshotCard Snapshot="financeSnapshot"
                                         CompanyId="CompanyId"
                                         OnActionClick="OnActionClick" />
                </div>

                @if (dashboard.Finance is not null)
                {
                    @WidgetStatus("finance")

                    @if (dashboard.Finance.LowCashAlert is not null)
                    {
                        <section class="wizard-card mt-3" data-testid="executive-cockpit-low-cash-alert">
                            <div class="cockpit-card__header">
                                <div>
                                    <span class="@SeverityBadgeClass(dashboard.Finance.LowCashAlert.Severity)">@dashboard.Finance.LowCashAlert.Severity</span>
                                    <h4 class="h6 mt-2 mb-1">Low-cash alert</h4>
                                    <p class="mb-0">@dashboard.Finance.LowCashAlert.Summary</p>
                                </div>
                                <a class="btn btn-outline-secondary btn-sm"
                                   href="@ResolveRoute(dashboard.Finance.LowCashAlert.Route, FinanceRoutes.WithCompanyContext(FinanceRoutes.Home, CompanyId))"
                                   data-testid="executive-cockpit-low-cash-alert-open-detail"
                                   @onclick='() => NavigateToAsync(dashboard.Finance.LowCashAlert.Route, FinanceRoutes.WithCompanyContext(FinanceRoutes.Home, CompanyId), "finance", "low-cash-alert")'
                                   @onclick:preventDefault="true">Open detail</a>
                            </div>
                            @if (dashboard.Finance.LowCashAlert.ContributingFactors.Count > 0)
                            {
                                <ul class="mt-3 mb-0">
                                    @foreach (var factor in dashboard.Finance.LowCashAlert.ContributingFactors)
                                    {
                                        <li>@factor</li>
                                    }
                                </ul>
                            }
                        </section>
                    }

                    @if (dashboard.Finance.DeepLinks.Count > 0)
                    {
                        <div class="dashboard-actions mt-3">
                            @foreach (var link in dashboard.Finance.DeepLinks)
                            {
                                <a class="btn btn-outline-secondary"
                                   href="@ResolveRoute(link.Route, FinanceRoutes.WithCompanyContext(FinanceRoutes.Home, CompanyId))"
                                   data-testid="@($"finance-deep-link-{NormalizeCssToken(link.Key)}")"
                                   @onclick='() => NavigateToAsync(link.Route, FinanceRoutes.WithCompanyContext(FinanceRoutes.Home, CompanyId), "finance", link.Key, link.Label)'
                                   @onclick:preventDefault="true">@link.Label</a>
                            }
                        </div>
                    }

                    @if (dashboard.Finance.AvailableActions.Count > 0)
                    {
                        <div class="dashboard-actions mt-3">
                            @foreach (var action in dashboard.Finance.AvailableActions)
                            {
                                @if (string.Equals(action.HttpMethod, "GET", StringComparison.OrdinalIgnoreCase) && HasDrillRoute(action.Route))
                                {
                                    <a class="btn btn-outline-primary"
                                       href="@ResolveRoute(action.Route, FinanceRoutes.WithCompanyContext(FinanceRoutes.Home, CompanyId))"
                                       data-testid="@($"finance-action-{NormalizeCssToken(action.Key)}")"
                                       @onclick='() => NavigateToAsync(action.Route, FinanceRoutes.WithCompanyContext(FinanceRoutes.Home, CompanyId), "finance", action.Key, action.Label)'
                                       @onclick:preventDefault="true">@action.Label</a>
                                }
                                else
                                {
                                    <button class="btn btn-outline-primary"
                                            type="button"
                                            data-testid="@($"finance-action-{NormalizeCssToken(action.Key)}")"
                                            @onclick="() => ExecuteFinanceActionAsync(action)"
                                            disabled="@(!action.IsEnabled || IsFinanceActionRunning(action.Key))">@action.Label</button>
                                }
                            }
                        </div>
                    }
                }

                @if (!string.IsNullOrWhiteSpace(financeActionStatusMessage))
                {
                    <div class="alert alert-success mt-3 mb-0">@financeActionStatusMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(financeActionErrorMessage))
                {
                    <div class="alert alert-warning mt-3 mb-0">@financeActionErrorMessage</div>
                }
            </article>

            <article class="wizard-card wizard-card--compact cockpit-card dashboard-snapshot-panel" data-testid="operations-snapshot-panel">
                <div class="cockpit-card__header">
                    <div>
                        <h2 class="h5 mb-1">Operations snapshot</h2>
                        <p class="text-body-secondary mb-0">Actionable operating counts and threshold-based business signals.</p>
                    </div>
                    <div class="cockpit-toolbar">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshBusinessSignalsAsync" disabled="@IsWidgetLoading("business-signals")">Refresh operations</button>
                        <a class="btn btn-outline-primary btn-sm"
                           href="@QueuePath"
                           @onclick='() => NavigateToAsync(QueuePath, QueuePath, "operations-snapshot", "open-queue", "Open queue")'
                           @onclick:preventDefault="true">Open queue</a>
                    </div>
                </div>
                @WidgetStatus("business-signals")

                <div class="cockpit-summary-kpi-grid mt-3">
                    @foreach (var item in OperationSummaryItems())
                    {
                        <article class="cockpit-summary-kpi">
                            <span class="cockpit-summary-kpi__label">@item.Label</span>
                            <strong class="cockpit-summary-kpi__value">@item.Value</strong>
                            <span class="text-body-secondary">@item.Description</span>
                            <a class="btn btn-sm btn-outline-secondary mt-2 align-self-start"
                               href="@item.Route"
                               @onclick='() => NavigateToAsync(item.Route, item.Route, "operations-snapshot", item.ActionKey, item.Label)'
                               @onclick:preventDefault="true">@item.ActionLabel</a>
                        </article>
                    }
                </div>

                <div class="mt-4">
                    <BusinessSignalsPanel Signals="VisibleBusinessSignals"
                                          CompanyId="CompanyId"
                                          OnActionClick="OnActionClick" />
                </div>
            </article>
        </div>

        <div class="dashboard-two-column-row dashboard-two-column-row--supporting">
        <article class="wizard-card wizard-card--compact cockpit-card" data-testid="agent-activity-panel">
            <div class="cockpit-card__header">
                <div>
                    <h2 class="h5 mb-1">Agent activity</h2>
                    <p class="text-body-secondary mb-0">Recent dashboard-visible activity from agents, workflows, and operating systems.</p>
                </div>
                <a class="btn btn-outline-primary btn-sm"
                   href="@ActivityFeedPath"
                   @onclick='() => NavigateToAsync(ActivityFeedPath, ActivityFeedPath, "agent-activity", "open-activity-feed", "Activity feed")'
                   @onclick:preventDefault="true">Open activity feed</a>
            </div>

            @if (dashboard.RecentActivity.Count == 0)
            {
                <p class="text-body-secondary mt-3 mb-0">No recent activity has been captured for this dashboard session yet.</p>
            }
            else
            {
                <div class="activity-list mt-3">
                    @foreach (var item in dashboard.RecentActivity.OrderByDescending(x => x.OccurredUtc).Take(5))
                    {
                        <article class="activity-item">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <strong>@item.Title</strong>
                                    <div class="text-body-secondary mt-1">@item.Summary</div>
                                    <small class="text-body-secondary">@item.ActivityType | @item.OccurredUtc.ToLocalTime():g</small>
                                </div>
                                <a class="btn btn-sm btn-outline-secondary"
                                   href="@ResolveRoute(item.Route, ActivityFeedPath)"
                                    @onclick='() => NavigateToAsync(item.Route, ActivityFeedPath, "agent-activity", NormalizeCssToken(item.ActivityType), item.Title)'
                                   @onclick:preventDefault="true">Open</a>
                            </div>
                        </article>
                    }
                </div>
            }
        </article>

        <article class="wizard-card wizard-card--compact cockpit-card" data-testid="department-cards-panel">
            <div class="cockpit-card__header">
                <div>
                    <h2 class="h5 mb-1">Department cards</h2>
                    <p class="text-body-secondary mb-0">Department dashboards remain compact, showing only the most meaningful non-zero signals.</p>
                </div>
            </div>
            <div class="cockpit-kpi-grid mt-3">
                @foreach (var departmentSection in VisibleDepartmentSections)
                {
                    var signals = departmentSection.VisibleSignals;
                    var avatarUrl = ResolveDepartmentRepresentativeAvatarUrl(departmentSection);
                    <section class="summary-pill department-section-card" aria-label="@departmentSection.DisplayName">
                        <div class="department-section-card__header">
                            <div class="department-section-card__leader">
                                @if (!string.IsNullOrWhiteSpace(avatarUrl))
                                {
                                    <div class="department-section-card__avatar-frame">
                                        <img class="department-section-card__avatar"
                                             src="@avatarUrl"
                                             alt="@GetDepartmentRepresentativeAvatarAlt(departmentSection)" />
                                    </div>
                                }
                                else
                                {
                                    <div class="department-section-card__avatar-frame department-section-card__avatar-frame--placeholder"
                                         aria-hidden="true">
                                        @GetDepartmentRepresentativeInitials(departmentSection)
                                    </div>
                                }

                                <div class="department-section-card__leader-copy">
                                    <span class="dashboard-kicker">@departmentSection.DisplayName</span>
                                    <strong>@(departmentSection.Representative?.RoleName ?? departmentSection.DisplayName)</strong>
                                    @if (!string.IsNullOrWhiteSpace(departmentSection.Representative?.DisplayName))
                                    {
                                        <span class="text-body-secondary">@departmentSection.Representative.DisplayName</span>
                                    }
                                </div>
                            </div>
                            <a class="department-section-card__link"
                               href="@ResolveRoute(departmentSection.Navigation.Route, AgentsPath)"
                               @onclick='() => NavigateToAsync(departmentSection.Navigation.Route, AgentsPath, "department-card", departmentSection.DepartmentKey, departmentSection.DisplayName)'
                               @onclick:preventDefault="true">@departmentSection.Navigation.Label</a>
                        </div>

                        @if (signals.Count > 0)
                        {
                            <dl class="cockpit-kpi-list department-section-card__metrics mb-0 mt-3">
                                @foreach (var signal in signals)
                                {
                                    <div><dt>@signal.Label</dt><dd>@signal.Value</dd></div>
                                }
                            </dl>
                        }
                        else
                        {
                            <div class="text-body-secondary mt-3">
                                <strong class="d-block">@departmentSection.EmptyState.Title</strong>
                                <span>@departmentSection.EmptyState.Message</span>
                            </div>
                        }
                    </section>
                }
            </div>
        </article>
        </div>
    }
</section>

@code {
    [Parameter]
    public Guid CompanyId { get; set; }

    [Parameter]
    public string? CompanyName { get; set; }

    [Parameter]
    public EventCallback<DashboardActionTelemetryContext> OnActionClick { get; set; }

    private bool isLoading = true;
    private string? errorMessage;
    private ExecutiveCockpitDashboardViewModel? dashboard;
    private DashboardFinanceSnapshotViewModel? financeSnapshot;
    private readonly HashSet<string> loadingWidgets = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, string> widgetErrors = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, DateTime> widgetSuccessUtc = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, DateTime> pendingWidgetRenderStartUtc = new(StringComparer.OrdinalIgnoreCase);
    private string? financeActionStatusMessage;
    private string? financeActionErrorMessage;
    private string? activeFinanceActionKey;
    private static readonly Meter WebMeter = new("VirtualCompany.ExecutiveCockpit.Web");
    private static readonly Histogram<double> WidgetFetchTiming = WebMeter.CreateHistogram<double>("executive_cockpit_widget_fetch_ms", "ms");
    private static readonly Histogram<double> WidgetRenderTiming = WebMeter.CreateHistogram<double>("executive_cockpit_widget_render_ms", "ms");

    private string DashboardPath => DashboardRoutes.EnsureCompanyContext("/dashboard", CompanyId, "/dashboard");
    private string AgentsPath => DashboardRoutes.EnsureCompanyContext("/agents", CompanyId, "/agents");
    private string TasksPath => DashboardRoutes.BuildTasksPath(CompanyId, filter: "today");
    private string WorkflowsPath => DashboardRoutes.EnsureCompanyContext("/workflows", CompanyId, "/workflows");
    private string ApprovalsPath => DashboardRoutes.BuildApprovalsPath(CompanyId);
    private string QueuePath => DashboardRoutes.EnsureCompanyContext(QueueRoutes.BuildPath(CompanyId), CompanyId, QueueRoutes.Home);
    private string ActivityFeedPath => DashboardRoutes.EnsureCompanyContext("/activity-feed", CompanyId, "/activity-feed");
    private string ResolvedCompanyName => !string.IsNullOrWhiteSpace(CompanyName)
        ? CompanyName!
        : dashboard?.CompanyName ?? "Workspace dashboard";
    private bool IsAnyWidgetLoading => loadingWidgets.Count > 0;
    private IReadOnlyList<BusinessSignalViewModel> VisibleBusinessSignals =>
        dashboard?.BusinessSignals
            .Take(3)
            .ToList()
        ?? [];
    private IReadOnlyList<DepartmentDashboardSectionViewModel> VisibleDepartmentSections =>
        dashboard?.DepartmentSections
            .Where(section => section.IsVisible)
            .OrderBy(section => section.DisplayOrder)
            .ToList()
        ?? [];

    private static string GetDepartmentRepresentativeInitials(DepartmentDashboardSectionViewModel section)
    {
        var source = !string.IsNullOrWhiteSpace(section.Representative?.DisplayName)
            ? section.Representative.DisplayName
            : section.DisplayName;
        var parts = source
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0]));

        var initials = new string(parts.ToArray());
        return string.IsNullOrWhiteSpace(initials) ? "?" : initials;
    }

    private static string GetDepartmentRepresentativeAvatarAlt(DepartmentDashboardSectionViewModel section)
    {
        var displayName = !string.IsNullOrWhiteSpace(section.Representative?.DisplayName)
            ? section.Representative.DisplayName
            : section.DisplayName;
        return $"{displayName} avatar";
    }

    private static readonly IReadOnlyDictionary<string, string> LegacyDepartmentAvatarMap =
        new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["/avatars/agents/finance-manager.png"] = "/images/laura.png",
            ["/avatars/agents/laura-finance.png"] = "/images/laura.png",
            ["/avatars/agents/sales-manager.png"] = "/images/paul.png",
            ["/avatars/agents/operations-manager.png"] = "/images/philip.png"
        };

    private static readonly IReadOnlyDictionary<string, string> DepartmentAvatarFallbackMap =
        new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["finance"] = "/images/laura.png",
            ["sales"] = "/images/paul.png",
            ["operations"] = "/images/philip.png"
        };

    private static string? ResolveDepartmentRepresentativeAvatarUrl(DepartmentDashboardSectionViewModel section)
    {
        var avatarUrl = section.Representative?.AvatarUrl?.Trim();
        if (!string.IsNullOrWhiteSpace(avatarUrl))
        {
            if (LegacyDepartmentAvatarMap.TryGetValue(avatarUrl, out var resolvedLegacyAvatarUrl))
            {
                return resolvedLegacyAvatarUrl;
            }

            if (avatarUrl.StartsWith("/images/", StringComparison.OrdinalIgnoreCase) ||
                avatarUrl.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
                avatarUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            {
                return avatarUrl;
            }
        }

        return DepartmentAvatarFallbackMap.TryGetValue(section.DepartmentKey, out var fallbackAvatarUrl)
            ? fallbackAvatarUrl
            : null;
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        foreach (var item in pendingWidgetRenderStartUtc.ToArray())
        {
            WidgetRenderTiming.Record(
                Math.Max(0, (DateTime.UtcNow - item.Value).TotalMilliseconds),
                WidgetTags(item.Key, "success"));
            pendingWidgetRenderStartUtc.Remove(item.Key);
        }

        return Task.CompletedTask;
    }

    private IReadOnlyList<OperationSummaryItem> OperationSummaryItems()
    {
        if (dashboard is null)
        {
            return [];
        }

        return
        [
            new("Pending approvals", dashboard.PendingApprovals.TotalCount, "Approvals still waiting on a decision.", ApprovalsPath, "open-approvals", "Review approvals"),
            new("Recent alerts", dashboard.Alerts.Count, "Alert volume currently visible to this role.", dashboard.Alerts.FirstOrDefault()?.Route is string alertRoute && !string.IsNullOrWhiteSpace(alertRoute) ? ResolveRoute(alertRoute, ActivityFeedPath) : ActivityFeedPath, "open-alerts", "Review alerts"),
            new("Active agents", dashboard.SetupState.AgentCount, "Agents configured for this company.", AgentsPath, "open-agents", "Open agents")
        ];
    }

    private static bool HasDrillRoute(string? route) =>
        !string.IsNullOrWhiteSpace(route) && route.StartsWith("/", StringComparison.Ordinal);

    private string ResolveRoute(string? route, string fallbackRoute) =>
        DashboardRoutes.EnsureCompanyContext(route, CompanyId, fallbackRoute);

    private async Task NavigateToAsync(string? route, string fallbackRoute, string area, string actionKey, string? label = null)
    {
        var resolvedRoute = ResolveRoute(route, fallbackRoute);
        if (OnActionClick.HasDelegate)
        {
            await OnActionClick.InvokeAsync(new DashboardActionTelemetryContext(area, actionKey, resolvedRoute, Label: label));
        }
        Navigation.NavigateTo(resolvedRoute);
    }

    private static string NormalizeCssToken(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "neutral" : value.Trim().ToLowerInvariant().Replace("_", "-");

    private bool IsWidgetLoading(string widgetKey) => loadingWidgets.Contains(widgetKey);

    private RenderFragment WidgetStatus(string widgetKey) => builder =>
    {
        var sequence = 0;
        if (loadingWidgets.Contains(widgetKey))
        {
            builder.OpenElement(sequence++, "p");
            builder.AddAttribute(sequence++, "class", "text-body-secondary mt-2 mb-0");
            builder.AddAttribute(sequence++, "role", "status");
            builder.AddAttribute(sequence++, "aria-live", "polite");
            builder.AddContent(sequence++, "Refreshing this widget...");
            builder.CloseElement();
        }
        else if (widgetErrors.TryGetValue(widgetKey, out var message))
        {
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "alert alert-warning mt-2 mb-0");
            builder.AddAttribute(sequence++, "role", "alert");
            builder.AddContent(sequence++, message);
            builder.CloseElement();
        }
        else if (widgetSuccessUtc.TryGetValue(widgetKey, out var refreshedUtc))
        {
            builder.OpenElement(sequence++, "p");
            builder.AddAttribute(sequence++, "class", "text-body-secondary mt-2 mb-0");
            builder.AddAttribute(sequence++, "aria-live", "polite");
            builder.AddContent(sequence++, $"Updated {refreshedUtc.ToLocalTime():g}");
            builder.CloseElement();
        }
    };

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;
        dashboard = null;
        financeSnapshot = null;
        widgetErrors.Clear();
        widgetSuccessUtc.Clear();

        try
        {
            var dashboardTask = ApiClient.GetAsync(CompanyId);
            var financeSnapshotTask = ApiClient.GetFinanceSnapshotAsync(CompanyId);
            dashboard = await dashboardTask;
            financeSnapshot = await financeSnapshotTask;
        }
        catch (OnboardingApiException ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RefreshDashboardWidgetsAsync()
    {
        await LoadAsync();
    }

    private Task RefreshBusinessSignalsAsync() =>
        RefreshWidgetAsync<List<BusinessSignalViewModel>>("business-signals");

    private Task RefreshFinanceWidgetAsync() =>
        RefreshWidgetAsync<ExecutiveCockpitFinanceViewModel>("finance");

    private async Task RefreshFinanceSnapshotAsync()
    {
        const string widgetKey = "finance-snapshot";
        loadingWidgets.Add(widgetKey);
        widgetErrors.Remove(widgetKey);
        widgetSuccessUtc.Remove(widgetKey);
        var stopwatch = Stopwatch.StartNew();

        try
        {
            financeSnapshot = await ApiClient.GetFinanceSnapshotAsync(CompanyId);
            WidgetFetchTiming.Record(stopwatch.Elapsed.TotalMilliseconds, WidgetTags(widgetKey, "success"));
            pendingWidgetRenderStartUtc[widgetKey] = DateTime.UtcNow;
            widgetSuccessUtc[widgetKey] = financeSnapshot?.AsOfUtc ?? DateTime.UtcNow;
        }
        catch (OnboardingApiException ex)
        {
            widgetErrors[widgetKey] = ex.Message;
            WidgetFetchTiming.Record(stopwatch.Elapsed.TotalMilliseconds, WidgetTags(widgetKey, "failure"));
            Logger.LogWarning(ex, "Executive cockpit widget {WidgetKey} refresh failed.", widgetKey);
        }
        finally
        {
            loadingWidgets.Remove(widgetKey);
        }
    }

    private async Task RefreshWidgetAsync<TPayload>(string widgetKey)
    {
        if (dashboard is null)
        {
            return;
        }

        loadingWidgets.Add(widgetKey);
        widgetErrors.Remove(widgetKey);
        widgetSuccessUtc.Remove(widgetKey);
        var stopwatch = Stopwatch.StartNew();

        try
        {
            var result = await ApiClient.GetWidgetAsync<TPayload>(CompanyId, widgetKey);
            ApplyWidgetPayload(widgetKey, result is null ? null : (object?)result.Payload);
            Logger.LogInformation(
                "Executive cockpit widget {WidgetKey} fetched in {ElapsedMilliseconds} ms.",
                widgetKey,
                stopwatch.Elapsed.TotalMilliseconds);
            WidgetFetchTiming.Record(stopwatch.Elapsed.TotalMilliseconds, WidgetTags(widgetKey, "success"));
            pendingWidgetRenderStartUtc[widgetKey] = DateTime.UtcNow;
            widgetSuccessUtc[widgetKey] = result?.GeneratedAtUtc ?? DateTime.UtcNow;
        }
        catch (OnboardingApiException ex)
        {
            widgetErrors[widgetKey] = ex.Message;
            WidgetFetchTiming.Record(stopwatch.Elapsed.TotalMilliseconds, WidgetTags(widgetKey, "failure"));
            Logger.LogWarning(ex, "Executive cockpit widget {WidgetKey} refresh failed.", widgetKey);
        }
        finally
        {
            loadingWidgets.Remove(widgetKey);
        }
    }

    private void ApplyWidgetPayload(string widgetKey, object? payload)
    {
        if (dashboard is null || payload is null)
        {
            return;
        }

        switch (widgetKey)
        {
            case "business-signals" when payload is List<BusinessSignalViewModel> businessSignals:
                dashboard.BusinessSignals = businessSignals;
                break;
            case "finance" when payload is ExecutiveCockpitFinanceViewModel finance:
                dashboard.Finance = finance;
                break;
        }
    }

    private static string SeverityBadgeClass(string severity) =>
        severity.Trim().ToLowerInvariant() switch
        {
            "critical" => "badge text-bg-danger",
            "warning" => "badge text-bg-warning",
            _ => "badge text-bg-secondary"
        };

    private RenderFragment AlertContent(ExecutiveCockpitAlertViewModel alert) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "span");
        builder.AddAttribute(sequence++, "class", "badge text-bg-warning");
        builder.AddContent(sequence++, alert.Severity);
        builder.CloseElement();
        builder.OpenElement(sequence++, "strong");
        builder.AddAttribute(sequence++, "class", "d-block mt-2");
        builder.AddContent(sequence++, alert.Title);
        builder.CloseElement();
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "text-body-secondary");
        builder.AddContent(sequence++, alert.Summary);
        builder.CloseElement();
        builder.OpenElement(sequence++, "small");
        builder.AddContent(sequence++, alert.OccurredUtc.ToLocalTime().ToString("g"));
        builder.CloseElement();
    };

    private RenderFragment ActivityContent(ExecutiveCockpitActivityItemViewModel item) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "strong");
        builder.AddContent(sequence++, item.Title);
        builder.CloseElement();
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "text-body-secondary");
        builder.AddContent(sequence++, item.Summary);
        builder.CloseElement();
        builder.OpenElement(sequence++, "small");
        builder.AddContent(sequence++, $"{item.ActivityType} | {item.OccurredUtc.ToLocalTime():g}");
        builder.CloseElement();
    };

    private bool IsFinanceActionRunning(string actionKey) =>
        string.Equals(activeFinanceActionKey, actionKey, StringComparison.OrdinalIgnoreCase);

    private IEnumerable<ExecutiveCockpitFinanceActionViewModel> FinanceActions(params string[] keys)
    {
        if (dashboard?.Finance is null || keys.Length == 0)
        {
            return [];
        }

        var keySet = new HashSet<string>(keys, StringComparer.OrdinalIgnoreCase);
        return dashboard.Finance.AvailableActions.Where(action => keySet.Contains(action.Key));
    }

    private async Task ExecuteFinanceActionAsync(ExecutiveCockpitFinanceActionViewModel action)
    {
        if (CompanyId == Guid.Empty || !action.IsEnabled)
        {
            return;
        }

        if (OnActionClick.HasDelegate)
        {
            await OnActionClick.InvokeAsync(new DashboardActionTelemetryContext("finance", action.Key, ResolveRoute(action.Route, FinanceRoutes.WithCompanyContext(FinanceRoutes.Home, CompanyId)), Label: action.Label));
        }
        activeFinanceActionKey = action.Key;
        financeActionStatusMessage = null;
        financeActionErrorMessage = null;

        try
        {
            if (string.Equals(action.HttpMethod, "GET", StringComparison.OrdinalIgnoreCase))
            {
                if (HasDrillRoute(action.Route))
                {
                    Navigation.NavigateTo(ResolveRoute(action.Route, FinanceRoutes.WithCompanyContext(FinanceRoutes.Home, CompanyId)));
                }
                return;
            }

            switch (action.Key)
            {
                case "review_invoice" when action.TargetId is Guid invoiceId:
                    await FinanceApiClient.StartInvoiceReviewWorkflowAsync(CompanyId, invoiceId);
                    financeActionStatusMessage = "Invoice review started.";
                    break;
                case "inspect_anomaly" when action.TargetId is Guid transactionId:
                    await FinanceApiClient.EvaluateTransactionAnomalyAsync(CompanyId, transactionId);
                    financeActionStatusMessage = "Anomaly inspection submitted.";
                    break;
                case "view_cash_position":
                    await FinanceApiClient.EvaluateCashPositionAsync(CompanyId);
                    financeActionStatusMessage = "Cash position refreshed.";
                    break;
                case "open_finance_summary":
                    break;
            }

            await RefreshFinanceWidgetAsync();
            if (HasDrillRoute(action.Route))
            {
                Navigation.NavigateTo(ResolveRoute(action.Route, FinanceRoutes.WithCompanyContext(FinanceRoutes.Home, CompanyId)));
            }
        }
        catch (FinanceApiException ex)
        {
            financeActionErrorMessage = ex.Message;
        }
        finally
        {
            activeFinanceActionKey = null;
        }
    }

    private static KeyValuePair<string, object?>[] WidgetTags(string widgetKey, string status) =>
    [
        new("widget", NormalizeCssToken(widgetKey)),
        new("status", status)
    ];

    private sealed record OperationSummaryItem(string Label, int Value, string Description, string Route, string ActionKey, string ActionLabel);
}
