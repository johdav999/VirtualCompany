@page "/dashboard"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject OnboardingApiClient ApiClient
@inject FinanceApiClient FinanceApiClient
@inject DashboardSummaryApiClient DashboardSummaryApiClient
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IDashboardInteractionService DashboardInteractionService
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@using VirtualCompany.Shared
@using VirtualCompany.Web.Services

<PageTitle>Dashboard</PageTitle>

@if (isLoading)
{
    <section class="py-4">
        <h1>Workspace dashboard</h1>
        <p class="text-body-secondary mb-0">Loading web dashboard context...</p>
    </section>
}
else if (CompanyId is null)
{
    <section class="py-4 dashboard-hero">
        <div class="dashboard-shell">
            <div class="wizard-card dashboard-summary">
                <span class="dashboard-kicker">Web-first onboarding</span>
                <h1>Choose a company dashboard or continue onboarding</h1>
                <p class="lead mb-3">The Blazor web app is the primary surface for company creation and guided setup. Resume onboarding for new workspaces, or open an active company dashboard.</p>
                <div class="dashboard-actions">
                    <a class="btn btn-primary" href="onboarding">Resume web onboarding</a>
                </div>

                @if (ActiveMemberships.Count > 0)
                {
                    <div class="template-grid mt-4">
                        @foreach (var membership in ActiveMemberships)
                        {
                            <a class="template-card text-decoration-none text-reset" href="@($"/dashboard?companyId={membership.CompanyId}")">
                                <strong>@membership.CompanyName</strong>
                                <div class="text-body-secondary mt-2">Role: @membership.MembershipRole | Access: @membership.Status</div>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <p class="text-body-secondary mt-4 mb-0">No active company membership is selected yet. Start in the onboarding wizard to create the first workspace from the web app.</p>
                }

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="alert alert-danger mt-4 mb-0">@errorMessage</div>
                }
            </div>

            <div class="wizard-card wizard-card--compact">
                <h2 class="h5">Dashboard handoff</h2>
                <ul class="mb-0">
                    <li>Incomplete company setup is routed back into onboarding.</li>
                    <li>Completed setup lands in the company dashboard with starter guidance.</li>
                    <li>Mobile remains a companion surface and does not own onboarding orchestration.</li>
                </ul>
            </div>
        </div>
    </section>
}
else
{
    <section class="py-4 dashboard-hero">
        <div class="company-dashboard-layout company-dashboard-layout--single">
            <div class="company-dashboard-main dashboard-home">
                <section class="wizard-card dashboard-finance-strip" data-testid="dashboard-finance-strip">
                    @if (CanResetFinanceData)
                    {
                        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                            <div>
                                <span class="dashboard-kicker">Finance admin</span>
                                <h2 class="h6 mb-0">Financial data reset</h2>
                            </div>
                            <button type="button"
                                    class="btn btn-outline-danger btn-sm"
                                    disabled="@isResettingFinancialData"
                                    @onclick="HandleResetFinancialDataAsync">
                                @(isResettingFinancialData ? "Resetting..." : "Reset finance data")
                            </button>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(financeResetErrorMessage))
                    {
                        <div class="alert alert-danger mb-3" role="alert">@financeResetErrorMessage</div>
                    }
                    else if (!string.IsNullOrWhiteSpace(financeResetSuccessMessage))
                    {
                        <div class="alert alert-success mb-3" role="status">@financeResetSuccessMessage</div>
                    }

                    <div class="dashboard-finance-strip__grid">
                        <article class="dashboard-finance-strip__item">
                            <span class="dashboard-finance-strip__label">Revenue</span>
                            <strong class="dashboard-finance-strip__value">@RevenueDisplay</strong>
                        </article>
                        <article class="dashboard-finance-strip__item">
                            <span class="dashboard-finance-strip__label">Costs</span>
                            <strong class="dashboard-finance-strip__value">@CostsDisplay</strong>
                        </article>
                        <article class="dashboard-finance-strip__item">
                            <span class="dashboard-finance-strip__label">Profit</span>
                            <strong class="dashboard-finance-strip__value">@ProfitDisplay</strong>
                        </article>
                        <article class="dashboard-finance-strip__item">
                            <span class="dashboard-finance-strip__label">Available cash</span>
                            <strong class="dashboard-finance-strip__value">@AvailableCashDisplay</strong>
                        </article>
                    </div>
                </section>

                <div class="dashboard-home-grid">
                    <section class="wizard-card dashboard-section-card dashboard-briefing-card" data-testid="latest-briefing-panel">
                        <div class="dashboard-section-card__heading">
                            <h2 class="h3 mb-0">Latest Briefing</h2>
                        </div>

                        <div class="dashboard-briefing-agent">
                            <img class="agent-avatar dashboard-briefing-agent__avatar"
                                 src="@LatestBriefingAvatarUrl"
                                 alt="@($"{LatestBriefingAgentName} avatar")" />
                            <div class="dashboard-briefing-agent__copy">
                                <strong class="dashboard-briefing-agent__name">@LatestBriefingAgentName</strong>
                                <span class="dashboard-briefing-agent__role">@LatestBriefingAgentRole</span>
                            </div>
                        </div>
                    </section>

                    <section class="wizard-card dashboard-section-card dashboard-briefing-summary-card" data-testid="latest-briefing-summary-panel">
                        <div class="dashboard-section-card__heading">
                            <h2 class="h3 mb-0">Summary</h2>
                        </div>

                        @if (isSummaryLoading)
                        {
                            <p class="text-body-secondary mb-0">Generating dashboard summary...</p>
                        }
                        else if (!string.IsNullOrWhiteSpace(summaryErrorMessage))
                        {
                            <p class="text-body-secondary mb-0">@summaryErrorMessage</p>
                        }
                        else if (briefingSummary is null || string.IsNullOrWhiteSpace(briefingSummary.Summary))
                        {
                            <p class="text-body-secondary mb-0">No briefing summary is available yet.</p>
                        }
                        else
                        {
                            <p class="mb-0">@briefingSummary.Summary</p>
                        }
                    </section>

                    @if (CompanyId is Guid actionCompanyId)
                    {
                        <div class="dashboard-home-grid__full">
                            <TopActionsList CompanyId="actionCompanyId"
                                            Count="5"
                                            Kicker=""
                                            Title="What to do next"
                                            Subtitle=""
                                            QueueLinkLabel="Open work"
                                            OnActionClick="HandleDashboardActionAsync" />
                        </div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="alert alert-danger mb-0">@errorMessage</div>
                }
            </div>
        </div>
    </section>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "companyId")]
    public Guid? CompanyId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "welcome")]
    public string? Welcome { get; set; }

    private bool isLoading = true;
    private CurrentUserContextViewModel? currentUser;
    private OnboardingProgressViewModel? onboardingProgress;
    private CompanyAccessViewModel? companyAccess;
    private CompanyDashboardEntryViewModel? dashboardEntry;
    private DashboardBriefingCardViewModel? briefings;
    private MonthlySummaryViewModel? financeMonthlySummary;
    private CashPositionSummaryViewModel? financeCashPosition;
    private DashboardBriefingSummaryViewModel? briefingSummary;
    private bool isSummaryLoading;
    private bool isResettingFinancialData;
    private string? summaryErrorMessage;
    private string? financeResetErrorMessage;
    private string? financeResetSuccessMessage;
    private string? errorMessage;
    private IJSObjectReference? telemetryModule;
    private DotNetObjectReference<Dashboard>? dotNetReference;
    private string? scrollTrackerId;
    private Guid? trackedInteractionCompanyId;
    private string RevenueDisplay => financeMonthlySummary?.Revenue ?? "USD --";
    private string CostsDisplay => financeMonthlySummary?.Expenses ?? "USD --";
    private string ProfitDisplay => financeMonthlySummary?.NetResult ?? "USD --";
    private string AvailableCashDisplay => financeCashPosition?.AvailableBalance ?? "USD --";
    private static string LatestBriefingAgentName => "LAURA";
    private static string LatestBriefingAgentRole => "Finance Manager";
    private static string LatestBriefingAvatarUrl => "/images/laura.png";
    private bool CanResetFinanceData =>
        companyAccess is not null &&
        FinanceAccess.CanAccessSandboxAdmin(companyAccess.MembershipRole);
    private IReadOnlyList<CompanyMembershipViewModel> ActiveMemberships =>
        currentUser?.Memberships
            .Where(x => string.Equals(x.Status, "active", StringComparison.OrdinalIgnoreCase))
            .ToList()
        ?? [];

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            currentUser = await ApiClient.GetCurrentUserContextAsync();
            onboardingProgress = await ApiClient.GetProgressAsync();
            companyAccess = null;
            dashboardEntry = null;
            briefings = null;
            financeMonthlySummary = null;
            briefingSummary = null;
            summaryErrorMessage = null;
            financeResetErrorMessage = null;
            financeResetSuccessMessage = null;
            isSummaryLoading = false;

            if (CompanyId is not Guid companyId)
            {
                if (onboardingProgress?.CanResume == true || string.Equals(onboardingProgress?.Status, "in_progress", StringComparison.OrdinalIgnoreCase))
                {
                    Navigation.NavigateTo("/onboarding", replace: true);
                    return;
                }

                if (currentUser?.ActiveCompany is not null)
                {
                    Navigation.NavigateTo($"/dashboard?companyId={currentUser.ActiveCompany.CompanyId}", replace: true);
                    return;
                }

                return;
            }

            companyAccess = await ApiClient.GetCompanyAccessAsync(companyId);
            dashboardEntry = companyAccess is null ? null : await ApiClient.GetDashboardEntryAsync(companyId);
            briefings = companyAccess is null ? null : await ApiClient.GetLatestBriefingsAsync(companyId);
            financeCashPosition = null;
            if (companyAccess is not null)
            {
                await LoadFinanceSnapshotAsync(companyId);
            }

            if (companyAccess is not null)
            {
                isSummaryLoading = true;
                try
                {
                    briefingSummary = await DashboardSummaryApiClient.GetBriefingSummaryAsync(companyId);
                }
                catch (OnboardingApiException ex)
                {
                    summaryErrorMessage = ex.Message;
                }
                finally
                {
                    isSummaryLoading = false;
                }
            }

            if (dashboardEntry?.RequiresOnboarding == true)
            {
                Navigation.NavigateTo("/onboarding", replace: true);
                return;
            }
        }
        catch (OnboardingApiException ex)
        {
            errorMessage = ex.Message;
            companyAccess = null;
            briefings = null;
            dashboardEntry = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (CompanyId is not Guid selectedCompanyId)
        {
            if (!string.IsNullOrWhiteSpace(scrollTrackerId))
            {
                await DisposeScrollTrackerAsync();
            }

            trackedInteractionCompanyId = null;
            DashboardInteractionService.EndSession();
            return;
        }

        if (trackedInteractionCompanyId != selectedCompanyId)
        {
            await DisposeScrollTrackerAsync();
            trackedInteractionCompanyId = selectedCompanyId;
            DashboardInteractionService.StartSession("dashboard", selectedCompanyId);
        }

        if (!string.IsNullOrWhiteSpace(scrollTrackerId)) return;

        try
        {
            telemetryModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/dashboardTelemetry.js");
            dotNetReference ??= DotNetObjectReference.Create(this);
            scrollTrackerId = await telemetryModule.InvokeAsync<string>("registerDashboardScrollTracker", dotNetReference);
        }
        catch
        {
            // Ignore telemetry bootstrapping failures in prerender and tests.
        }
    }

    [JSInvokable]
    public Task OnDashboardScrollDepthChanged(double depthPercentage)
    {
        DashboardInteractionService.RecordScrollDepth(depthPercentage);
        return Task.CompletedTask;
    }

    private Task HandleDashboardActionAsync(DashboardActionTelemetryContext context)
    {
        DashboardInteractionService.RecordAction(context);
        return Task.CompletedTask;
    }

    private async Task HandleResetFinancialDataAsync()
    {
        if (CompanyId is not Guid companyId || isResettingFinancialData || !CanResetFinanceData)
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            "Reset all generated financial data for this company? This keeps company setup and master data.");
        if (!confirmed)
        {
            return;
        }

        financeResetErrorMessage = null;
        financeResetSuccessMessage = null;
        isResettingFinancialData = true;

        try
        {
            var result = await FinanceApiClient.ResetFinancialDataAsync(companyId);
            financeResetSuccessMessage = $"Financial data reset completed. Deleted {result.TotalDeleted} record(s).";
            await LoadFinanceSnapshotAsync(companyId);
        }
        catch (FinanceApiException ex)
        {
            financeResetErrorMessage = ex.Message;
        }
        finally
        {
            isResettingFinancialData = false;
        }
    }

    private async Task LoadFinanceSnapshotAsync(Guid companyId)
    {
        try
        {
            var monthlySummary = await FinanceApiClient.GetMonthlySummaryAsync(companyId);
            financeMonthlySummary = FinanceSummaryPresenter.ToMonthlySummaryViewModel(monthlySummary);

            var referenceUtc = await FinanceApiClient.GetFinanceReferenceUtcAsync(companyId);
            var cashPosition = await FinanceApiClient.GetCashPositionAsync(companyId, referenceUtc);
            financeCashPosition = FinanceSummaryPresenter.ToCashPositionViewModel(cashPosition);
        }
        catch (FinanceApiException)
        {
            financeMonthlySummary = null;
            financeCashPosition = null;
        }
    }

    private async Task DisposeScrollTrackerAsync()
    {
        if (telemetryModule is null || string.IsNullOrWhiteSpace(scrollTrackerId))
        {
            scrollTrackerId = null;
            return;
        }

        try
        {
            await telemetryModule.InvokeVoidAsync("disposeDashboardScrollTracker", scrollTrackerId);
        }
        catch
        {
        }
        finally
        {
            scrollTrackerId = null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        await DisposeScrollTrackerAsync();
        DashboardInteractionService.EndSession();

        if (telemetryModule is not null)
        {
            try
            {
                await telemetryModule.DisposeAsync();
            }
            catch
            {
            }
        }

        dotNetReference?.Dispose();
    }
}
