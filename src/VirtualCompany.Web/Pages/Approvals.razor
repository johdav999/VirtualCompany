@page "/approvals"
@rendermode InteractiveServer
@inject ApprovalApiClient ApprovalApiClient
@inject InboxApiClient InboxApiClient
@inject OnboardingApiClient OnboardingApiClient
@inject NavigationManager Navigation
@inject ILogger<Approvals> Logger
@using Microsoft.AspNetCore.Components
@using VirtualCompany.Web.Services

<PageTitle>Approvals</PageTitle>

@if (isLoading)
{
    <section class="py-4">
        <h1>Approval inbox</h1>
        <p class="text-body-secondary mb-0">Loading approval requests...</p>
    </section>
}
else if (CompanyId is null)
{
    <section class="py-4 dashboard-hero">
        <div class="dashboard-shell">
            <div class="wizard-card dashboard-summary">
                <h1>Choose a company approval inbox</h1>
                <p class="lead mb-3">Approvals are scoped to a company workspace.</p>

                @if (ActiveMemberships.Count > 0)
                {
                    <div class="template-grid mt-4">
                        @foreach (var membership in ActiveMemberships)
                        {
                            <a class="template-card text-decoration-none text-reset" href="@BuildApprovalsUri(membership.CompanyId, null, null, null, Source)">
                                <strong>@membership.CompanyName</strong>
                                <div class="text-body-secondary mt-2">Role: @membership.MembershipRole | Access: @membership.Status</div>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <p class="text-body-secondary mb-0">No active company membership is available.</p>
                }

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="alert alert-danger mt-4 mb-0">@errorMessage</div>
                }
            </div>
        </div>
    </section>
}
else
{
    <section class="py-4 dashboard-hero">
        <div class="dashboard-shell approvals-layout">
            <div class="wizard-card dashboard-summary approvals-workbench">
                <span class="dashboard-kicker">Approval inbox</span>
                <h1>@(companyAccess?.CompanyName ?? "Approvals")</h1>
                <p class="text-body-secondary mb-0">Review the rationale and affected data before deciding.</p>

                <form class="agent-filter-bar mt-4" method="get">
                    <input type="hidden" name="companyId" value="@CompanyId" />
                    @if (ApprovalId is Guid approvalId)
                    {
                        <input type="hidden" name="approvalId" value="@approvalId" />
                    }
                    @if (!string.IsNullOrWhiteSpace(Source))
                    {
                        <input type="hidden" name="source" value="@Source" />
                    }
                    <div>
                        <label class="form-label" for="approval-status-filter">Status</label>
                        <select id="approval-status-filter" class="form-select" name="status">
                            <option value="" selected="@false">All approvals</option>
                            <option value="pending" selected="@IsSelected(StatusOrDefault, "pending")">Pending</option>
                            <option value="approved" selected="@IsSelected(StatusOrDefault, "approved")">Approved</option>
                            <option value="rejected" selected="@IsSelected(StatusOrDefault, "rejected")">Rejected</option>
                        </select>
                    </div>
                    <div class="dashboard-actions">
                        <button class="btn btn-primary" type="submit">Apply filter</button>
                        <a class="btn btn-outline-secondary" href="@BuildApprovalsUri(CompanyId!.Value, null, null, null, Source)">Clear</a>
                    </div>
                </form>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="alert alert-danger mt-4 mb-0">@errorMessage</div>
                }

                @if (approvals.Count == 0)
                {
                    <p class="text-body-secondary mt-4 mb-0">No approvals are waiting for review.</p>
                }
                else
                {
                    <ApprovalInbox Approvals="approvals" SelectedApprovalId="selectedApproval?.Id" OnSelectApproval="SelectApprovalAsync" />
                }
            </div>

            <div class="wizard-card wizard-card--compact approvals-detail-panel">
                <ApprovalDetail Approval="selectedApproval"
                                DecisionComment="@decisionComment"
                                DecisionCommentChanged="OnDecisionCommentChanged"
                                IsDeciding="isDeciding"
                                OnApprove='@(() => DecideAsync("approve"))'
                                OnReject='@(() => DecideAsync("reject"))' />
            </div>
        </div>
    </section>
}

@code {
    [SupplyParameterFromQuery(Name = "companyId")]
    public Guid? CompanyId { get; set; }

    [SupplyParameterFromQuery(Name = "approvalId")]
    public Guid? ApprovalId { get; set; }

    [SupplyParameterFromQuery(Name = "status")]
    public string? Status { get; set; }

    [SupplyParameterFromQuery(Name = DashboardRoutes.FilterQueryKey)]
    public string? Filter { get; set; }

    [SupplyParameterFromQuery(Name = DashboardRoutes.SourceQueryKey)]
    public string? Source { get; set; }

    private bool isLoading = true;
    private bool isDeciding;
    private CurrentUserContextViewModel? currentUser;
    private CompanyAccessViewModel? companyAccess;
    private List<ApprovalRequestViewModel> approvals = [];
    private ApprovalRequestViewModel? selectedApproval;
    private string? decisionComment;
    private string? errorMessage;
    private IReadOnlyList<CompanyMembershipViewModel> ActiveMemberships =>
        currentUser?.Memberships
            .Where(x => string.Equals(x.Status, "active", StringComparison.OrdinalIgnoreCase))
            .ToList()
        ?? [];

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        Logger.LogInformation(
            "Approvals page parameters updated. CompanyId: {CompanyId}. ApprovalId: {ApprovalId}. Status: {Status}. Filter: {Filter}. Source: {Source}.",
            CompanyId,
            ApprovalId,
            Status,
            Filter,
            Source);

        try
        {
            currentUser = await OnboardingApiClient.GetCurrentUserContextAsync();
            if (CompanyId is not Guid companyId)
            {
                if (currentUser?.ActiveCompany is not null)
                {
                    Navigation.NavigateTo($"/approvals?companyId={currentUser.ActiveCompany.CompanyId}", replace: true);
                }

                return;
            }

            companyAccess = await OnboardingApiClient.GetCompanyAccessAsync(companyId);
            await LoadApprovalInboxAsync(companyId);
        }
        catch (OnboardingApiException ex)
        {
            Logger.LogWarning(
                ex,
                "Approvals page failed to load. CompanyId: {CompanyId}. ApprovalId: {ApprovalId}. Status: {Status}.",
                CompanyId,
                ApprovalId,
                StatusOrDefault);
            errorMessage = ex.Message;
            approvals = [];
            selectedApproval = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SelectApprovalAsync(Guid approvalId)
    {
        if (CompanyId is not Guid companyId)
        {
            Logger.LogWarning("Approval selection ignored because no company id was present. ApprovalId: {ApprovalId}.", approvalId);
            return;
        }

        Logger.LogInformation(
            "Selecting approval from UI. CompanyId: {CompanyId}. ApprovalId: {ApprovalId}. PendingInboxFilter: {PendingInboxFilter}.",
            companyId,
            approvalId,
            IsPendingInboxFilter);

        try
        {
            selectedApproval = IsPendingInboxFilter
                ? await InboxApiClient.GetPendingApprovalDetailAsync(companyId, approvalId)
                : await ApprovalApiClient.GetAsync(companyId, approvalId);
            selectedApproval = ApprovalPresentationFormatter.Format(selectedApproval);
            decisionComment = null;
            Logger.LogInformation(
                "Approval detail loaded. CompanyId: {CompanyId}. ApprovalId: {ApprovalId}. TargetType: {TargetType}. TargetId: {TargetId}. AffectedEntities: {AffectedEntities}. Status: {Status}.",
                companyId,
                selectedApproval.Id,
                selectedApproval.TargetEntityType,
                selectedApproval.TargetEntityId,
                selectedApproval.AffectedEntities.Count,
                selectedApproval.Status);
        }
        catch (OnboardingApiException ex)
        {
            Logger.LogWarning(
                ex,
                "Approval detail request failed. CompanyId: {CompanyId}. ApprovalId: {ApprovalId}. PendingInboxFilter: {PendingInboxFilter}.",
                companyId,
                approvalId,
                IsPendingInboxFilter);
            errorMessage = ex.Message;
        }
    }

    private async Task DecideAsync(string decision)
    {
        if (CompanyId is not Guid companyId || selectedApproval?.CurrentStep is null)
        {
            Logger.LogWarning(
                "Approval decision ignored because selection was incomplete. CompanyId: {CompanyId}. SelectedApprovalId: {ApprovalId}. Decision: {Decision}. HasCurrentStep: {HasCurrentStep}.",
                CompanyId,
                selectedApproval?.Id,
                decision,
                selectedApproval?.CurrentStep is not null);
            return;
        }

        isDeciding = true;
        errorMessage = null;
        var approvalId = selectedApproval.Id;
        var stepId = selectedApproval.CurrentStep.Id;
        Logger.LogInformation(
            "Submitting approval decision from UI. CompanyId: {CompanyId}. ApprovalId: {ApprovalId}. StepId: {StepId}. Decision: {Decision}. PendingInboxFilter: {PendingInboxFilter}.",
            companyId,
            approvalId,
            stepId,
            decision,
            IsPendingInboxFilter);
        try
        {
            var request = new ApprovalDecisionRequest
            {
                ApprovalId = approvalId,
                StepId = stepId,
                Decision = decision,
                Comment = decisionComment
            };
            var result = IsPendingInboxFilter
                ? await InboxApiClient.DecidePendingApprovalAsync(companyId, approvalId, request)
                : await ApprovalApiClient.DecideAsync(companyId, approvalId, request);
            selectedApproval = ApprovalPresentationFormatter.Format(result.Approval);
            decisionComment = null;
            Logger.LogInformation(
                "Approval decision completed in UI. CompanyId: {CompanyId}. ApprovalId: {ApprovalId}. Finalized: {Finalized}. NewStatus: {Status}. NextStepId: {NextStepId}.",
                companyId,
                result.Approval.Id,
                result.IsFinalized,
                result.Approval.Status,
                result.NextStep?.Id);
            await LoadApprovalInboxAsync(companyId);
        }
        catch (OnboardingApiException ex)
        {
            Logger.LogWarning(
                ex,
                "Approval decision failed in UI. CompanyId: {CompanyId}. ApprovalId: {ApprovalId}. StepId: {StepId}. Decision: {Decision}. PendingInboxFilter: {PendingInboxFilter}.",
                companyId,
                approvalId,
                stepId,
                decision,
                IsPendingInboxFilter);
            errorMessage = ex.Message;
        }
        finally
        {
            isDeciding = false;
        }
    }

    private async Task LoadApprovalInboxAsync(Guid companyId)
    {
        Logger.LogInformation(
            "Loading approval inbox. CompanyId: {CompanyId}. PendingInboxFilter: {PendingInboxFilter}. ApprovalId: {ApprovalId}.",
            companyId,
            IsPendingInboxFilter,
            ApprovalId);

        if (IsPendingInboxFilter)
        {
            var inbox = await InboxApiClient.GetInboxAsync(companyId);
            approvals = ApprovalPresentationFormatter.Format(inbox.PendingApprovals.Select(ToApprovalRequestViewModel));
            if (ApprovalId is Guid approvalId)
            {
                try
                {
                    selectedApproval = ApprovalPresentationFormatter.Format(await InboxApiClient.GetPendingApprovalDetailAsync(companyId, approvalId));
                }
                catch (OnboardingApiException ex)
                {
                    Logger.LogInformation(
                        ex,
                        "Pending approval detail could not be reloaded from inbox. CompanyId: {CompanyId}. ApprovalId: {ApprovalId}. Falling back to first available pending approval.",
                        companyId,
                        approvalId);
                    selectedApproval = approvals.FirstOrDefault();
                }
            }
            else
            {
                selectedApproval = approvals.FirstOrDefault();
            }
            Logger.LogInformation(
                "Loaded pending approval inbox. CompanyId: {CompanyId}. ApprovalCount: {ApprovalCount}. SelectedApprovalId: {SelectedApprovalId}.",
                companyId,
                approvals.Count,
                selectedApproval?.Id);
            return;
        }

        approvals = ApprovalPresentationFormatter.Format(await ApprovalApiClient.ListAsync(companyId, StatusOrDefault));
        selectedApproval = ApprovalId is Guid selectedApprovalId
            ? ApprovalPresentationFormatter.Format(await ApprovalApiClient.GetAsync(companyId, selectedApprovalId))
            : approvals.FirstOrDefault();
        Logger.LogInformation(
            "Loaded approval list. CompanyId: {CompanyId}. ApprovalCount: {ApprovalCount}. SelectedApprovalId: {SelectedApprovalId}. StatusFilter: {StatusFilter}.",
            companyId,
            approvals.Count,
            selectedApproval?.Id,
            StatusOrDefault);
    }

    private static ApprovalRequestViewModel ToApprovalRequestViewModel(ApprovalInboxItemViewModel item) =>
        new()
        {
            Id = item.Id,
            CompanyId = item.CompanyId,
            TargetEntityType = item.TargetEntityType,
            TargetEntityId = item.TargetEntityId,
            ApprovalType = item.ApprovalType,
            Status = item.Status,
            RationaleSummary = item.RationaleSummary,
            RequestedByActorType = item.RequestedByActorType,
            RequestedByActorId = item.RequestedByActorId,
            RequiredRole = item.RequiredRole,
            RequiredUserId = item.RequiredUserId,
            AffectedDataSummary = item.AffectedDataSummary,
            ThresholdSummary = item.ThresholdSummary,
            CurrentStep = item.CurrentStep,
            CreatedAt = item.CreatedAt
        };

    private string? StatusOrDefault =>
        NormalizeApprovalStatus(Status, Filter);

    private bool IsPendingInboxFilter => string.Equals(StatusOrDefault, "pending", StringComparison.OrdinalIgnoreCase);

    private static bool IsSelected(string? currentValue, string expectedValue) =>
        string.Equals(currentValue?.Trim(), expectedValue, StringComparison.OrdinalIgnoreCase);

    private static string NormalizeApprovalStatus(string? status, string? filter)
    {
        if (!string.IsNullOrWhiteSpace(status))
        {
            return status.Trim();
        }

        return filter?.Trim().ToLowerInvariant() switch
        {
            "approved" => "approved",
            "rejected" => "rejected",
            _ => "pending"
        };
    }

    private static string? NormalizeApprovalFilter(string? filter, string? status)
    {
        if (!string.IsNullOrWhiteSpace(filter))
        {
            return filter.Trim().ToLowerInvariant();
        }

        return string.IsNullOrWhiteSpace(status) ? null : status.Trim().ToLowerInvariant();
    }

    private static string BuildApprovalsUri(Guid companyId, string? filter, string? status, Guid? approvalId, string? source) =>
        DashboardRoutes.BuildApprovalsPath(companyId, NormalizeApprovalFilter(filter, status), approvalId, source);

    private static bool IsPending(ApprovalRequestViewModel approval) =>
        string.Equals(approval.Status, "pending", StringComparison.OrdinalIgnoreCase);

    private Task OnDecisionCommentChanged(string? value)
    {
        decisionComment = value;
        return Task.CompletedTask;
    }
}
