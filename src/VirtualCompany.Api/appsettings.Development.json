{
  "ConnectionStrings": {
    "VirtualCompanyDb": "Server=localhost,1433;Database=virtualcompany;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=True"
  },
  "DatabaseInitialization": {
    "ApplyMigrationsOnStartup": true
  },
  "CompanyDocuments": {
    "MaxUploadBytes": 10485760,
    "Storage": {
      "RootPath": "App_Data/object-storage",
      "BaseUri": ""
    }
  },
  "ProactiveTaskCreation": {
    "DeduplicationWindowSeconds": 900
  },
  "KnowledgeChunking": {
    "TargetChunkLength": 1200,
    "OverlapLength": 200,
    "MaxChunkCountPerDocument": 256,
    "StrategyVersion": "paragraph-overlap-v1"
  },
  "KnowledgeEmbeddings": {
    "Provider": "deterministic",
    "BaseUrl": "https://api.openai.com/v1/",
    "ApiKey": "",
    "Model": "text-embedding-3-small",
    "ModelVersion": "deterministic-v1",
    "Dimensions": 256,
    "TimeoutSeconds": 30
  },
  "KnowledgeIndexing": {
    "Enabled": true,
    "BatchSize": 5,
    "ClaimTimeoutSeconds": 300,
    "PollIntervalSeconds": 10
  },
  "GroundedContextRetrievalCache": {
    "Enabled": true,
    "KeyVersion": "task-9-4-7-v1",
    "DefaultTtlSeconds": 60,
    "KnowledgeTtlSeconds": 120,
    "MemoryTtlSeconds": 30
  },
  "ExecutiveCockpitDashboardCache": {
    "Enabled": true,
    "KeyPrefix": "vc:executive-cockpit",
    "KeyVersion": "v1",
    "TtlSeconds": 60,
    "WidgetTtlSeconds": 60,
    "VersionTokenTtlSeconds": 86400
  },
  "DashboardBriefingSummary": {
    "Enabled": true,
    "BaseUrl": "https://api.openai.com/v1/",
    "ApiKey": "",
    "Model": "gpt-4.1-mini",
    "TimeoutSeconds": 30
  },

  "CompanyOutboxDispatcher": {
    "Enabled": true,
    "BatchSize": 20,
    "PollIntervalSeconds": 5,
    "MaxAttempts": 5,
    "RetryDelaySeconds": 30,
    "ClaimTimeoutSeconds": 60
  },
  "WorkflowScheduler": {
    "Enabled": true,
    "PollIntervalSeconds": 60,
    "LockTtlSeconds": 120,
    "BatchSize": 50,
    "LockKey": "workflow-scheduler"
  },
  "TriggerWorker": {
    "Enabled": true,
    "PollingIntervalSeconds": 10,
    "BatchSize": 50,
    "MaxRetryAttempts": 3,
    "RetryBackoffSeconds": 10,
    "LockKey": "trigger-evaluation-worker",
    "LockTtlSeconds": 120
  },
  "RedisExecutionCoordination": {
    "KeyPrefix": "vc",
    "DefaultLockLeaseSeconds": 120,
    "DefaultExecutionStateTtlSeconds": 3600
  },
  "Orchestration": {
    "MultiAgentCollaboration": {
      "MaxWorkers": 3,
      "MaxDepth": 1,
      "MaxRuntimeSeconds": 45,
      "MaxTotalSteps": 6
    }
  },
  "FinanceTransactionCreation": {
    "AllowNonSimulationTransactionCreation": false
  },
  "SimulationFeatures": {
    "UiVisible": true,
    "BackendExecutionEnabled": true,
    "BackgroundJobsEnabled": true,
    "DisabledMessage": "Simulation is disabled by configuration for this environment."
  },
  "SimulationStartup": {
    "StopRunningSessionsOnStartup": true
  },
  "Observability": {
    "CorrelationId": {
      "HeaderName": "X-Correlation-ID"
    },
    "Health": {
      "Path": "/health",
      "LivenessPath": "/health/live",
      "ReadinessPath": "/health/ready"
    },
    "RateLimiting": {
      "Enabled": false,
      "Chat": {
        "PermitLimit": 120,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Tasks": {
        "PermitLimit": 120,
        "WindowSeconds": 60,
        "QueueLimit": 0
      }
    },
    "Redis": {
      "ConnectionString": ""
    },
    "ObjectStorage": {
      "Enabled": false,
      "ServiceUri": "",
      "HealthPath": "/"
    }
  },
  "Logging": {
    "IncludeScopes": true,
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
