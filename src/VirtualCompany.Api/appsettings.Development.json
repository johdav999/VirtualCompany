      "ReadinessPath": "/health/ready"
    },
    "RateLimiting": {
      "Enabled": false,
      "Chat": {
        "PermitLimit": 120,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Tasks": {
        "PermitLimit": 120,
        "WindowSeconds": 60,
        "QueueLimit": 0
      }
    },
    "Redis": {
      "ConnectionString": ""
    },
    "ObjectStorage": {
      "Enabled": false,
      "ServiceUri": "",
      "HealthPath": "/"
    }
  },
  "Logging": {
    "IncludeScopes": true,
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
