{
  "ConnectionStrings": {
    "VirtualCompanyDb": "Host=localhost;Port=5432;Database=virtualcompany;Username=postgres;Password=postgres;Include Error Detail=true"
  },
  "DatabaseInitialization": {
    "ApplyMigrationsOnStartup": false
  },
  "CompanyOutboxDispatcher": {
    "Enabled": true,
    "BatchSize": 20,
    "PollIntervalSeconds": 5,
    "MaxAttempts": 5,
    "RetryDelaySeconds": 30,
    "ClaimTimeoutSeconds": 60
  },
  "Observability": {
    "CorrelationId": {
      "HeaderName": "X-Correlation-ID"
    },
    "Health": {
      "Path": "/health",
      "LivenessPath": "/health/live",
      "ReadinessPath": "/health/ready"
    },
    "RateLimiting": {
      "Enabled": true,
      "Chat": {
        "PermitLimit": 30,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Tasks": {
        "PermitLimit": 30,
        "WindowSeconds": 60,
        "QueueLimit": 0
      }
    },
    "Redis": {
      "ConnectionString": ""
    },
    "ObjectStorage": {
      "Enabled": false,
      "ServiceUri": "",
      "HealthPath": "/"
    }
  },
  "Logging": {
    "IncludeScopes": true,
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
