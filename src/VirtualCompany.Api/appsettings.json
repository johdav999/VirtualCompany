{
  "ConnectionStrings": {
    "VirtualCompanyDb": "Host=localhost;Port=5432;Database=virtualcompany;Username=postgres;Password=postgres;Include Error Detail=true"
  },
  "DatabaseInitialization": {
    "ApplyMigrationsOnStartup": false
  },
  "CompanyDocuments": {
    "MaxUploadBytes": 10485760,
    "Storage": {
      "RootPath": "App_Data/object-storage",
      "BaseUri": ""
    }
  },
  "KnowledgeChunking": {
    "TargetChunkLength": 1200,
    "OverlapLength": 200,
    "MaxChunkCountPerDocument": 256,
    "StrategyVersion": "paragraph-overlap-v1"
  },
  "KnowledgeEmbeddings": {
    "Provider": "deterministic",
    "BaseUrl": "https://api.openai.com/v1/",
    "ApiKey": "",
    "Model": "text-embedding-3-small",
    "ModelVersion": "deterministic-v1",
    "Dimensions": 256,
    "TimeoutSeconds": 30
  },
  "KnowledgeIndexing": {
    "Enabled": true,
    "BatchSize": 5,
    "ClaimTimeoutSeconds": 300,
    "PollIntervalSeconds": 10
  },
  "GroundedContextRetrievalCache": {
    "Enabled": true,
    "KeyVersion": "task-9-4-7-v1",
    "DefaultTtlSeconds": 60,
    "KnowledgeTtlSeconds": 120,
    "MemoryTtlSeconds": 30
  },
  "CompanyOutboxDispatcher": {
    "Enabled": true,
    "BatchSize": 20,
    "PollIntervalSeconds": 5,
    "MaxAttempts": 5,
    "RetryDelaySeconds": 30,
    "ClaimTimeoutSeconds": 60
  },
  "Observability": {
    "CorrelationId": {
      "HeaderName": "X-Correlation-ID"
    },
    "Health": {
      "Path": "/health",
      "LivenessPath": "/health/live",
      "ReadinessPath": "/health/ready"
    },
    "RateLimiting": {
      "Enabled": true,
      "Chat": {
        "PermitLimit": 30,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Tasks": {
        "PermitLimit": 30,
        "WindowSeconds": 60,
        "QueueLimit": 0
      }
    },
    "Redis": {
      "ConnectionString": ""
    },
    "ObjectStorage": {
      "Enabled": false,
      "ServiceUri": "",
      "HealthPath": "/"
    }
  },
  "Logging": {
    "IncludeScopes": true,
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
