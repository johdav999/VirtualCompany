+using Microsoft.AspNetCore.Authorization;
+using VirtualCompany.Application.Authorization;
+using VirtualCompany.Application.Tenancy;
+
+namespace VirtualCompany.Infrastructure.Authorization;
+
+public sealed class CompanyMembershipAuthorizationHandler : AuthorizationHandler<RequireCompanyMembershipRequirement>
+{
+    private readonly ICompanyContextAccessor _companyContextAccessor;
+    private readonly ICurrentUserAccessor _currentUserAccessor;
+
+    public CompanyMembershipAuthorizationHandler(ICompanyContextAccessor companyContextAccessor, ICurrentUserAccessor currentUserAccessor)
+    {
+        _companyContextAccessor = companyContextAccessor;
+        _currentUserAccessor = currentUserAccessor;
+    }
+
+    protected override Task HandleRequirementAsync(AuthorizationHandlerContext context, RequireCompanyMembershipRequirement requirement)
+    {
+        if (_currentUserAccessor.IsAuthenticated && _companyContextAccessor.Current.HasActiveMembership)
+        {
+            context.Succeed(requirement);
+        }
+
+        return Task.CompletedTask;
+    }
+}
+
+public sealed class CompanyRoleAuthorizationHandler : AuthorizationHandler<RequireCompanyRoleRequirement>
+{
+    private readonly ICompanyContextAccessor _companyContextAccessor;
+    private readonly ICurrentUserAccessor _currentUserAccessor;
+
+    public CompanyRoleAuthorizationHandler(ICompanyContextAccessor companyContextAccessor, ICurrentUserAccessor currentUserAccessor)
+    {
+        _companyContextAccessor = companyContextAccessor;
+        _currentUserAccessor = currentUserAccessor;
+    }
+
+    protected override Task HandleRequirementAsync(AuthorizationHandlerContext context, RequireCompanyRoleRequirement requirement)
+    {
+        var companyContext = _companyContextAccessor.Current;
+        if (_currentUserAccessor.IsAuthenticated && companyContext.HasActiveMembership && companyContext.Role is { } role && requirement.AllowedRoles.Contains(role))
+        {
+            context.Succeed(requirement);
+        }
+
+        return Task.CompletedTask;
+    }
+}
