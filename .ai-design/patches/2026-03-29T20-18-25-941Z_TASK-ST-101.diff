+using Microsoft.EntityFrameworkCore;
+using VirtualCompany.Application.Auth;
+using VirtualCompany.Application.Tenancy;
+using VirtualCompany.Domain.Enums;
+using VirtualCompany.Infrastructure.Persistence;
+
+namespace VirtualCompany.Infrastructure.Services;
+
+public sealed class UserContextService : IUserContextService
+{
+    private readonly VirtualCompanyDbContext _dbContext;
+    private readonly ICurrentUserAccessor _currentUserAccessor;
+    private readonly IUserProvisioningService _userProvisioningService;
+
+    public UserContextService(
+        VirtualCompanyDbContext dbContext,
+        ICurrentUserAccessor currentUserAccessor,
+        IUserProvisioningService userProvisioningService)
+    {
+        _dbContext = dbContext;
+        _currentUserAccessor = currentUserAccessor;
+        _userProvisioningService = userProvisioningService;
+    }
+
+    public async Task<CurrentUserResponse> GetCurrentUserAsync(CancellationToken cancellationToken = default)
+    {
+        if (!_currentUserAccessor.IsAuthenticated)
+        {
+            return new CurrentUserResponse(false, null);
+        }
+
+        var user = await _userProvisioningService.EnsureCurrentUserAsync(cancellationToken);
+        return new CurrentUserResponse(true, user);
+    }
+
+    public async Task<IReadOnlyList<CompanyMembershipDto>> GetMembershipsAsync(CancellationToken cancellationToken = default)
+    {
+        var userId = RequireUserId();
+
+        return await _dbContext.CompanyMemberships
+            .AsNoTracking()
+            .Where(x => x.UserId == userId)
+            .OrderBy(x => x.Company.Name)
+            .Select(x => new CompanyMembershipDto(x.Id, x.CompanyId, x.Company.Name, x.Role, x.Status))
+            .ToListAsync(cancellationToken);
+    }
+
+    public async Task<CompanyAccessSummaryDto?> GetCurrentCompanyAccessAsync(Guid companyId, CancellationToken cancellationToken = default)
+    {
+        var userId = RequireUserId();
+
+        return await _dbContext.CompanyMemberships
+            .AsNoTracking()
+            .Where(x => x.CompanyId == companyId && x.UserId == userId)
+            .Select(x => new CompanyAccessSummaryDto(
+                x.CompanyId,
+                x.Company.Name,
+                x.Id,
+                x.Role,
+                x.Status,
+                x.Status == CompanyMembershipStatus.Active))
+            .SingleOrDefaultAsync(cancellationToken);
+    }
+
+    public async Task<CompanyMembershipDto?> GetMembershipAsync(Guid companyId, Guid membershipId, CancellationToken cancellationToken = default)
+    {
+        return await _dbContext.CompanyMemberships
+            .AsNoTracking()
+            .Where(x => x.CompanyId == companyId && x.Id == membershipId)
+            .Select(x => new CompanyMembershipDto(
+                x.Id,
+                x.CompanyId,
+                x.Company.Name,
+                x.Role,
+                x.Status))
+            .SingleOrDefaultAsync(cancellationToken);
+    }
+
+    private Guid RequireUserId()
+    {
+        if (_currentUserAccessor.UserId is not { } userId)
+        {
+            throw new InvalidOperationException("The current request is not associated with a provisioned user.");
+        }
+
+        return userId;
+    }
+}
diff --git a/src/VirtualCompany.Infrastructure/Tenancy/CompanyContextPipeline.cs b/src/VirtualCompany.Infrastructure/Tenancy/CompanyContextPipeline.cs
new file mode 100644
--- /dev/null
+++ b/src/VirtualCompany.Infrastructure/Tenancy/CompanyContextPipeline.cs
@@ -0,0 +1,112 @@
+using Microsoft.AspNetCore.Mvc;
+using Microsoft.EntityFrameworkCore;
+using VirtualCompany.Application.Tenancy;
+using VirtualCompany.Infrastructure.Persistence;
+
+namespace VirtualCompany.Infrastructure.Tenancy;
+
+public sealed class CompanyContextAccessor : ICompanyContextAccessor
+{
+    public CompanyContext Current { get; } = new();
+}
+
+public sealed class CompanyContextResolutionMiddleware
+{
+    private readonly RequestDelegate _next;
+
+    public CompanyContextResolutionMiddleware(RequestDelegate next)
+    {
+        _next = next;
+    }
+
+    public async Task InvokeAsync(
+        HttpContext context,
+        ICompanyContextAccessor companyContextAccessor,
+        ICurrentUserAccessor currentUserAccessor,
+        VirtualCompanyDbContext dbContext)
+    {
+        companyContextAccessor.Current.Clear();
+
+        if (!currentUserAccessor.IsAuthenticated)
+        {
+            await _next(context);
+            return;
+        }
+
+        var routeCompanyId = context.Request.RouteValues.TryGetValue("companyId", out var routeValue)
+            ? routeValue?.ToString()
+            : null;
+
+        var headerCompanyId = context.Request.Headers.TryGetValue("X-Company-Id", out var headerValues)
+            ? headerValues.ToString()
+            : null;
+
+        if (string.IsNullOrWhiteSpace(routeCompanyId) && string.IsNullOrWhiteSpace(headerCompanyId))
+        {
+            await _next(context);
+            return;
+        }
+
+        if (!TryResolveCompanyId(routeCompanyId, headerCompanyId, out var companyId, out var error))
+        {
+            context.Response.StatusCode = StatusCodes.Status400BadRequest;
+            await context.Response.WriteAsJsonAsync(new ProblemDetails
+            {
+                Title = "Invalid company context.",
+                Detail = error,
+                Status = StatusCodes.Status400BadRequest
+            });
+            return;
+        }
+
+        if (currentUserAccessor.UserId is not { } userId)
+        {
+            context.Response.StatusCode = StatusCodes.Status401Unauthorized;
+            return;
+        }
+
+        var membership = await dbContext.CompanyMemberships
+            .AsNoTracking()
+            .Where(x => x.CompanyId == companyId && x.UserId == userId)
+            .Select(x => new
+            {
+                x.Id,
+                x.Role,
+                x.Status,
+                CompanyName = x.Company.Name
+            })
+            .SingleOrDefaultAsync(context.RequestAborted);
+
+        if (membership is null)
+        {
+            companyContextAccessor.Current.Set(companyId, null, null, null, null);
+        }
+        else
+        {
+            companyContextAccessor.Current.Set(companyId, membership.CompanyName, membership.Id, membership.Role, membership.Status);
+        }
+
+        await _next(context);
+    }
+
+    private static bool TryResolveCompanyId(string? routeCompanyId, string? headerCompanyId, out Guid companyId, out string? error)
+    {
+        companyId = Guid.Empty;
+        error = null;
+
+        if (!string.IsNullOrWhiteSpace(routeCompanyId) && !string.IsNullOrWhiteSpace(headerCompanyId) && !string.Equals(routeCompanyId, headerCompanyId, StringComparison.OrdinalIgnoreCase))
+        {
+            error = "The route companyId and X-Company-Id header must match when both are supplied.";
+            return false;
+        }
+
+        var rawCompanyId = string.IsNullOrWhiteSpace(routeCompanyId) ? headerCompanyId : routeCompanyId;
+        if (!Guid.TryParse(rawCompanyId, out companyId))
+        {
+            error = "The supplied company identifier is not a valid GUID.";
+            return false;
+        }
+
+        return true;
+    }
+}
