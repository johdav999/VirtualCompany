+using Microsoft.AspNetCore.Hosting;
+using Microsoft.AspNetCore.Mvc.Testing;
+using Microsoft.EntityFrameworkCore;
+using Microsoft.Extensions.DependencyInjection;
+using Microsoft.Extensions.DependencyInjection.Extensions;
+using VirtualCompany.Domain.Entities;
+using VirtualCompany.Domain.Enums;
+using VirtualCompany.Infrastructure.Persistence;
+
+namespace VirtualCompany.Api.Tests;
+
+public sealed class CustomWebApplicationFactory : WebApplicationFactory<Program>
+{
+    protected override void ConfigureWebHost(IWebHostBuilder builder)
+    {
+        builder.ConfigureServices(services =>
+        {
+            services.RemoveAll<DbContextOptions<VirtualCompanyDbContext>>();
+            services.AddDbContext<VirtualCompanyDbContext>(options =>
+                options.UseInMemoryDatabase($"virtual-company-tests-{Guid.NewGuid():N}"));
+
+            using var serviceProvider = services.BuildServiceProvider();
+            using var scope = serviceProvider.CreateScope();
+
+            var dbContext = scope.ServiceProvider.GetRequiredService<VirtualCompanyDbContext>();
+            dbContext.Database.EnsureCreated();
+            SeedData(dbContext);
+        });
+    }
+
+    private static void SeedData(VirtualCompanyDbContext dbContext)
+    {
+        dbContext.Users.RemoveRange(dbContext.Users);
+        dbContext.Companies.RemoveRange(dbContext.Companies);
+        dbContext.CompanyMemberships.RemoveRange(dbContext.CompanyMemberships);
+
+        var now = new DateTime(2026, 3, 29, 18, 0, 0, DateTimeKind.Utc);
+
+        var alice = new User
+        {
+            Id = TestData.AliceUserId,
+            Email = "alice@local.test",
+            DisplayName = "Alice Admin",
+            AuthProvider = "development",
+            AuthSubject = "alice",
+            CreatedAtUtc = now,
+            UpdatedAtUtc = now
+        };
+
+        var bob = new User
+        {
+            Id = TestData.BobUserId,
+            Email = "bob@local.test",
+            DisplayName = "Bob Employee",
+            AuthProvider = "development",
+            AuthSubject = "bob",
+            CreatedAtUtc = now,
+            UpdatedAtUtc = now
+        };
+
+        var adminCompany = new Company { Id = TestData.AdminCompanyId, Name = "Admin Corp", CreatedAtUtc = now, UpdatedAtUtc = now };
+        var employeeCompany = new Company { Id = TestData.EmployeeCompanyId, Name = "Employee Corp", CreatedAtUtc = now, UpdatedAtUtc = now };
+        var pendingCompany = new Company { Id = TestData.PendingCompanyId, Name = "Pending Corp", CreatedAtUtc = now, UpdatedAtUtc = now };
+        var forbiddenCompany = new Company { Id = TestData.ForbiddenCompanyId, Name = "Forbidden Corp", CreatedAtUtc = now, UpdatedAtUtc = now };
+
+        dbContext.Users.AddRange(alice, bob);
+        dbContext.Companies.AddRange(adminCompany, employeeCompany, pendingCompany, forbiddenCompany);
+        dbContext.CompanyMemberships.AddRange(
+            new CompanyMembership
+            {
+                Id = TestData.AliceAdminMembershipId,
+                CompanyId = TestData.AdminCompanyId,
+                UserId = TestData.AliceUserId,
+                Role = CompanyMembershipRole.Admin,
+                Status = CompanyMembershipStatus.Active,
+                CreatedAtUtc = now,
+                UpdatedAtUtc = now
+            },
+            new CompanyMembership
+            {
+                Id = TestData.AliceEmployeeMembershipId,
+                CompanyId = TestData.EmployeeCompanyId,
+                UserId = TestData.AliceUserId,
+                Role = CompanyMembershipRole.Employee,
+                Status = CompanyMembershipStatus.Active,
+                CreatedAtUtc = now,
+                UpdatedAtUtc = now
+            },
+            new CompanyMembership
+            {
+                Id = TestData.AlicePendingMembershipId,
+                CompanyId = TestData.PendingCompanyId,
+                UserId = TestData.AliceUserId,
+                Role = CompanyMembershipRole.Manager,
+                Status = CompanyMembershipStatus.Pending,
+                CreatedAtUtc = now,
+                UpdatedAtUtc = now
+            },
+            new CompanyMembership
+            {
+                Id = TestData.BobAdminCompanyMembershipId,
+                CompanyId = TestData.AdminCompanyId,
+                UserId = TestData.BobUserId,
+                Role = CompanyMembershipRole.Employee,
+                Status = CompanyMembershipStatus.Active,
+                CreatedAtUtc = now,
+                UpdatedAtUtc = now
+            });
+
+        dbContext.SaveChanges();
+    }
+}
+
+public static class TestData
+{
+    public static readonly Guid AliceUserId = Guid.Parse("11111111-1111-1111-1111-111111111111");
+    public static readonly Guid BobUserId = Guid.Parse("22222222-2222-2222-2222-222222222222");
+
+    public static readonly Guid AdminCompanyId = Guid.Parse("aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa");
+    public static readonly Guid EmployeeCompanyId = Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb");
+    public static readonly Guid PendingCompanyId = Guid.Parse("cccccccc-cccc-cccc-cccc-cccccccccccc");
+    public static readonly Guid ForbiddenCompanyId = Guid.Parse("dddddddd-dddd-dddd-dddd-dddddddddddd");
+
+    public static readonly Guid AliceAdminMembershipId = Guid.Parse("10000000-0000-0000-0000-000000000001");
+    public static readonly Guid AliceEmployeeMembershipId = Guid.Parse("10000000-0000-0000-0000-000000000002");
+    public static readonly Guid AlicePendingMembershipId = Guid.Parse("10000000-0000-0000-0000-000000000003");
+    public static readonly Guid BobAdminCompanyMembershipId = Guid.Parse("10000000-0000-0000-0000-000000000004");
+}
