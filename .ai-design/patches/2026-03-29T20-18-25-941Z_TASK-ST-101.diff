@@ -0,0 +1,110 @@
+using System.Net;
+using System.Net.Http.Json;
+using VirtualCompany.Application.Auth;
+using VirtualCompany.Application.Tenancy;
+using VirtualCompany.Domain.Enums;
+using Xunit;
+
+namespace VirtualCompany.Api.Tests;
+
+public sealed class TenantAwareAuthTests : IClassFixture<CustomWebApplicationFactory>
+{
+    private readonly CustomWebApplicationFactory _factory;
+
+    public TenantAwareAuthTests(CustomWebApplicationFactory factory)
+    {
+        _factory = factory;
+    }
+
+    [Fact]
+    public async Task Me_endpoint_returns_authenticated_user()
+    {
+        using var client = CreateAuthenticatedClient("alice");
+
+        var response = await client.GetFromJsonAsync<CurrentUserResponse>("/api/auth/me");
+
+        Assert.NotNull(response);
+        Assert.True(response!.Authenticated);
+        Assert.Equal("alice@local.test", response.User!.Email);
+        Assert.Equal("development", response.User.AuthProvider);
+    }
+
+    [Fact]
+    public async Task Memberships_endpoint_returns_current_users_memberships()
+    {
+        using var client = CreateAuthenticatedClient("alice");
+
+        var memberships = await client.GetFromJsonAsync<List<CompanyMembershipDto>>("/api/auth/memberships");
+
+        Assert.NotNull(memberships);
+        Assert.Equal(3, memberships!.Count);
+        Assert.Contains(memberships, x => x.CompanyId == TestData.AdminCompanyId && x.Role == CompanyMembershipRole.Admin && x.Status == CompanyMembershipStatus.Active);
+        Assert.Contains(memberships, x => x.CompanyId == TestData.PendingCompanyId && x.Status == CompanyMembershipStatus.Pending);
+    }
+
+    [Fact]
+    public async Task Active_membership_can_access_company_scope()
+    {
+        using var client = CreateAuthenticatedClient("alice");
+
+        var response = await client.GetAsync($"/api/companies/{TestData.AdminCompanyId}/access");
+
+        Assert.Equal(HttpStatusCode.OK, response.StatusCode);
+
+        var payload = await response.Content.ReadFromJsonAsync<CompanyAccessSummaryDto>();
+        Assert.NotNull(payload);
+        Assert.Equal(CompanyMembershipRole.Admin, payload!.Role);
+        Assert.True(payload.IsActive);
+    }
+
+    [Fact]
+    public async Task Missing_or_inactive_membership_is_forbidden()
+    {
+        using var client = CreateAuthenticatedClient("alice");
+
+        var noMembershipResponse = await client.GetAsync($"/api/companies/{TestData.ForbiddenCompanyId}/access");
+        var pendingMembershipResponse = await client.GetAsync($"/api/companies/{TestData.PendingCompanyId}/access");
+
+        Assert.Equal(HttpStatusCode.Forbidden, noMembershipResponse.StatusCode);
+        Assert.Equal(HttpStatusCode.Forbidden, pendingMembershipResponse.StatusCode);
+    }
+
+    [Fact]
+    public async Task Role_based_policy_uses_persisted_membership_role()
+    {
+        using var client = CreateAuthenticatedClient("alice");
+
+        var adminResponse = await client.GetAsync($"/api/companies/{TestData.AdminCompanyId}/admin-access");
+        var employeeResponse = await client.GetAsync($"/api/companies/{TestData.EmployeeCompanyId}/admin-access");
+
+        Assert.Equal(HttpStatusCode.OK, adminResponse.StatusCode);
+        Assert.Equal(HttpStatusCode.Forbidden, employeeResponse.StatusCode);
+    }
+
+    [Fact]
+    public async Task Membership_resource_queries_are_filtered_by_company_id()
+    {
+        using var client = CreateAuthenticatedClient("alice");
+
+        var allowedResponse = await client.GetAsync($"/api/companies/{TestData.AdminCompanyId}/memberships/{TestData.BobAdminCompanyMembershipId}");
+        var crossTenantResponse = await client.GetAsync($"/api/companies/{TestData.EmployeeCompanyId}/memberships/{TestData.BobAdminCompanyMembershipId}");
+
+        Assert.Equal(HttpStatusCode.OK, allowedResponse.StatusCode);
+        Assert.Equal(HttpStatusCode.NotFound, crossTenantResponse.StatusCode);
+    }
+
+    private HttpClient CreateAuthenticatedClient(string subject)
+    {
+        var client = _factory.CreateClient(new WebApplicationFactoryClientOptions
+        {
+            BaseAddress = new Uri("https://localhost")
+        });
+
+        client.DefaultRequestHeaders.Add("X-Auth-Subject", subject);
+        client.DefaultRequestHeaders.Add("X-Auth-Email", $"{subject}@local.test");
+        client.DefaultRequestHeaders.Add("X-Auth-Name", char.ToUpperInvariant(subject[0]) + subject[1..]);
+        client.DefaultRequestHeaders.Add("X-Auth-Provider", "development");
+
+        return client;
+    }
+}
