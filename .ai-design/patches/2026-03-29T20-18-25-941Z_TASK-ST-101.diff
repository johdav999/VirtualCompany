+using Microsoft.AspNetCore.Authorization;
+using VirtualCompany.Domain.Enums;
+
+namespace VirtualCompany.Application.Authorization;
+
+public static class CompanyAuthorizationPolicies
+{
+    public const string RequireCompanyMembership = "RequireCompanyMembership";
+    public const string RequireCompanyAdmin = "RequireCompanyAdmin";
+    public const string RequireCompanyManagerOrAbove = "RequireCompanyManagerOrAbove";
+}
+
+public sealed class RequireCompanyMembershipRequirement : IAuthorizationRequirement
+{
+}
+
+public sealed class RequireCompanyRoleRequirement : IAuthorizationRequirement
+{
+    public RequireCompanyRoleRequirement(params CompanyMembershipRole[] allowedRoles)
+    {
+        AllowedRoles = allowedRoles.ToHashSet();
+    }
+
+    public IReadOnlySet<CompanyMembershipRole> AllowedRoles { get; }
+}
