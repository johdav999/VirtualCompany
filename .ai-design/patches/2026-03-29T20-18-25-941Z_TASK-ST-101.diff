+using Microsoft.AspNetCore.Authorization;
+using Microsoft.AspNetCore.Mvc;
+using VirtualCompany.Application.Authorization;
+using VirtualCompany.Application.Tenancy;
+
+namespace VirtualCompany.Api.Controllers;
+
+[ApiController]
+[Route("api/companies")]
+[Authorize]
+public sealed class CompaniesController : ControllerBase
+{
+    private readonly IUserContextService _userContextService;
+
+    public CompaniesController(IUserContextService userContextService)
+    {
+        _userContextService = userContextService;
+    }
+
+    [HttpGet("{companyId:guid}/access")]
+    [Authorize(Policy = CompanyAuthorizationPolicies.RequireCompanyMembership)]
+    public async Task<ActionResult<CompanyAccessSummaryDto>> GetAccessAsync(Guid companyId, CancellationToken cancellationToken)
+    {
+        var access = await _userContextService.GetCurrentCompanyAccessAsync(companyId, cancellationToken);
+        return access is null ? NotFound() : Ok(access);
+    }
+
+    [HttpGet("{companyId:guid}/admin-access")]
+    [Authorize(Policy = CompanyAuthorizationPolicies.RequireCompanyAdmin)]
+    public async Task<ActionResult<object>> GetAdminAccessAsync(Guid companyId, CancellationToken cancellationToken)
+    {
+        var access = await _userContextService.GetCurrentCompanyAccessAsync(companyId, cancellationToken);
+        return access is null
+            ? NotFound()
+            : Ok(new
+            {
+                access.CompanyId,
+                access.CompanyName,
+                access.Role,
+                access.Status,
+                access.IsActive,
+                HasAdminAccess = true
+            });
+    }
+
+    [HttpGet("{companyId:guid}/memberships/{membershipId:guid}")]
+    [Authorize(Policy = CompanyAuthorizationPolicies.RequireCompanyAdmin)]
+    public async Task<ActionResult<CompanyMembershipDto>> GetMembershipAsync(Guid companyId, Guid membershipId, CancellationToken cancellationToken)
+    {
+        var membership = await _userContextService.GetMembershipAsync(companyId, membershipId, cancellationToken);
+        return membership is null ? NotFound() : Ok(membership);
+    }
+}
