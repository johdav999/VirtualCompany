+using System.Security.Claims;
+using VirtualCompany.Application.Auth;
+using VirtualCompany.Domain.Enums;
+
+namespace VirtualCompany.Application.Tenancy;
+
+public sealed class CompanyContext
+{
+    public Guid? CompanyId { get; private set; }
+    public string? CompanyName { get; private set; }
+    public Guid? MembershipId { get; private set; }
+    public CompanyMembershipRole? Role { get; private set; }
+    public CompanyMembershipStatus? Status { get; private set; }
+
+    public bool HasCompany => CompanyId.HasValue;
+
+    public bool HasActiveMembership => Status == CompanyMembershipStatus.Active;
+
+    public void Clear()
+    {
+        CompanyId = null;
+        CompanyName = null;
+        MembershipId = null;
+        Role = null;
+        Status = null;
+    }
+
+    public void Set(
+        Guid companyId,
+        string? companyName,
+        Guid? membershipId,
+        CompanyMembershipRole? role,
+        CompanyMembershipStatus? status)
+    {
+        CompanyId = companyId;
+        CompanyName = companyName;
+        MembershipId = membershipId;
+        Role = role;
+        Status = status;
+    }
+}
+
+public interface ICompanyContextAccessor
+{
+    CompanyContext Current { get; }
+}
+
+public interface ICurrentUserAccessor
+{
+    ClaimsPrincipal Principal { get; }
+    bool IsAuthenticated { get; }
+    Guid? UserId { get; }
+}
+
+public sealed record CompanyMembershipDto(Guid MembershipId, Guid CompanyId, string CompanyName, CompanyMembershipRole Role, CompanyMembershipStatus Status);
+
+public sealed record CompanyAccessSummaryDto(Guid CompanyId, string CompanyName, Guid MembershipId, CompanyMembershipRole Role, CompanyMembershipStatus Status, bool IsActive);
+
+public interface IUserContextService
+{
+    Task<CurrentUserResponse> GetCurrentUserAsync(CancellationToken cancellationToken = default);
+    Task<IReadOnlyList<CompanyMembershipDto>> GetMembershipsAsync(CancellationToken cancellationToken = default);
+    Task<CompanyAccessSummaryDto?> GetCurrentCompanyAccessAsync(Guid companyId, CancellationToken cancellationToken = default);
+    Task<CompanyMembershipDto?> GetMembershipAsync(Guid companyId, Guid membershipId, CancellationToken cancellationToken = default);
+}
