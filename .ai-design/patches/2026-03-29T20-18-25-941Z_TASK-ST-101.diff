@@ -0,0 +1,241 @@
+using System.Security.Claims;
+using System.Text.Encodings.Web;
+using Microsoft.AspNetCore.Authentication;
+using Microsoft.EntityFrameworkCore;
+using Microsoft.Extensions.Logging;
+using Microsoft.Extensions.Options;
+using Microsoft.Extensions.Primitives;
+using VirtualCompany.Application.Auth;
+using VirtualCompany.Application.Tenancy;
+using VirtualCompany.Domain.Entities;
+using VirtualCompany.Infrastructure.Persistence;
+
+namespace VirtualCompany.Infrastructure.Auth;
+
+public static class DevelopmentAuthenticationDefaults
+{
+    public const string Scheme = "DevelopmentHeader";
+    public const string ProviderName = "development";
+}
+
+public static class CurrentUserClaimTypes
+{
+    public const string InternalUserId = "vc:user_id";
+    public const string AuthProvider = "vc:auth_provider";
+}
+
+public sealed class DevelopmentHeaderAuthenticationHandler : AuthenticationHandler<AuthenticationSchemeOptions>
+{
+    public DevelopmentHeaderAuthenticationHandler(
+        IOptionsMonitor<AuthenticationSchemeOptions> options,
+        ILoggerFactory logger,
+        UrlEncoder encoder)
+        : base(options, logger, encoder)
+    {
+    }
+
+    protected override Task<AuthenticateResult> HandleAuthenticateAsync()
+    {
+        if (!Request.Headers.TryGetValue("X-Auth-Subject", out var subjectValues) || StringValues.IsNullOrEmpty(subjectValues))
+        {
+            return Task.FromResult(AuthenticateResult.NoResult());
+        }
+
+        var subject = subjectValues.ToString();
+        var provider = Request.Headers.TryGetValue("X-Auth-Provider", out var providerValues) && !StringValues.IsNullOrEmpty(providerValues)
+            ? providerValues.ToString()
+            : DevelopmentAuthenticationDefaults.ProviderName;
+        var email = Request.Headers.TryGetValue("X-Auth-Email", out var emailValues) && !StringValues.IsNullOrEmpty(emailValues)
+            ? emailValues.ToString()
+            : $"{subject}@local.test";
+        var displayName = Request.Headers.TryGetValue("X-Auth-Name", out var nameValues) && !StringValues.IsNullOrEmpty(nameValues)
+            ? nameValues.ToString()
+            : email;
+
+        var claims = new List<Claim>
+        {
+            new(ClaimTypes.NameIdentifier, subject),
+            new(ClaimTypes.Email, email),
+            new(ClaimTypes.Name, displayName),
+            new(CurrentUserClaimTypes.AuthProvider, provider)
+        };
+
+        var identity = new ClaimsIdentity(claims, DevelopmentAuthenticationDefaults.Scheme);
+        var principal = new ClaimsPrincipal(identity);
+        var ticket = new AuthenticationTicket(principal, DevelopmentAuthenticationDefaults.Scheme);
+
+        return Task.FromResult(AuthenticateResult.Success(ticket));
+    }
+}
+
+public sealed class DevelopmentClaimsAuthProvider : IAuthProvider
+{
+    public string Name => DevelopmentAuthenticationDefaults.ProviderName;
+
+    public ExternalIdentity? GetIdentity(ClaimsPrincipal principal)
+    {
+        if (principal.Identity?.IsAuthenticated != true)
+        {
+            return null;
+        }
+
+        var subject = principal.FindFirstValue(ClaimTypes.NameIdentifier);
+        if (string.IsNullOrWhiteSpace(subject))
+        {
+            return null;
+        }
+
+        return new ExternalIdentity(
+            Name,
+            subject,
+            principal.FindFirstValue(ClaimTypes.Email),
+            principal.FindFirstValue(ClaimTypes.Name));
+    }
+}
+
+public sealed class HttpContextExternalIdentityAccessor : IExternalIdentityAccessor
+{
+    private readonly IEnumerable<IAuthProvider> _authProviders;
+    private readonly IHttpContextAccessor _httpContextAccessor;
+
+    public HttpContextExternalIdentityAccessor(IEnumerable<IAuthProvider> authProviders, IHttpContextAccessor httpContextAccessor)
+    {
+        _authProviders = authProviders;
+        _httpContextAccessor = httpContextAccessor;
+    }
+
+    public ExternalIdentity? GetCurrentIdentity()
+    {
+        var principal = _httpContextAccessor.HttpContext?.User;
+        if (principal?.Identity?.IsAuthenticated != true)
+        {
+            return null;
+        }
+
+        var providerName = principal.FindFirstValue(CurrentUserClaimTypes.AuthProvider) ?? DevelopmentAuthenticationDefaults.ProviderName;
+        var provider = _authProviders.FirstOrDefault(x => string.Equals(x.Name, providerName, StringComparison.OrdinalIgnoreCase));
+        return provider?.GetIdentity(principal);
+    }
+}
+
+public sealed class HttpContextCurrentUserAccessor : ICurrentUserAccessor
+{
+    private readonly IHttpContextAccessor _httpContextAccessor;
+
+    public HttpContextCurrentUserAccessor(IHttpContextAccessor httpContextAccessor)
+    {
+        _httpContextAccessor = httpContextAccessor;
+    }
+
+    public ClaimsPrincipal Principal => _httpContextAccessor.HttpContext?.User ?? new ClaimsPrincipal(new ClaimsIdentity());
+
+    public bool IsAuthenticated => Principal.Identity?.IsAuthenticated == true;
+
+    public Guid? UserId
+    {
+        get
+        {
+            var rawValue = Principal.FindFirstValue(CurrentUserClaimTypes.InternalUserId);
+            return Guid.TryParse(rawValue, out var userId) ? userId : null;
+        }
+    }
+}
+
+public sealed class UserProvisioningService : IUserProvisioningService
+{
+    private readonly VirtualCompanyDbContext _dbContext;
+    private readonly IExternalIdentityAccessor _externalIdentityAccessor;
+    private readonly IHttpContextAccessor _httpContextAccessor;
+
+    public UserProvisioningService(
+        VirtualCompanyDbContext dbContext,
+        IExternalIdentityAccessor externalIdentityAccessor,
+        IHttpContextAccessor httpContextAccessor)
+    {
+        _dbContext = dbContext;
+        _externalIdentityAccessor = externalIdentityAccessor;
+        _httpContextAccessor = httpContextAccessor;
+    }
+
+    public async Task<CurrentUserDto> EnsureCurrentUserAsync(CancellationToken cancellationToken = default)
+    {
+        var identity = _externalIdentityAccessor.GetCurrentIdentity()
+            ?? throw new InvalidOperationException("An authenticated external identity is required.");
+
+        var normalizedEmail = string.IsNullOrWhiteSpace(identity.Email) ? $"{identity.Subject}@local.test" : identity.Email.Trim();
+        var normalizedDisplayName = string.IsNullOrWhiteSpace(identity.DisplayName) ? normalizedEmail : identity.DisplayName.Trim();
+
+        var user = await _dbContext.Users
+            .SingleOrDefaultAsync(x => x.AuthProvider == identity.Provider && x.AuthSubject == identity.Subject, cancellationToken);
+
+        if (user is null)
+        {
+            user = await _dbContext.Users
+                .SingleOrDefaultAsync(x => x.Email == normalizedEmail, cancellationToken);
+        }
+
+        var now = DateTime.UtcNow;
+
+        if (user is null)
+        {
+            user = new User
+            {
+                Email = normalizedEmail,
+                DisplayName = normalizedDisplayName,
+                AuthProvider = identity.Provider,
+                AuthSubject = identity.Subject,
+                CreatedAtUtc = now,
+                UpdatedAtUtc = now
+            };
+
+            _dbContext.Users.Add(user);
+        }
+        else
+        {
+            user.Email = normalizedEmail;
+            user.DisplayName = normalizedDisplayName;
+            user.AuthProvider = identity.Provider;
+            user.AuthSubject = identity.Subject;
+            user.UpdatedAtUtc = now;
+        }
+
+        if (_dbContext.ChangeTracker.HasChanges())
+        {
+            await _dbContext.SaveChangesAsync(cancellationToken);
+        }
+
+        var claimsIdentity = _httpContextAccessor.HttpContext?.User.Identity as ClaimsIdentity;
+        if (claimsIdentity is not null)
+        {
+            var existingClaim = claimsIdentity.FindFirst(CurrentUserClaimTypes.InternalUserId);
+            if (existingClaim is not null)
+            {
+                claimsIdentity.RemoveClaim(existingClaim);
+            }
+
+            claimsIdentity.AddClaim(new Claim(CurrentUserClaimTypes.InternalUserId, user.Id.ToString()));
+        }
+
+        return new CurrentUserDto(user.Id, user.Email, user.DisplayName, user.AuthProvider, user.AuthSubject);
+    }
+}
+
+public sealed class CurrentUserSynchronizationMiddleware
+{
+    private readonly RequestDelegate _next;
+
+    public CurrentUserSynchronizationMiddleware(RequestDelegate next)
+    {
+        _next = next;
+    }
+
+    public async Task InvokeAsync(HttpContext context, IUserProvisioningService userProvisioningService)
+    {
+        if (context.User.Identity?.IsAuthenticated == true)
+        {
+            await userProvisioningService.EnsureCurrentUserAsync(context.RequestAborted);
+        }
+
+        await _next(context);
+    }
+}
